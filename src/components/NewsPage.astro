function fmtNum(n, dec) {
  if (n == null || !isFinite(n)) return '—';
  return n.toLocaleString('en-US', { minimumFractionDigits: dec||0, maximumFractionDigits: dec||0 });
}

function chgHtml(c) {
  if (c == null || !isFinite(c)) return '<span class="mkt-chg neu">—</span>';
  var cls = c > 0 ? 'pos' : (c < 0 ? 'neg' : 'neu');
  var arrow = c > 0 ? '▲' : (c < 0 ? '▼' : '');
  return '<span class="mkt-chg ' + cls + '">' + arrow + Math.abs(c).toFixed(2) + '%</span>';
}

function mktRow(name, price, change) {
  return '<div class="mkt-row">' +
    '<span class="mkt-name">' + name + '</span>' +
    '<span class="mkt-price">' + price + '</span>' +
    chgHtml(change) +
    '</div>';
}

function fetchMarkets() {
  Promise.all([
    fetch('/api/markets').then(function(r){ return r.json(); }),
    fetch('/api/crypto').then(function(r){ return r.json(); }),
  ]).then(function(results) {
    var mkt = results[0];
    var crypto = results[1];

    // FX
    var fxHtml = '';
    if (mkt.irr) {
      if (mkt.irr.usd) fxHtml += mktRow('USD / Toman', fmtNum(mkt.irr.usd.price, 0)+' T', mkt.irr.usd.change);
      if (mkt.irr.eur) fxHtml += mktRow('EUR / Toman', fmtNum(mkt.irr.eur.price, 0)+' T', mkt.irr.eur.change);
    }
    if (mkt.eur_rsd) fxHtml += mktRow('EUR / RSD', fmtNum(mkt.eur_rsd.price, 2), mkt.eur_rsd.change);
    document.getElementById('mkt-fx').innerHTML = fxHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Commodities
    var commHtml = '';
    if (mkt.commodities) {
      if (mkt.commodities.gold)   commHtml += mktRow('Gold (oz)',   '$'+fmtNum(mkt.commodities.gold.price,   0), mkt.commodities.gold.change);
      if (mkt.commodities.silver) commHtml += mktRow('Silver (oz)', '$'+fmtNum(mkt.commodities.silver.price, 2), mkt.commodities.silver.change);
      if (mkt.commodities.brent)  commHtml += mktRow('Brent (bbl)', '$'+fmtNum(mkt.commodities.brent.price,  2), mkt.commodities.brent.change);
      if (mkt.commodities.wti)    commHtml += mktRow('WTI (bbl)',   '$'+fmtNum(mkt.commodities.wti.price,    2), mkt.commodities.wti.change);
    }
    document.getElementById('mkt-comm').innerHTML = commHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Indices — show all available
    var idxHtml = '';
    (mkt.indices||[]).forEach(function(idx) {
      idxHtml += mktRow(idx.name || idx.short, fmtNum(idx.price, 0), idx.change);
    });
    document.getElementById('mkt-indices').innerHTML = idxHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Crypto top 10
    var cryptoHtml = '';
    var coins = Array.isArray(crypto) ? crypto.slice(0, 10) : [];
    coins.forEach(function(c) {
      var sym = (c.symbol||'').toUpperCase();
      var px  = c.current_price;
      var dec = px >= 1000 ? 0 : (px >= 1 ? 2 : 4);
      var chg = c.price_change_percentage_24h_in_currency || c.price_change_percentage_24h || null;
      cryptoHtml += mktRow(sym, '$'+fmtNum(px, dec), chg);
    });
    document.getElementById('mkt-crypto').innerHTML = cryptoHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Timestamp
    var upd = document.getElementById('mkt-updated');
    if (upd && mkt.updated) {
      var d = new Date(mkt.updated);
      upd.textContent = '↻ ' + d.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' });
    }
  }).catch(function(e){ console.warn('Markets fetch error', e); });
}

fetchMarkets();
setInterval(fetchMarkets, 300000); // 5 min

// ── Collapsible market sections (MetaTrader style) ────────────────────────
(function() {
  function wireMarketHeads() {
    document.querySelectorAll('.mkt-head').forEach(function(hd) {
      if (hd.dataset.wired) return;
      hd.dataset.wired = '1';
      var arrow = document.createElement('span');
      arrow.className = 'mkt-arrow';
      arrow.textContent = '▾';
      hd.appendChild(arrow);
      hd.addEventListener('click', function() {
        var rows = hd.nextElementSibling;
        while (rows && !rows.classList.contains('mkt-rows')) rows = rows.nextElementSibling;
        if (!rows) return;
        var collapsed = rows.classList.toggle('mkt-rows-hidden');
        arrow.style.transform = collapsed ? 'rotate(-90deg)' : '';
      });
    });
  }
  // Wire immediately (headers are in HTML), and again after first markets fetch
  wireMarketHeads();
  document.addEventListener('marketsRendered', wireMarketHeads);
})();

// ─────────────────────────────────────────────────────────────────────────────
// TITLE NEWS — RSS feed, auto-refresh every 5 min
// ─────────────────────────────────────────────────────────────────────────────
var rssArticles = [], rssLangFilter = 'all', searchTerm = '';

function timeAgo(p) {
  if (!p) return '';
  try {
    var d = new Date(p), f = (Date.now()-d.getTime())/60000;
    if (f < 1)    return t.timeAgo.now;
    if (f < 60)   return Math.round(f) + t.timeAgo.min;
    if (f < 1440) return Math.round(f/60) + t.timeAgo.hr;
    return Math.round(f/1440) + t.timeAgo.days;
  } catch(e){ return ''; }
}

function renderRssList() {
  var list = document.getElementById('rss-list');
  if (!list) return;
  var q = searchTerm.toLowerCase();
  var filtered = rssArticles.filter(function(a) {
    if (rssLangFilter !== 'all' && a.lang !== rssLangFilter) return false;
    if (q) return (a.title||'').toLowerCase().indexOf(q) >= 0;
    return true;
  });
  if (!filtered.length) {
    list.innerHTML = '<div style="color:var(--silver-muted);font-size:12px;padding:16px 0;">' + (t.noResults||'No results.') + '</div>';
    return;
  }
  list.innerHTML = '';
  filtered.slice(0, 50).forEach(function(a) {
    var row = document.createElement('div');
    row.className = 'rss-row';
    if (a.lang === 'fa' || a.lang === 'ar') row.setAttribute('dir', 'rtl');
    if (a.link) {
      row.dataset.url = a.link;
      row.onclick = function() { window.open(this.dataset.url, '_blank', 'noopener,noreferrer'); };
    }
    row.innerHTML =
      '<div class="rss-row-top">' +
        '<span class="rss-src">' + escHtml(a.source||'') + '</span>' +
        '<span class="rss-time">' + timeAgo(a.pubDate) + '</span>' +
      '</div>' +
      '<div class="rss-title">' + decodeEntities(a.title||'') + '</div>';
    list.appendChild(row);
  });
  var meta = document.getElementById('news-meta');
  if (meta) meta.textContent = (t.metaSources||'{n} articles').replace('{n}', rssArticles.length);
}

function buildRssLangTabs(articles) {
  var langs = {};
  articles.forEach(function(a){ langs[a.lang] = (langs[a.lang]||0)+1; });
  var row = document.getElementById('rss-lang-row');
  if (!row) return;
  row.innerHTML = '';
  var allBtn = document.createElement('button');
  allBtn.className = 'lang-tab active';
  allBtn.textContent = t.allNews;
  allBtn.addEventListener('click', function() {
    rssLangFilter = 'all';
    document.querySelectorAll('#rss-lang-row .lang-tab').forEach(function(x){ x.classList.remove('active'); });
    allBtn.classList.add('active'); renderRssList();
  });
  row.appendChild(allBtn);
  Object.keys(langs).sort().forEach(function(l) {
    var tab = document.createElement('button');
    tab.className = 'lang-tab';
    tab.textContent = (t.langNames[l]||l) + ' ('+langs[l]+')';
    tab.addEventListener('click', function() {
      rssLangFilter = l;
      document.querySelectorAll('#rss-lang-row .lang-tab').forEach(function(x){ x.classList.remove('active'); });
      tab.classList.add('active'); renderRssList();
    });
    row.appendChild(tab);
  });
}

function fetchTitleNews() {
  var updEl = document.getElementById('rss-updated');
  if (updEl) updEl.textContent = '↻…';
  fetch('/api/news', { cache: 'no-cache' }).then(function(r){ return r.json(); }).then(function(data) {
    rssArticles = data.articles || [];
    buildRssLangTabs(rssArticles);
    renderRssList();
    if (updEl) updEl.textContent = new Date().toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' });
  }).catch(function(e) {
    var list = document.getElementById('rss-list');
    if (list) list.innerHTML = '<div style="color:var(--silver-muted);font-size:12px;padding:16px 0;">' + (t.failedLoad||'Failed to load.') + '</div>';
  });
}

fetchTitleNews();
setInterval(fetchTitleNews, 300000); // 5 min

var se = document.getElementById('news-search');
if (se) se.addEventListener('input', function(){ searchTerm = this.value.trim(); renderRssList(); });

// ─────────────────────────────────────────────────────────────────────────────
// DETAIL NEWS — AHoosh own articles, static from content collection
// ─────────────────────────────────────────────────────────────────────────────
function renderDetailNews() {
  var grid = document.getElementById('detail-grid');
  if (!grid) return;
  if (!ownArticles || !ownArticles.length) {
    grid.innerHTML = '<div style="color:var(--silver-muted);font-size:12px;padding:16px 0;grid-column:1/-1;">Our editorial team is working on the first articles.</div>';
    return;
  }
  grid.innerHTML = '';
  ownArticles.forEach(function(a) {
    var card = document.createElement('a');
    card.className = 'news-card-full';
    card.href = '/articles/' + a.slug;
    card.innerHTML =
      '<div class="src-badge" style="background:rgba(215,161,61,0.2);color:var(--gold);">★ AHoosh</div>' +
      '<div class="headline">' + escHtml(a.title) + '</div>' +
      '<div class="date">' + timeAgo(a.pubDate) + '</div>';
    grid.appendChild(card);
  });
}

renderDetailNews();

// ─────────────────────────────────────────────────────────────────────────────
// UTILS
// ─────────────────────────────────────────────────────────────────────────────
function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

var _decodeEl = document.createElement('textarea');
function decodeEntities(s) {
  _decodeEl.innerHTML = String(s);
  return _decodeEl.value;
}

// ─────────────────────────────────────────────────────────────────────────────
// CALENDAR WIDGET
// ─────────────────────────────────────────────────────────────────────────────
// ─── INTERACTIVE CALENDAR ────────────────────────────────────────────────────
var _now = new Date();
var calY = _now.getFullYear(), calM = _now.getMonth(), calSel = null;
var CAL_MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
var CAL_DAYS = ['Su','Mo','Tu','We','Th','Fr','Sa'];
window.calPrev = function() { calM--; if (calM < 0) { calM = 11; calY--; } renderCalendar(); };
window.calNext = function() { calM++; if (calM > 11) { calM = 0; calY++; } renderCalendar(); };
window.calSelect = function(d) { calSel = d + '-' + calM + '-' + calY; renderCalendar(); };

function renderCalendar() {
  var el = document.getElementById('cal-widget');
  if (!el) return;
  var todY = _now.getFullYear(), todM = _now.getMonth(), todD = _now.getDate();
  var firstDay = new Date(calY, calM, 1).getDay();
  var days = new Date(calY, calM + 1, 0).getDate();
  var html = '<div class="cal-nav">'
    + '<button class="cal-nav-btn" onclick="calPrev()">‹</button>'
    + '<span class="cal-month">' + CAL_MONTHS[calM] + ' ' + calY + '</span>'
    + '<button class="cal-nav-btn" onclick="calNext()">›</button>'
    + '</div><div class="cal-grid">';
  CAL_DAYS.forEach(function(d){ html += '<div class="cal-dh">'+d+'</div>'; });
  for (var i = 0; i < firstDay; i++) html += '<div class="cal-d empty"></div>';
  for (var d = 1; d <= days; d++) {
    var isToday = (d === todD && calM === todM && calY === todY);
    var isSel   = (calSel === d + '-' + calM + '-' + calY);
    var cls = 'cal-d' + (isToday ? ' today' : '') + (isSel && !isToday ? ' selected' : '');
    html += '<div class="' + cls + '" onclick="calSelect(' + d + ')">' + d + '</div>';
  }
  html += '</div>';
  el.innerHTML = html;
}
renderCalendar();

// ─── WEATHER WIDGET — Open-Meteo (free, no key) + geocoding city search ──────
var WMO_ICONS = { 0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',53:'🌦',55:'🌧',61:'🌧',63:'🌧',65:'🌧',71:'🌨',73:'🌨',75:'❄️',80:'🌦',81:'🌧',82:'⛈',95:'⛈',96:'⛈',99:'⛈' };
var WMO_DESC  = { 0:'Clear sky',1:'Mainly clear',2:'Partly cloudy',3:'Overcast',45:'Foggy',48:'Foggy',51:'Light drizzle',53:'Drizzle',55:'Heavy drizzle',61:'Light rain',63:'Rain',65:'Heavy rain',71:'Light snow',73:'Snow',75:'Heavy snow',80:'Rain showers',81:'Showers',82:'Heavy showers',95:'Thunderstorm',96:'Thunderstorm',99:'Thunderstorm' };
var DAY_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

function loadWeather(lat, lon, city) {
  var el = document.getElementById('weather-widget');
  if (el) el.innerHTML = '<div class="side-loading">Loading…</div>';
  fetch('https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&current_weather=true&daily=weathercode,temperature_2m_max,temperature_2m_min&timezone=auto&forecast_days=6')
    .then(function(r){ return r.json(); })
    .then(function(data) {
      var el2 = document.getElementById('weather-widget');
      if (!el2) return;
      var cw = data.current_weather;
      var code = cw.weathercode;
      var daily = data.daily || {};
      var fHtml = '';
      if (daily.time) {
        for (var i = 1; i < Math.min(6, daily.time.length); i++) {
          var dt = new Date(daily.time[i]+'T12:00:00');
          fHtml += '<div class="wx-day"><span>' + DAY_NAMES[dt.getDay()] + ' ' + (WMO_ICONS[daily.weathercode[i]]||'🌡') + '</span>'
                 + '<span class="wx-day-temp">' + Math.round(daily.temperature_2m_max[i]) + '° / ' + Math.round(daily.temperature_2m_min[i]) + '°</span></div>';
        }
      }
      el2.innerHTML =
        '<div class="wx-city">📍 ' + escHtml(city) + '</div>' +
        '<div class="wx-icon">' + (WMO_ICONS[code]||'🌡') + '</div>' +
        '<div class="wx-temp">' + Math.round(cw.temperature) + '°C</div>' +
        '<div class="wx-desc">' + (WMO_DESC[code]||'') + '</div>' +
        '<div class="wx-row">💨 ' + Math.round(cw.windspeed) + ' km/h</div>' +
        (fHtml ? '<div class="wx-forecast">' + fHtml + '</div>' : '');
    })
    .catch(function(){
      var el3 = document.getElementById('weather-widget');
      if (el3) el3.innerHTML = '<div class="side-loading">Unavailable</div>';
    });
}

// City search via Open-Meteo geocoding
var _wxTimer = null;
var wxInput = document.getElementById('wx-city-input');
var wxSug   = document.getElementById('wx-suggestions');
if (wxInput && wxSug) {
  wxInput.addEventListener('input', function() {
    clearTimeout(_wxTimer);
    var q = this.value.trim();
    if (q.length < 2) { wxSug.style.display='none'; return; }
    _wxTimer = setTimeout(function() {
      fetch('https://geocoding-api.open-meteo.com/v1/search?name='+encodeURIComponent(q)+'&count=6&language=en&format=json')
        .then(function(r){ return r.json(); })
        .then(function(data) {
          var results = data.results || [];
          if (!results.length) { wxSug.style.display='none'; return; }
          wxSug.innerHTML = '';
          results.forEach(function(r) {
            var label = r.name + (r.admin1 ? ', '+r.admin1 : '') + ', ' + r.country;
            var item = document.createElement('div');
            item.className = 'wx-sug-item';
            item.textContent = label;
            item.addEventListener('click', function() {
              wxInput.value = r.name + ', ' + r.country;
              wxSug.style.display = 'none';
              loadWeather(r.latitude, r.longitude, r.name + ', ' + r.country);
            });
            wxSug.appendChild(item);
          });
          wxSug.style.display = 'block';
        })
        .catch(function(){ wxSug.style.display='none'; });
    }, 350);
  });
  document.addEventListener('click', function(e) {
    if (!wxSug.contains(e.target) && e.target !== wxInput) wxSug.style.display='none';
  });
}

// Initial load: geolocation → Belgrade fallback
if (navigator.geolocation) {
  navigator.geolocation.getCurrentPosition(
    function(pos) { loadWeather(pos.coords.latitude.toFixed(4), pos.coords.longitude.toFixed(4), 'Your Location'); },
    function()    { loadWeather(44.8, 20.5, 'Belgrade'); },
    { timeout: 5000 }
  );
} else {
  loadWeather(44.8, 20.5, 'Belgrade');
}

})();
</script>
