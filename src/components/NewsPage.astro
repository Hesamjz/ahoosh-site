---
// NewsPage.astro — shared live TV + news feed component
// Each locale page passes `locale` and `t` (translated strings)
const { locale, t } = Astro.props;
---

<!-- Hero -->
<section style="background:linear-gradient(160deg,#03142E 0%,#010A18 100%);padding:32px 24px 24px;border-bottom:1px solid rgba(215,161,61,0.1);">
  <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <div class="section-eyebrow" style="margin-bottom:6px;">{t.eyebrow}</div>
      <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(20px,4vw,28px);color:var(--silver);margin:0;">{t.heading}</h1>
      <p style="font-size:13px;color:var(--silver-dim);margin-top:6px;" set:html={t.subheading}></p>
    </div>
    <div id="news-updated" style="font-size:11px;color:var(--silver-muted);"></div>
  </div>
</section>

<div style="max-width:1100px;margin:0 auto;padding:24px 24px 64px;">

  <!-- ══ LIVE TV ══════════════════════════════════════════════════════ -->
  <section style="margin-bottom:40px;">
    <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">
      {t.liveTVLabel}
    </div>

    <!-- Language filter row for channels -->
    <div id="ch-lang-row" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;"></div>

    <!-- Channel picker -->
    <div id="channel-btns" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;"></div>

    <!-- Player -->
    <div style="position:relative;width:100%;max-width:800px;background:#000;border-radius:8px;overflow:hidden;border:1px solid rgba(215,161,61,0.2);">
      <video id="live-video" controls muted playsinline style="width:100%;display:block;aspect-ratio:16/9;background:#000;"></video>
      <iframe id="live-iframe" style="width:100%;aspect-ratio:16/9;border:none;display:none;" allow="autoplay; encrypted-media"></iframe>
    </div>
    <div id="channel-info" style="margin-top:10px;font-size:12px;color:var(--silver-muted);"></div>
  </section>

  <!-- ══ NEWS FEED ════════════════════════════════════════════════════ -->
  <section>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:14px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);">
        {t.latestNewsLabel}
      </div>
      <div id="lang-tabs" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
    </div>
    <input id="news-search" type="text" placeholder={t.searchPlaceholder} style="width:100%;max-width:360px;display:block;margin-bottom:14px;background:rgba(10,30,60,0.8);border:1px solid rgba(215,161,61,0.2);border-radius:6px;padding:8px 12px;color:var(--silver);font-size:13px;font-family:var(--font-body);outline:none;" />
    <div id="news-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;">
      <div class="news-skeleton"></div><div class="news-skeleton"></div>
      <div class="news-skeleton"></div><div class="news-skeleton"></div>
      <div class="news-skeleton"></div><div class="news-skeleton"></div>
    </div>
    <div style="margin-top:16px;text-align:center;font-size:11px;color:var(--silver-muted);" id="news-meta"></div>
  </section>
</div>

<style is:global>
  .news-skeleton {
    height:90px;
    background:linear-gradient(90deg,rgba(255,255,255,0.04) 25%,rgba(255,255,255,0.07) 50%,rgba(255,255,255,0.04) 75%);
    background-size:200% 100%;animation:shimmer 1.4s infinite;
    border-radius:6px;border:1px solid rgba(215,161,61,0.08);
  }
  @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
  .news-card-full{background:rgba(10,30,60,0.8);border:1px solid rgba(215,161,61,0.15);border-radius:6px;padding:14px;cursor:pointer;transition:border-color 150ms ease;text-decoration:none;display:block;}
  .news-card-full:hover{border-color:rgba(215,161,61,0.45);}
  .news-card-full .src-badge{display:inline-block;font-size:9px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--gold);background:rgba(215,161,61,0.1);border-radius:3px;padding:2px 6px;margin-bottom:7px;}
  .news-card-full .headline{font-size:13px;color:var(--silver);line-height:1.55;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;}
  .news-card-full .date{font-size:10px;color:var(--silver-muted);margin-top:6px;}
  .ch-btn{background:rgba(10,30,60,0.8);border:1px solid rgba(215,161,61,0.2);border-radius:6px;padding:6px 12px;font-size:12px;color:var(--silver-dim);cursor:pointer;font-family:var(--font-body);transition:all 150ms ease;}
  .ch-btn:hover,.ch-btn.active{background:rgba(215,161,61,0.15);border-color:rgba(215,161,61,0.5);color:var(--gold);}
  .ch-lang-btn{background:rgba(10,30,60,0.5);border:1px solid rgba(215,161,61,0.12);border-radius:4px;padding:3px 10px;font-size:11px;color:var(--silver-muted);cursor:pointer;font-family:var(--font-body);transition:all 150ms ease;}
  .ch-lang-btn:hover,.ch-lang-btn.active{background:rgba(215,161,61,0.12);border-color:rgba(215,161,61,0.4);color:var(--gold);}
  .lang-tab{background:rgba(10,30,60,0.6);border:1px solid rgba(215,161,61,0.15);border-radius:4px;padding:4px 10px;font-size:11px;color:var(--silver-muted);cursor:pointer;font-family:var(--font-body);transition:all 150ms ease;}
  .lang-tab:hover,.lang-tab.active{background:rgba(215,161,61,0.12);border-color:rgba(215,161,61,0.4);color:var(--gold);}
</style>

<script is:inline define:vars={{ locale, t }}>
(function(){

// ── ALL CHANNELS — verified live stream IDs ─────────────────────────────────
// No Iranian state media (no Tasnim, Mehr, Fars, IRIB, Press TV)
// All IDs verified via YouTube /live endpoint, June 2026
const CHANNELS_ALL = [
  // English
  { id:'france24-en', name:'France 24',    lang:'en', type:'youtube', vid:'HvZt-nh9sGg' },
  { id:'aljazeera',   name:'Al Jazeera',   lang:'en', type:'youtube', vid:'LkfNJ6EFkwM' },
  { id:'bbc-world',   name:'BBC World',    lang:'en', type:'youtube', vid:'PatB45tYFtc'  },
  { id:'sky',         name:'Sky News',     lang:'en', type:'youtube', vid:'9Auq9mYxFEE'  },
  { id:'cnn',         name:'CNN',          lang:'en', type:'youtube', vid:'aB-6_-GboaM'  },
  { id:'cnn-i',       name:'CNN Intl',     lang:'en', type:'youtube', vid:'Z-nKTmdGpz0'  },
  { id:'dw-en',       name:'DW News',      lang:'en', type:'youtube', vid:'LuKwFajn37U'  },
  { id:'trt',         name:'TRT World',    lang:'en', type:'youtube', vid:'oNUi_iXNPeo'  },
  { id:'euronews-en', name:'Euronews EN',  lang:'en', type:'youtube', vid:'pykpO5kQJ98'  },
  { id:'reuters',     name:'Reuters',      lang:'en', type:'youtube', vid:'R02egjcxpUw'  },
  { id:'abc',         name:'ABC News',     lang:'en', type:'youtube', vid:'exIvC0l8x-Y'  },
  { id:'cbs',         name:'CBS News',     lang:'en', type:'youtube', vid:'khdVidn7AfQ'  },
  { id:'fox',         name:'Fox News',     lang:'en', type:'youtube', vid:'qEHza_8UL-k'  },
  { id:'wion',        name:'WION',         lang:'en', type:'youtube', vid:'X5yAyEpwxU0'  },
  { id:'gbnews',      name:'GB News',      lang:'en', type:'youtube', vid:'4fzMTueenHs'  },
  // Markets
  { id:'bloomberg',   name:'Bloomberg TV', lang:'market', type:'youtube', vid:'dp8PhLsUcFE' },
  { id:'cnbc',        name:'CNBC',         lang:'market', type:'youtube', vid:'9NyxcX3rhQs' },
  // Persian — diaspora only (no Iranian state media)
  { id:'bbc-fa',      name:'BBC Persian',  lang:'fa', type:'youtube', vid:'XRHV-9m_WO4'  },
  { id:'iranintl',    name:'Iran Intl',    lang:'fa', type:'youtube', vid:'5JDxjsAVaGk'  },
  { id:'manoto',      name:'Manoto',       lang:'fa', type:'youtube', vid:'bQJFCVV8hCg'  },
  { id:'voa-fa',      name:'VOA Farsi',    lang:'fa', type:'youtube', vid:'nkwyi4gDpxs'  },
  { id:'rfarda',      name:'Radio Farda',  lang:'fa', type:'hls', src:'https://rferl-ingest.akamaized.net/hls/live/2121768/tvmc01/playlist.m3u8' },
  { id:'iranfarda',   name:'Irane Farda',  lang:'fa', type:'hls', src:'https://hls.iranfarda.live/hls/stream.m3u8' },
  // German
  { id:'welt',        name:'WELT',         lang:'de', type:'youtube', vid:'RRr0687ik44'  },
  { id:'euronews-de', name:'Euronews DE',  lang:'de', type:'youtube', vid:'CQ3KsEbsYHs'  },
  { id:'arte',        name:'ARTE',         lang:'de', type:'youtube', vid:'3gjNL03uYWc'  },
  // French
  { id:'france24-fr', name:'France 24 FR', lang:'fr', type:'youtube', vid:'a47ckXKZjxI'  },
  { id:'euronews-fr', name:'Euronews FR',  lang:'fr', type:'youtube', vid:'NiRIbKwAejk'  },
  // Spanish
  { id:'dw-es',       name:'DW Español',   lang:'es', type:'youtube', vid:'yZh3xsFqCt8'  },
  // Serbian / Balkan
  { id:'rts1',        name:'RTS 1',        lang:'sr', type:'youtube', vid:'8jrBwSYdZEQ'  },
  { id:'hrt',         name:'HRT',          lang:'sr', type:'youtube', vid:'lbAeay4EVZ0'  },
  // Arabic
  { id:'aljazeera-ar',name:'Al Jazeera عر',lang:'ar', type:'youtube', vid:'N8xxOD0nT1Y' },
  { id:'alarabiya',   name:'Al Arabiya',   lang:'ar', type:'youtube', vid:'n7eQejkXbnM'  },
  { id:'bbc-ar',      name:'BBC Arabic',   lang:'ar', type:'youtube', vid:'O1pGmVtj2Y8'  },
  { id:'indep-ar',    name:'Indep. Arabic',lang:'ar', type:'youtube', vid:'WKryGkxaPn4'  },
  { id:'dw-ar',       name:'DW Arabic',    lang:'ar', type:'youtube', vid:'AGkp2AL8e7o'  },
  { id:'alhadath',    name:'Al Hadath',    lang:'ar', type:'youtube', vid:'SPvxA_UuoYY'  },
  { id:'sky-ar',      name:'Sky Arabia',   lang:'ar', type:'youtube', vid:'ymYr5ze2XeA'  },
  { id:'cnn-ar',      name:'CNN Arabic',   lang:'ar', type:'youtube', vid:'n8osICWftpU'  },
];

// ── Lang order: locale first, then EN, then rest ──
var langOrder = [locale, 'en', 'market', 'de', 'fr', 'fa', 'ar', 'sr', 'es'];
function langRank(l) {
  var i = langOrder.indexOf(l);
  return i < 0 ? 99 : i;
}
var SORTED = CHANNELS_ALL.slice().sort(function(a,b){ return langRank(a.lang)-langRank(b.lang); });

// ── Player state ─────────────────────────────────────────────────────────────
var currentCh = null;
var hlsInstance = null;
var hlsReady = false;

function loadYoutube(vid) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  v.style.display = 'none';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  i.src = 'https://www.yout-ube.com/embed/' + vid + '?autoplay=1&rel=0&playsinline=1&fs=0';
  i.style.display = 'block';
}

function loadHls(src) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  i.src = ''; i.style.display = 'none';
  v.style.display = 'block';
  function go() {
    if (window.Hls && Hls.isSupported()) {
      if (hlsInstance) hlsInstance.destroy();
      hlsInstance = new Hls({ enableWorker: true, lowLatencyMode: true });
      hlsInstance.loadSource(src);
      hlsInstance.attachMedia(v);
      hlsInstance.on(Hls.Events.MANIFEST_PARSED, function(){ v.play().catch(function(){}); });
    } else if (v.canPlayType('application/vnd.apple.mpegurl')) {
      v.src = src; v.play().catch(function(){});
    }
  }
  if (hlsReady) { go(); }
  else {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.5.7/hls.min.js';
    s.onload = function(){ hlsReady = true; go(); };
    document.head.appendChild(s);
  }
}

function loadChannel(ch) {
  currentCh = ch.id;
  document.querySelectorAll('.ch-btn').forEach(function(b){
    b.classList.toggle('active', b.dataset.id === ch.id);
  });
  document.getElementById('channel-info').textContent = '▶ ' + ch.name + ' — ' + t.liveSuffix;
  if (ch.type === 'youtube') { loadYoutube(ch.vid); }
  else { loadHls(ch.src); }
}

// ── Build language filter tabs (for channels) ────────────────────────────────
var activeLangFilter = locale;
var chLangRow = document.getElementById('ch-lang-row');
var seenLangs = [];
CHANNELS_ALL.forEach(function(c){ if (seenLangs.indexOf(c.lang) < 0) seenLangs.push(c.lang); });

// "All" button
var allChBtn = document.createElement('button');
allChBtn.className = 'ch-lang-btn';
allChBtn.textContent = t.allChannels;
allChBtn.addEventListener('click', function(){
  activeLangFilter = 'all';
  renderChannelBtns();
  document.querySelectorAll('.ch-lang-btn').forEach(function(b){ b.classList.remove('active'); });
  allChBtn.classList.add('active');
});
chLangRow.appendChild(allChBtn);

seenLangs.forEach(function(l){
  var b = document.createElement('button');
  b.className = 'ch-lang-btn' + (l === locale ? ' active' : '');
  b.dataset.lang = l;
  b.textContent = t.langNames[l] || l;
  b.addEventListener('click', function(){
    activeLangFilter = l;
    renderChannelBtns();
    document.querySelectorAll('.ch-lang-btn').forEach(function(x){ x.classList.remove('active'); });
    b.classList.add('active');
  });
  chLangRow.appendChild(b);
});

function renderChannelBtns() {
  var bc = document.getElementById('channel-btns');
  bc.innerHTML = '';
  var list = activeLangFilter === 'all'
    ? SORTED
    : CHANNELS_ALL.filter(function(c){ return c.lang === activeLangFilter; });
  list.forEach(function(ch){
    var btn = document.createElement('button');
    btn.className = 'ch-btn' + (currentCh === ch.id ? ' active' : '');
    btn.dataset.id = ch.id;
    btn.textContent = ch.name;
    btn.addEventListener('click', function(){ loadChannel(ch); });
    bc.appendChild(btn);
  });
}

// Initial render: show locale channels
renderChannelBtns();

// Auto-load first channel of current locale
var firstCh = CHANNELS_ALL.find(function(c){ return c.lang === locale; }) || SORTED[0];
loadChannel(firstCh);

// ── News Feed ─────────────────────────────────────────────────────────────────
var allArticles = [], activeLang = 'all', searchTerm = '';

function timeAgo(p) {
  if (!p) return '';
  try {
    var d = new Date(p), f = (Date.now()-d.getTime())/60000;
    if (f < 1)    return t.timeAgo.now;
    if (f < 60)   return Math.round(f) + t.timeAgo.min;
    if (f < 1440) return Math.round(f/60) + t.timeAgo.hr;
    return Math.round(f/1440) + t.timeAgo.days;
  } catch(e){ return p; }
}

function renderNewsGrid() {
  var g = document.getElementById('news-grid');
  if (!g) return;
  var f = allArticles.filter(function(a){
    if (activeLang !== 'all' && a.lang !== activeLang) return false;
    if (searchTerm) { var q=searchTerm.toLowerCase(); return (a.title||'').toLowerCase().includes(q)||(a.source||'').toLowerCase().includes(q); }
    return true;
  });
  if (!f.length) { g.innerHTML='<div style="color:var(--silver-muted);font-size:13px;padding:24px 0;grid-column:1/-1;text-align:center;">'+t.noResults+'</div>'; return; }
  g.innerHTML='';
  f.slice(0,60).forEach(function(a){
    var c=document.createElement('a'); c.className='news-card-full';
    if (a.isOwn) {
      c.href='/articles/'+a.slug;
      c.style.borderColor='rgba(215,161,61,0.4)';
    } else {
      c.href=a.link||'#'; c.target='_blank'; c.rel='noopener noreferrer';
    }
    var rtl=(a.lang==='fa'||a.lang==='ar');
    var badge = a.isOwn ? '<div class="src-badge" style="background:rgba(215,161,61,0.2);color:var(--gold);">★ AHOOSH</div>' : '<div class="src-badge">'+a.source+'</div>';
    c.innerHTML=badge+'<div class="headline"'+(rtl?' dir="rtl" style="text-align:right"':'')+'>'+a.title+'</div><div class="date">'+timeAgo(a.pubDate)+'</div>';
    g.appendChild(c);
  });
}

function buildLangTabs(arts) {
  var langs={};
  arts.forEach(function(a){ langs[a.lang]=(langs[a.lang]||0)+1; });
  var tabs=document.getElementById('lang-tabs'); if (!tabs) return;
  tabs.innerHTML='';
  var all=document.createElement('button'); all.className='lang-tab active'; all.textContent=t.allNews;
  all.addEventListener('click',function(){ activeLang='all'; document.querySelectorAll('.lang-tab').forEach(function(x){x.classList.remove('active');}); all.classList.add('active'); renderNewsGrid(); });
  tabs.appendChild(all);
  Object.keys(langs).sort().forEach(function(l){
    var tab=document.createElement('button'); tab.className='lang-tab'; tab.textContent=(t.langNames[l]||l)+' ('+langs[l]+')';
    tab.addEventListener('click',function(){ activeLang=l; document.querySelectorAll('.lang-tab').forEach(function(x){x.classList.remove('active');}); tab.classList.add('active'); renderNewsGrid(); });
    tabs.appendChild(tab);
  });
}

var se=document.getElementById('news-search');
if(se) se.addEventListener('input',function(){ searchTerm=this.value.trim(); renderNewsGrid(); });

async function fetchNews() {
  try {
    var [ownResp, rssResp] = await Promise.all([
      fetch('/api/own-articles.json', {signal:AbortSignal.timeout(8000)}).catch(function(){return null;}),
      fetch('/api/news', {signal:AbortSignal.timeout(20000)}).catch(function(){return null;}),
    ]);
    var ownRaw = (ownResp && ownResp.ok) ? await ownResp.json() : [];
    var ownArts = ownRaw.map(function(a){ return Object.assign({}, a, {isOwn:true, link:'/articles/'+a.slug}); });
    var d = (rssResp && rssResp.ok) ? await rssResp.json() : {articles:[], sources:0};
    allArticles = ownArts.concat(d.articles||[]);
    buildLangTabs(allArticles);
    renderNewsGrid();
    var m=document.getElementById('news-meta');
    if(m) m.textContent=allArticles.length+' '+t.metaSources.replace('{n}',d.sources||0)+' · '+t.updatedAt+': '+new Date().toLocaleTimeString(t.localeCode);
    var u=document.getElementById('news-updated');
    if(u) u.textContent=t.updatedAt+': '+new Date().toLocaleTimeString(t.localeCode);
  } catch(e) {
    var g=document.getElementById('news-grid');
    if(g) g.innerHTML='<div style="color:var(--silver-muted);font-size:13px;padding:24px 0;grid-column:1/-1;">'+t.failedLoad+'</div>';
  }
}

fetchNews();
setInterval(fetchNews, 300000);

})();
</script>
