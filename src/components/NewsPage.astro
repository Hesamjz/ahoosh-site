var seenLangs = [];
CHANNELS_ALL.forEach(function(c){ if (seenLangs.indexOf(c.lang) < 0) seenLangs.push(c.lang); });

var langSel = document.getElementById('ch-lang-sel');
var nameSel = document.getElementById('ch-name-sel');

if (langSel && nameSel) {
  // Populate category dropdown — grouped by Languages / Topics
  var CHAN_GROUPS = [
    { label: '🌐 Languages', keys: ['en','fa','de','fr','es','sr','ar'] },
    { label: '📺 Topics',    keys: ['sport','tech'] },
  ];
  CHAN_GROUPS.forEach(function(group) {
    var groupLangs = group.keys.filter(function(l){ return seenLangs.indexOf(l) >= 0; });
    if (!groupLangs.length) return;
    var grpEl = document.createElement('optgroup');
    grpEl.label = group.label;
    groupLangs.forEach(function(l) {
      var o = document.createElement('option');
      o.value = l;
      o.textContent = t.langNames[l] || (l.charAt(0).toUpperCase() + l.slice(1));
      if (l === locale) o.selected = true;
      grpEl.appendChild(o);
    });
    langSel.appendChild(grpEl);
  });

  function populateChannels(lang) {
    nameSel.innerHTML = '';
    var list = CHANNELS_ALL.filter(function(c){ return c.lang === lang; });
    list.forEach(function(ch) {
      var o = document.createElement('option');
      o.value = ch.id;
      o.textContent = ch.name;
      nameSel.appendChild(o);
    });
    // Defaults per category
    var preferred = { en:'euronews-en', sport:'shabakeh3' };
    var defCh = (preferred[lang] && list.find(function(c){ return c.id === preferred[lang]; })) || list[0];
    if (defCh) { nameSel.value = defCh.id; loadChannel(defCh); }
  }

  langSel.addEventListener('change', function() { populateChannels(this.value); });
  nameSel.addEventListener('change', function() {
    var ch = CHANNELS_ALL.find(function(c){ return c.id === this.value; }, this);
    if (ch) loadChannel(ch);
  });

  populateChannels(locale);
}

