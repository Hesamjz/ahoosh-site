];

// SVG sizes
var R = 44; // dial radius (SVG units, viewBox 0 0 100 100, centre at 50,50)

function makeDial(id) {
  // Returns the static SVG string (no hands) — hands are <line> elements updated by JS
  var markers = '';
  for (var h = 0; h < 12; h++) {
    var angle = h * 30; // degrees
    var rad   = (angle - 90) * Math.PI / 180;
    var isMain = (h % 3 === 0); // 12,3,6,9
    var r1 = isMain ? R - 6 : R - 4;
    var r2 = isMain ? R - 1 : R - 2;
    var x1 = 50 + r1 * Math.cos(rad);
    var y1 = 50 + r1 * Math.sin(rad);
    var x2 = 50 + r2 * Math.cos(rad);
    var y2 = 50 + r2 * Math.sin(rad);
    var sw = isMain ? '2' : '1.2';
    markers += '<line x1="'+x1+'" y1="'+y1+'" x2="'+x2+'" y2="'+y2+'" stroke="#D7A13D" stroke-width="'+sw+'" stroke-linecap="round"/>';
  }
  return '<svg class="analog-clock" id="svgclock-'+id+'" viewBox="0 0 100 100" width="82" height="82" xmlns="http://www.w3.org/2000/svg">'
    // outer bezel ring
    + '<circle cx="50" cy="50" r="49" fill="#1a1206" stroke="#D7A13D" stroke-width="2"/>'
    // inner bezel ring
    + '<circle cx="50" cy="50" r="46" fill="none" stroke="#8a6520" stroke-width="0.5"/>'
    // dial face
    + '<circle cx="50" cy="50" r="'+R+'" fill="#03142E"/>'
    // markers
    + markers
    // hour hand (will be updated)
    + '<line id="hhand-'+id+'" x1="50" y1="50" x2="50" y2="22" stroke="#D7A13D" stroke-width="3.5" stroke-linecap="round"/>'
    // minute hand
    + '<line id="mhand-'+id+'" x1="50" y1="50" x2="50" y2="14" stroke="#C8C8C8" stroke-width="2.5" stroke-linecap="round"/>'
    // second hand
    + '<line id="shand-'+id+'" x1="50" y1="54" x2="50" y2="12" stroke="#C0392B" stroke-width="1.2" stroke-linecap="round"/>'
    // centre dot
    + '<circle cx="50" cy="50" r="2.5" fill="#D7A13D"/>'
    + '</svg>';
}

function handCoords(cx, cy, angle_deg, length) {
  var rad = (angle_deg - 90) * Math.PI / 180;
  return { x: cx + length * Math.cos(rad), y: cy + length * Math.sin(rad) };
}

var _tzFmt = CLOCKS.map(function(c) {
  return new Intl.DateTimeFormat('en-GB', {
    timeZone: c.tz,
    hour:'numeric', minute:'numeric', second:'numeric', hour12:false
  });
});
var _dateFmt = CLOCKS.map(function(c) {
  return new Intl.DateTimeFormat('en-GB', { timeZone:c.tz, weekday:'short', month:'short', day:'numeric' });
});

// Build DOM
var strip = document.getElementById('clocks-strip');
CLOCKS.forEach(function(c, i) {
  var wrap = document.createElement('div');
  wrap.className = 'clock-wrap' + (c.mobileHide ? ' clock-mobile-hide' : '');
  wrap.innerHTML =
    '<div class="city-name">' + c.name + '</div>' +
    makeDial(i) +
    '<div class="city-date" id="cd-' + i + '">---</div>';
  strip.appendChild(wrap);
});

function tickClocks() {
  var now = new Date();
  CLOCKS.forEach(function(c, i) {
    // parse time in timezone
    var parts = _tzFmt[i].formatToParts(now);
    var H = 0, M = 0, S = 0;
    parts.forEach(function(p) {
      if (p.type === 'hour')   H = parseInt(p.value, 10);
      if (p.type === 'minute') M = parseInt(p.value, 10);
      if (p.type === 'second') S = parseInt(p.value, 10);
    });

    var hAngle = (H % 12) * 30 + M * 0.5 + S * (0.5/60);
    var mAngle = M * 6 + S * 0.1;
    var sAngle = S * 6;

    var hPt = handCoords(50, 50, hAngle, 22);
    var mPt = handCoords(50, 50, mAngle, 30);
    var sPt = handCoords(50, 50, sAngle, 32);
    var sTail = handCoords(50, 50, sAngle + 180, 6);

    var hEl = document.getElementById('hhand-'+i);
    var mEl = document.getElementById('mhand-'+i);
    var sEl = document.getElementById('shand-'+i);
    if (!hEl) return;
    hEl.setAttribute('x2', hPt.x); hEl.setAttribute('y2', hPt.y);
    mEl.setAttribute('x2', mPt.x); mEl.setAttribute('y2', mPt.y);
    sEl.setAttribute('x1', sTail.x); sEl.setAttribute('y1', sTail.y);
    sEl.setAttribute('x2', sPt.x);  sEl.setAttribute('y2', sPt.y);

    var de = document.getElementById('cd-'+i);
    if (de) de.textContent = _dateFmt[i].format(now);
  });
}
tickClocks();
setInterval(tickClocks, 1000);

// ─────────────────────────────────────────────────────────────────────────────
// PLAYER STATE + LOGIC
// ─────────────────────────────────────────────────────────────────────────────
var currentCh   = null;
var hlsInstance = null;
var hlsReady    = false;
var activeSrcIdx  = 0;
var activeSrcList = [];

function updateSourceBadge() {
  var badge = document.getElementById('src-badge');
  var nxt   = document.getElementById('next-src-btn');
  if (!badge) return;
  if (activeSrcList.length <= 1) { badge.style.display='none'; if(nxt) nxt.style.display='none'; return; }
  badge.style.display = 'inline-flex';
  badge.textContent = '⚡ Source ' + (activeSrcIdx+1) + ' / ' + activeSrcList.length;
  if (nxt) nxt.style.display = (activeSrcIdx+1 < activeSrcList.length) ? 'inline-block' : 'none';
}

function tryNextSource() {
  if (activeSrcIdx + 1 >= activeSrcList.length) return;
  activeSrcIdx++;
  playSrc(activeSrcList[activeSrcIdx]);
  updateSourceBadge();
}

function playSrc(src) {
  if (src.type === 'youtube') { loadYoutube(src.vid, src.chanId); }
  else if (src.type === 'iframe') { loadIframe(src.src); }
  else { loadHls(src.src); }
}

function loadIframe(src) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  v.style.display = 'none';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  i.src = src;
  i.style.display = 'block';
}

function loadYoutube(vid, chanId) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  v.style.display = 'none';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  var base = chanId
    ? 'https://www.youtube.com/embed/live_stream?channel=' + chanId + '&autoplay=1&rel=0&playsinline=1'
    : 'https://www.yout-ube.com/embed/' + vid + '?autoplay=1&rel=0&playsinline=1&fs=0';
  i.src = base;
  i.style.display = 'block';
}

function loadHls(src) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  i.src = ''; i.style.display = 'none';
  v.style.display = 'block';
  function go() {
    if (window.Hls && Hls.isSupported()) {
      if (hlsInstance) hlsInstance.destroy();
      hlsInstance = new Hls({ enableWorker:true, lowLatencyMode:true });
      hlsInstance.loadSource(src);
      hlsInstance.attachMedia(v);
      hlsInstance.on(Hls.Events.MANIFEST_PARSED, function(){ v.muted=true; v.play().catch(function(){}); });
      hlsInstance.on(Hls.Events.ERROR, function(ev, data) {
        if (data.fatal && activeSrcIdx + 1 < activeSrcList.length) {
          hlsInstance.destroy(); hlsInstance = null;
          activeSrcIdx++;
          updateSourceBadge();
          playSrc(activeSrcList[activeSrcIdx]);
        }
      });
    } else if (v.canPlayType('application/vnd.apple.mpegurl')) {
      v.src = src; v.play().catch(function(){});
    }
  }
  if (hlsReady) { go(); }
  else {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.5.7/hls.min.js';
    s.onload = function(){ hlsReady = true; go(); };
    document.head.appendChild(s);
  }
}

// YouTube postMessage fallback
window.addEventListener('message', function(e) {
  if (!e.data) return;
  try {
    var d = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
    if (d.event === 'infoDelivery' && d.info && d.info.playerError) {
      if (activeSrcIdx + 1 < activeSrcList.length) {
        activeSrcIdx++; updateSourceBadge(); playSrc(activeSrcList[activeSrcIdx]);
      }
    }
  } catch(ex){}
});

function loadChannel(ch) {
  currentCh = ch.id;
  document.querySelectorAll('.ch-btn').forEach(function(b){
    b.classList.toggle('active', b.dataset.id === ch.id);
  });
  document.getElementById('channel-info').textContent = '▶ ' + ch.name + ' — ' + t.liveSuffix;
  if (ch.sources && ch.sources.length) {
    activeSrcList = ch.sources;
  } else if (ch.type === 'youtube') {
    activeSrcList = [{ type:'youtube', vid:ch.vid }];
  } else {
    activeSrcList = [{ type:'hls', src:ch.src }];
  }
  activeSrcIdx = 0;
  updateSourceBadge();
  playSrc(activeSrcList[0]);
}

