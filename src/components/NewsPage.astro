---
// NewsPage.astro — unified live page: world clocks + TV + markets + news
// Each locale page passes `locale` and `t` (translated strings)
import { getCollection } from 'astro:content';
const { locale, t } = Astro.props;

// AHoosh own articles — server-side, static, zero API cost
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const ownArticles = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 24)
  .map(p => ({
    title: p.data.title,
    description: p.data.description || '',
    pubDate: p.data.pubDate instanceof Date ? p.data.pubDate.toISOString() : String(p.data.pubDate),
    slug: p.id.replace(/\.(md|mdx)$/, ''),
    lang: p.data.lang || 'en',
  }));
---

<!-- Hero -->
<section style="background:linear-gradient(160deg,#03142E 0%,#010A18 100%);padding:28px 24px 18px;border-bottom:1px solid rgba(215,161,61,0.1);">
  <div style="max-width:1240px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <div class="section-eyebrow" style="margin-bottom:6px;">{t.eyebrow}</div>
      <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(18px,3.5vw,26px);color:var(--silver);margin:0;">{t.heading}</h1>
      <p style="font-size:12px;color:var(--silver-dim);margin-top:4px;" set:html={t.subheading}></p>
    </div>
  </div>
</section>

<!-- ══ WORLD CLOCKS — Analog ══════════════════════════════════════════════ -->
<div style="background:rgba(1,10,24,0.97);border-bottom:1px solid rgba(215,161,61,0.1);padding:14px 24px;overflow-x:auto;-webkit-overflow-scrolling:touch;position:sticky;top:0;z-index:100;display:flex;justify-content:center;">
  <div style="display:inline-flex;gap:24px;align-items:flex-end;" id="clocks-strip">
    <!-- populated by JS -->
  </div>
</div>

<div style="max-width:1440px;margin:0 auto;padding:20px 20px 64px;">
  <div class="page-3col">

    <!-- ══ LEFT: Calendar + Markets (sticky) ════════════════════════════════ -->
    <div class="left-col">

      <!-- Calendar card -->
      <div class="side-card">
        <div class="side-label">📅 Calendar</div>
        <div id="cal-widget"></div>
      </div>

      <!-- Markets card -->
      <div class="side-card" style="margin-top:14px;">
        <div class="side-label">{t.marketsLabel || '📊 Markets'}</div>

        <div class="mkt-head">FX</div>
        <div id="mkt-fx" class="mkt-rows">
          <div class="mkt-skel"></div><div class="mkt-skel"></div><div class="mkt-skel"></div>
        </div>

        <div class="mkt-head" style="margin-top:10px;">Commodities</div>
        <div id="mkt-comm" class="mkt-rows">
          <div class="mkt-skel"></div><div class="mkt-skel"></div>
        </div>

        <div class="mkt-head" style="margin-top:10px;">
          Indices
          <span style="font-weight:400;opacity:0.45;font-size:9px;margin-left:4px;">~15min delay</span>
        </div>
        <div id="mkt-indices" class="mkt-rows">
          <div class="mkt-skel"></div><div class="mkt-skel"></div>
          <div class="mkt-skel"></div><div class="mkt-skel"></div>
        </div>

        <div class="mkt-head" style="margin-top:10px;">Crypto</div>
        <div id="mkt-crypto" class="mkt-rows">
          <div class="mkt-skel"></div><div class="mkt-skel"></div><div class="mkt-skel"></div>
        </div>

        <div id="mkt-updated" style="font-size:10px;color:var(--silver-muted);margin-top:10px;text-align:right;"></div>
      </div>

    </div>

    <!-- ══ CENTER: Video + News ══════════════════════════════════════════════ -->
    <div class="center-col">

      <!-- TV section -->
      <section style="margin-bottom:28px;">
        <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">{t.liveTVLabel}</div>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap;">
          <select id="ch-lang-sel" class="ch-sel" aria-label="Channel category"></select>
          <select id="ch-name-sel" class="ch-sel" aria-label="Channel" style="min-width:160px;"></select>
        </div>
        <div style="position:relative;width:100%;background:#000;border-radius:8px;overflow:hidden;border:1px solid rgba(215,161,61,0.2);">
          <video id="live-video" controls muted playsinline style="width:100%;display:block;aspect-ratio:16/9;background:#000;"></video>
          <iframe id="live-iframe" style="width:100%;aspect-ratio:16/9;border:none;display:none;" allow="autoplay; encrypted-media"></iframe>
        </div>
        <div style="margin-top:6px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <div id="channel-info" style="font-size:11px;color:var(--silver-muted);"></div>
          <span id="src-badge" style="display:none;align-items:center;gap:5px;font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--gold);background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);border-radius:4px;padding:2px 8px;">⚡ Source 1 / 1</span>
          <button id="next-src-btn" onclick="tryNextSource()" style="display:none;font-size:10px;background:rgba(215,161,61,0.08);border:1px solid rgba(215,161,61,0.2);border-radius:4px;padding:3px 10px;color:var(--silver-dim);cursor:pointer;font-family:var(--font-body);">↻ Try next source</button>
        </div>
      </section>

      <!-- News -->
      <div dir={t.rtl ? 'rtl' : 'ltr'}>

        <!-- Title News -->
        <div style="margin-bottom:28px;">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
            <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);">{t.titleNewsLabel || '📰 Title News'}</div>
            <div id="rss-updated" style="font-size:10px;color:var(--silver-muted);"></div>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:8px;">
            <input id="news-search" type="text" placeholder={t.searchPlaceholder}
              style="flex:1;min-width:160px;max-width:280px;background:rgba(10,30,60,0.8);border:1px solid rgba(215,161,61,0.2);border-radius:6px;padding:6px 10px;color:var(--silver);font-size:12px;font-family:var(--font-body);outline:none;" />
            <div id="rss-lang-row" style="display:flex;flex-wrap:wrap;gap:4px;"></div>
          </div>
          <div id="rss-list" style="display:flex;flex-direction:column;"></div>
          <div id="news-meta" style="margin-top:8px;font-size:10px;color:var(--silver-muted);"></div>
        </div>

        <!-- Detail News -->
        <div>
          <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">{t.detailNewsLabel || '✍️ Our Articles'}</div>
          <div id="detail-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;"></div>
        </div>

      </div>
    </div>

    <!-- ══ RIGHT: Weather (sticky) ═══════════════════════════════════════════ -->
    <div class="right-col">
      <div class="side-card">
        <div class="side-label">🌤 Weather</div>
        <input id="wx-city-input" class="side-input" type="text" placeholder="Search city…" autocomplete="off" />
        <div id="wx-suggestions"></div>
        <div id="weather-widget"><div class="side-loading">Detecting location…</div></div>
      </div>
    </div>

  </div>
</div>

<style is:global>
  /* ── Analog clocks ────────────────────────────────────────────────────── */
  .clock-wrap {
    display:inline-flex;flex-direction:column;align-items:center;gap:6px;
  }
  .clock-wrap .city-name {
    font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
    color:var(--silver-muted);
  }
  .clock-wrap .city-date {
    font-size:9px;color:var(--gold);opacity:0.7;
  }
  .analog-clock { flex-shrink:0; }

  /* ── 2-column grid ────────────────────────────────────────────────────── */
  .live-grid { display:grid;grid-template-columns:290px 1fr;gap:20px;align-items:start; }
  @media(max-width:880px) { .live-grid { grid-template-columns:1fr; } }

  /* ── Markets sidebar ──────────────────────────────────────────────────── */
  .mkt-sidebar {
    background:rgba(3,20,46,0.65);border:1px solid rgba(215,161,61,0.12);
    border-radius:8px;padding:14px;position:sticky;top:16px;
  }
  .mkt-head {
    font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
    color:var(--silver-muted);border-bottom:1px solid rgba(215,161,61,0.08);
    padding-bottom:4px;margin-bottom:6px;
    cursor:pointer;user-select:none;display:flex;align-items:center;justify-content:space-between;
  }
  .mkt-head:hover { color:var(--gold); }
  .mkt-arrow { font-size:11px;transition:transform 0.18s;display:inline-block;opacity:0.6; }
  .mkt-rows { display:flex;flex-direction:column;gap:3px; }
  .mkt-rows-hidden { display:none; }
  .mkt-row {
    display:flex;align-items:center;justify-content:space-between;
    padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.025);
  }
  .mkt-row .mkt-name { font-size:11px;color:var(--silver-dim);flex:1;min-width:0; }
  .mkt-row .mkt-price { font-size:11px;font-weight:700;color:var(--silver);font-family:var(--font-head);margin:0 6px; }
  .mkt-row .mkt-chg { font-size:10px;padding:1px 4px;border-radius:3px;font-weight:700;min-width:44px;text-align:right;flex-shrink:0; }
  .mkt-chg.pos { color:#22c55e;background:rgba(34,197,94,0.1); }
  .mkt-chg.neg { color:#ef4444;background:rgba(239,68,68,0.1); }
  .mkt-chg.neu { color:var(--silver-muted);background:rgba(255,255,255,0.04); }
  .mkt-skel {
    height:20px;border-radius:3px;margin-bottom:3px;
    background:linear-gradient(90deg,rgba(255,255,255,0.03) 25%,rgba(255,255,255,0.06) 50%,rgba(255,255,255,0.03) 75%);
    background-size:200% 100%;animation:shimmer 1.4s infinite;
  }

  /* ── News column ──────────────────────────────────────────────────────── */
  .news-col {}

  /* ── 3-col TV layout ────────────────────────────────────────────────────── */
  /* ── Main 3-col page layout ─────────────────────────────────────────────── */
  .page-3col {
    display:grid;
    grid-template-columns:240px 1fr 240px;
    gap:20px;
    align-items:start;
  }
  .left-col {
    position:sticky;
    top:148px;
    max-height:calc(100vh - 158px);
    overflow-y:auto;
    scrollbar-width:thin;
    scrollbar-color:rgba(215,161,61,0.2) transparent;
  }
  .left-col::-webkit-scrollbar { width:4px; }
  .left-col::-webkit-scrollbar-thumb { background:rgba(215,161,61,0.2);border-radius:2px; }
  .right-col {
    position:sticky;
    top:148px;
  }
  .center-col { min-width:0; }
  .side-card {
    background:rgba(1,10,24,0.7);border:1px solid rgba(215,161,61,0.12);
    border-radius:8px;padding:14px;
  }
  .side-label {
    font-family:var(--font-head);font-size:10px;font-weight:700;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);
    margin-bottom:10px;
  }
  .side-loading { font-size:12px;color:var(--silver-muted);padding:8px 0; }
  .side-input {
    width:100%;box-sizing:border-box;
    background:rgba(5,20,50,0.9);border:1px solid rgba(215,161,61,0.25);
    border-radius:5px;padding:5px 8px;color:var(--silver);font-size:12px;
    font-family:var(--font-body);outline:none;margin-bottom:6px;
  }
  /* Calendar */
  .cal-nav { display:flex;justify-content:space-between;align-items:center;margin-bottom:8px; }
  .cal-nav-btn {
    background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.2);
    color:var(--gold);border-radius:4px;padding:2px 8px;font-size:14px;cursor:pointer;
    font-family:var(--font-body);line-height:1.4;
  }
  .cal-nav-btn:hover { background:rgba(215,161,61,0.25); }
  .cal-month { font-size:12px;font-weight:700;color:var(--silver); }
  .cal-grid { display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-top:4px; }
  .cal-dh { font-size:9px;color:var(--silver-muted);text-align:center;padding:3px 0;font-weight:700; }
  .cal-d {
    font-size:11px;color:var(--silver-dim);text-align:center;padding:4px 1px;
    border-radius:3px;cursor:pointer;
  }
  .cal-d:hover:not(.empty):not(.today) { background:rgba(215,161,61,0.1); }
  .cal-d.today { background:var(--gold);color:#03142E;font-weight:700; }
  .cal-d.selected { background:rgba(215,161,61,0.22);color:var(--silver);font-weight:700; }
  .cal-d.empty { opacity:0;pointer-events:none; }
  /* Weather */
  #wx-suggestions {
    background:rgba(3,20,46,0.98);border:1px solid rgba(215,161,61,0.2);
    border-radius:5px;margin-bottom:6px;overflow:hidden;display:none;
  }
  .wx-sug-item {
    padding:7px 8px;font-size:11px;color:var(--silver-dim);cursor:pointer;
    border-bottom:1px solid rgba(255,255,255,0.04);
  }
  .wx-sug-item:last-child { border-bottom:none; }
  .wx-sug-item:hover { background:rgba(215,161,61,0.12);color:var(--silver); }
  .wx-temp { font-size:38px;font-weight:700;color:var(--silver);font-family:var(--font-head);line-height:1; }
  .wx-icon { font-size:34px;margin-bottom:4px; }
  .wx-desc { font-size:12px;color:var(--silver-dim);margin-top:4px; }
  .wx-row { font-size:11px;color:var(--silver-muted);margin-top:5px; }
  .wx-city { font-size:11px;color:var(--gold);margin-bottom:8px;font-weight:600; }
  .wx-forecast { margin-top:12px;display:flex;flex-direction:column;gap:5px; }
  .wx-day { display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--silver-muted);border-top:1px solid rgba(215,161,61,0.06);padding-top:5px; }
  .wx-day .wx-day-temp { color:var(--silver);font-weight:700; }

  @media(max-width:1100px) {
    .page-3col { grid-template-columns:200px 1fr 200px; }
  }
  @media(max-width:900px) {
    .page-3col { grid-template-columns:1fr; }
    .left-col, .right-col { position:static;max-height:none; }
    .right-col { display:none; }
  }

  /* RSS headline rows */
  .rss-row {
    display:flex;flex-direction:column;gap:5px;
    padding:10px 0;border-bottom:1px solid rgba(215,161,61,0.06);
    cursor:pointer;
  }
  .rss-row:hover .rss-title { color:var(--gold); }
  .rss-row-top { display:flex;align-items:center;justify-content:space-between;gap:8px; }
  .rss-src {
    font-size:9px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;
    color:var(--gold);background:rgba(215,161,61,0.08);border:1px solid rgba(215,161,61,0.18);
    border-radius:3px;padding:2px 5px;white-space:nowrap;flex-shrink:0;
  }
  .rss-title { font-size:17px;color:var(--silver);line-height:1.5; }
  .rss-time { flex-shrink:0;font-size:10px;color:var(--silver-muted);white-space:nowrap; }

  /* AHoosh article cards */
  .news-card-full {
    background:rgba(10,30,60,0.8);border:1px solid rgba(215,161,61,0.15);
    border-radius:6px;padding:12px;cursor:pointer;
    transition:border-color 150ms ease;text-decoration:none;display:block;
  }
  .news-card-full:hover { border-color:rgba(215,161,61,0.45); }
  .news-card-full .src-badge {
    display:inline-block;font-size:9px;font-weight:700;letter-spacing:0.08em;
    text-transform:uppercase;color:var(--gold);background:rgba(215,161,61,0.1);
    border-radius:3px;padding:2px 6px;margin-bottom:6px;
  }
  .news-card-full .headline {
    font-size:12px;color:var(--silver);line-height:1.55;
    display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;
  }
  .news-card-full .date { font-size:10px;color:var(--silver-muted);margin-top:5px; }

  /* Channel buttons */
  .ch-btn {
    background:rgba(10,30,60,0.8);border:1px solid rgba(215,161,61,0.2);
    border-radius:6px;padding:5px 10px;font-size:11px;color:var(--silver-dim);
    cursor:pointer;font-family:var(--font-body);transition:all 150ms ease;
  }
  .ch-btn:hover,.ch-btn.active {
    background:rgba(215,161,61,0.15);border-color:rgba(215,161,61,0.5);color:var(--gold);
  }
  .ch-lang-btn {
    background:rgba(10,30,60,0.5);border:1px solid rgba(215,161,61,0.12);
    border-radius:4px;padding:3px 9px;font-size:11px;color:var(--silver-muted);
    cursor:pointer;font-family:var(--font-body);transition:all 150ms ease;
  }
  .ch-lang-btn:hover,.ch-lang-btn.active {
    background:rgba(215,161,61,0.12);border-color:rgba(215,161,61,0.4);color:var(--gold);
  }
  .lang-tab {
    background:rgba(10,30,60,0.6);border:1px solid rgba(215,161,61,0.15);
    border-radius:4px;padding:3px 9px;font-size:11px;color:var(--silver-muted);
    cursor:pointer;font-family:var(--font-body);transition:all 150ms ease;
  }
  .lang-tab:hover,.lang-tab.active {
    background:rgba(215,161,61,0.12);border-color:rgba(215,161,61,0.4);color:var(--gold);
  }

  /* ── Mobile channel picker ───────────────────────────────────────────── */
  .mobile-ch-picker { display:none;flex-direction:column;gap:8px;margin-bottom:12px; }
  .desktop-ch-picker { display:block; }
  .ch-sel {
    background:rgba(5,20,50,0.95);
    border:1px solid rgba(215,161,61,0.3);border-radius:6px;
    padding:8px 12px;color:var(--silver);font-size:13px;
    font-family:var(--font-body);outline:none;cursor:pointer;
  }
  @media(max-width:640px) {
    .mobile-ch-picker { display:flex; }
    .desktop-ch-picker { display:none; }
  }

  /* ── Markets mobile: 2-col grid ──────────────────────────────────────── */
  @media(max-width:880px) {
    .mkt-sidebar { position:static; }
    .mkt-rows { display:grid;grid-template-columns:1fr 1fr;gap:6px; }
    .mkt-skel { height:22px; }
  }
  @media(max-width:768px) {
    .clock-mobile-hide { display:none; }
  }
  @media(max-width:500px) {
    .mkt-rows { grid-template-columns:1fr; }
    .clock-wrap { gap:4px; }
    .clock-wrap .city-name { font-size:8px; }
  }

  /* ── Clocks scroll hint ──────────────────────────────────────────────── */
  #clocks-strip { scroll-behavior:smooth; }

  /* Skeleton */
  .news-skeleton {
    height:90px;
    background:linear-gradient(90deg,rgba(255,255,255,0.04) 25%,rgba(255,255,255,0.07) 50%,rgba(255,255,255,0.04) 75%);
    background-size:200% 100%;animation:shimmer 1.4s infinite;
    border-radius:6px;border:1px solid rgba(215,161,61,0.08);
  }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

<script is:inline define:vars={{ locale, t, ownArticles }}>
(function(){

// ─────────────────────────────────────────────────────────────────────────────
// ALL CHANNELS — verified live stream IDs
// No Iranian state media (no Tasnim, Mehr, Fars, IRIB, Press TV)
// Sport & Tech channels use `sources` array for intelligent auto-fallback
// ─────────────────────────────────────────────────────────────────────────────
const CHANNELS_ALL = [
  // English
  { id:'france24-en', name:'France 24',    lang:'en', type:'youtube', vid:'HvZt-nh9sGg' },
  { id:'aljazeera',   name:'Al Jazeera',   lang:'en', type:'hls',     src:'https://live-hls-web-aje-gcp.thehlive.com/AJE/index.m3u8' },
  { id:'bbc-world',   name:'BBC World',    lang:'en', type:'hls',     src:'https://vs-hls-push-ww-live.akamaized.net/x=4/i=urn:bbc:pips:service:bbc_news_channel_hd/mobile_wifi_main_hd_abr_v2.m3u8' },
  { id:'sky',         name:'Sky News',     lang:'en', type:'youtube', vid:'YDvsBbKfLPA' },
  { id:'cnn',         name:'CNN',          lang:'en', type:'youtube', vid:'aB-6_-GboaM' },
  { id:'cnn-i',       name:'CNN Intl',     lang:'en', type:'youtube', vid:'Z-nKTmdGpz0' },
  { id:'dw-en',       name:'DW News',      lang:'en', type:'youtube', vid:'LuKwFajn37U' },
  { id:'trt',         name:'TRT World',    lang:'en', type:'youtube', vid:'oNUi_iXNPeo' },
  { id:'euronews-en', name:'Euronews EN',  lang:'en', type:'youtube', vid:'pykpO5kQJ98' },
  { id:'reuters',     name:'Reuters',      lang:'en', type:'youtube', vid:'R02egjcxpUw' },
  { id:'abc',         name:'ABC News',     lang:'en', type:'youtube', vid:'exIvC0l8x-Y' },
  { id:'cbs',         name:'CBS News',     lang:'en', type:'youtube', vid:'khdVidn7AfQ' },
  { id:'fox',         name:'Fox News',     lang:'en', type:'youtube', vid:'qEHza_8UL-k' },
