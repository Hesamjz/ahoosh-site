// ── Lang order ──
var langOrder = [locale, 'en', 'sport', 'tech', 'de', 'fr', 'fa', 'ar', 'sr', 'es'];
function langRank(l) { var i = langOrder.indexOf(l); return i < 0 ? 99 : i; }
var SORTED = CHANNELS_ALL.slice().sort(function(a,b){ return langRank(a.lang)-langRank(b.lang); });

// ─────────────────────────────────────────────────────────────────────────────
// WORLD CLOCKS — SVG Analog (Rolex-style)
// ─────────────────────────────────────────────────────────────────────────────
var CLOCKS = [
  { key:'tehran',    tz:'Asia/Tehran',      name:(t.cityNames&&t.cityNames.tehran)    ||'Tehran'    },
  { key:'belgrade',  tz:'Europe/Belgrade',  name:(t.cityNames&&t.cityNames.belgrade)  ||'Belgrade'  },
  { key:'london',    tz:'Europe/London',    name:(t.cityNames&&t.cityNames.london)    ||'London'    },
  { key:'newYork',   tz:'America/New_York', name:(t.cityNames&&t.cityNames.newYork)   ||'New York'  },
  { key:'dubai',     tz:'Asia/Dubai',       name:(t.cityNames&&t.cityNames.dubai)     ||'Dubai'     },
  { key:'tokyo',     tz:'Asia/Tokyo',       name:(t.cityNames&&t.cityNames.tokyo)     ||'Tokyo'     },
  { key:'singapore', tz:'Asia/Singapore',   name:(t.cityNames&&t.cityNames.singapore) ||'Singapore' },
];

// SVG sizes
var R = 44; // dial radius (SVG units, viewBox 0 0 100 100, centre at 50,50)

function makeDial(id) {
  // Returns the static SVG string (no hands) — hands are <line> elements updated by JS
  var markers = '';
  for (var h = 0; h < 12; h++) {
    var angle = h * 30; // degrees
    var rad   = (angle - 90) * Math.PI / 180;
    var isMain = (h % 3 === 0); // 12,3,6,9
    var r1 = isMain ? R - 6 : R - 4;
    var r2 = isMain ? R - 1 : R - 2;
    var x1 = 50 + r1 * Math.cos(rad);
    var y1 = 50 + r1 * Math.sin(rad);
    var x2 = 50 + r2 * Math.cos(rad);
    var y2 = 50 + r2 * Math.sin(rad);
    var sw = isMain ? '2' : '1.2';
    markers += '<line x1="'+x1+'" y1="'+y1+'" x2="'+x2+'" y2="'+y2+'" stroke="#D7A13D" stroke-width="'+sw+'" stroke-linecap="round"/>';
  }
  return '<svg class="analog-clock" id="svgclock-'+id+'" viewBox="0 0 100 100" width="82" height="82" xmlns="http://www.w3.org/2000/svg">'
    // outer bezel ring
    + '<circle cx="50" cy="50" r="49" fill="#1a1206" stroke="#D7A13D" stroke-width="2"/>'
    // inner bezel ring
    + '<circle cx="50" cy="50" r="46" fill="none" stroke="#8a6520" stroke-width="0.5"/>'
    // dial face
    + '<circle cx="50" cy="50" r="'+R+'" fill="#03142E"/>'
    // markers
    + markers
    // hour hand (will be updated)
    + '<line id="hhand-'+id+'" x1="50" y1="50" x2="50" y2="22" stroke="#D7A13D" stroke-width="3.5" stroke-linecap="round"/>'
    // minute hand
    + '<line id="mhand-'+id+'" x1="50" y1="50" x2="50" y2="14" stroke="#C8C8C8" stroke-width="2.5" stroke-linecap="round"/>'
    // second hand
    + '<line id="shand-'+id+'" x1="50" y1="54" x2="50" y2="12" stroke="#C0392B" stroke-width="1.2" stroke-linecap="round"/>'
    // centre dot
    + '<circle cx="50" cy="50" r="2.5" fill="#D7A13D"/>'
    + '</svg>';
}

function handCoords(cx, cy, angle_deg, length) {
  var rad = (angle_deg - 90) * Math.PI / 180;
  return { x: cx + length * Math.cos(rad), y: cy + length * Math.sin(rad) };
}

var _tzFmt = CLOCKS.map(function(c) {
  return new Intl.DateTimeFormat('en-GB', {
    timeZone: c.tz,
    hour:'numeric', minute:'numeric', second:'numeric', hour12:false
  });
});
var _dateFmt = CLOCKS.map(function(c) {
  return new Intl.DateTimeFormat('en-GB', { timeZone:c.tz, weekday:'short', month:'short', day:'numeric' });
});

// Build DOM
var strip = document.getElementById('clocks-strip');
CLOCKS.forEach(function(c, i) {
  var wrap = document.createElement('div');
  wrap.className = 'clock-wrap';
  wrap.innerHTML =
    '<div class="city-name">' + c.name + '</div>' +
    makeDial(i) +
    '<div class="city-date" id="cd-' + i + '">---</div>';
  strip.appendChild(wrap);
});

function tickClocks() {
  var now = new Date();
  CLOCKS.forEach(function(c, i) {
    // parse time in timezone
    var parts = _tzFmt[i].formatToParts(now);
    var H = 0, M = 0, S = 0;
    parts.forEach(function(p) {
      if (p.type === 'hour')   H = parseInt(p.value, 10);
      if (p.type === 'minute') M = parseInt(p.value, 10);
      if (p.type === 'second') S = parseInt(p.value, 10);
    });

    var hAngle = (H % 12) * 30 + M * 0.5 + S * (0.5/60);
    var mAngle = M * 6 + S * 0.1;
    var sAngle = S * 6;

    var hPt = handCoords(50, 50, hAngle, 22);
    var mPt = handCoords(50, 50, mAngle, 30);
    var sPt = handCoords(50, 50, sAngle, 32);
    var sTail = handCoords(50, 50, sAngle + 180, 6);

    var hEl = document.getElementById('hhand-'+i);
    var mEl = document.getElementById('mhand-'+i);
    var sEl = document.getElementById('shand-'+i);
    if (!hEl) return;
    hEl.setAttribute('x2', hPt.x); hEl.setAttribute('y2', hPt.y);
    mEl.setAttribute('x2', mPt.x); mEl.setAttribute('y2', mPt.y);
    sEl.setAttribute('x1', sTail.x); sEl.setAttribute('y1', sTail.y);
    sEl.setAttribute('x2', sPt.x);  sEl.setAttribute('y2', sPt.y);

    var de = document.getElementById('cd-'+i);
    if (de) de.textContent = _dateFmt[i].format(now);
  });
}
tickClocks();
setInterval(tickClocks, 1000);

// ─────────────────────────────────────────────────────────────────────────────
// PLAYER STATE + LOGIC
// ─────────────────────────────────────────────────────────────────────────────
var currentCh   = null;
var hlsInstance = null;
var hlsReady    = false;
var activeSrcIdx  = 0;
var activeSrcList = [];

function updateSourceBadge() {
  var badge = document.getElementById('src-badge');
  var nxt   = document.getElementById('next-src-btn');
  if (!badge) return;
  if (activeSrcList.length <= 1) { badge.style.display='none'; if(nxt) nxt.style.display='none'; return; }
  badge.style.display = 'inline-flex';
  badge.textContent = '⚡ Source ' + (activeSrcIdx+1) + ' / ' + activeSrcList.length;
  if (nxt) nxt.style.display = (activeSrcIdx+1 < activeSrcList.length) ? 'inline-block' : 'none';
}

function tryNextSource() {
  if (activeSrcIdx + 1 >= activeSrcList.length) return;
  activeSrcIdx++;
  playSrc(activeSrcList[activeSrcIdx]);
  updateSourceBadge();
}

function playSrc(src) {
  if (src.type === 'youtube') { loadYoutube(src.vid); }
  else if (src.type === 'iframe') { loadIframe(src.src); }
  else { loadHls(src.src); }
}

function loadIframe(src) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  v.style.display = 'none';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  i.src = src;
  i.style.display = 'block';
}

function loadYoutube(vid) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  v.style.display = 'none';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  i.src = 'https://www.yout-ube.com/embed/' + vid + '?autoplay=1&rel=0&playsinline=1&fs=0';
  i.style.display = 'block';
}

function loadHls(src) {
  var v = document.getElementById('live-video');
  var i = document.getElementById('live-iframe');
  i.src = ''; i.style.display = 'none';
  v.style.display = 'block';
  function go() {
    if (window.Hls && Hls.isSupported()) {
      if (hlsInstance) hlsInstance.destroy();
      hlsInstance = new Hls({ enableWorker:true, lowLatencyMode:true });
      hlsInstance.loadSource(src);
      hlsInstance.attachMedia(v);
      hlsInstance.on(Hls.Events.MANIFEST_PARSED, function(){ v.play().catch(function(){}); });
      hlsInstance.on(Hls.Events.ERROR, function(ev, data) {
        if (data.fatal && activeSrcIdx + 1 < activeSrcList.length) {
          hlsInstance.destroy(); hlsInstance = null;
          activeSrcIdx++;
          updateSourceBadge();
          playSrc(activeSrcList[activeSrcIdx]);
        }
      });
    } else if (v.canPlayType('application/vnd.apple.mpegurl')) {
      v.src = src; v.play().catch(function(){});
    }
  }
  if (hlsReady) { go(); }
  else {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.5.7/hls.min.js';
    s.onload = function(){ hlsReady = true; go(); };
    document.head.appendChild(s);
  }
}

// YouTube postMessage fallback
window.addEventListener('message', function(e) {
  if (!e.data) return;
  try {
    var d = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
    if (d.event === 'infoDelivery' && d.info && d.info.playerError) {
      if (activeSrcIdx + 1 < activeSrcList.length) {
        activeSrcIdx++; updateSourceBadge(); playSrc(activeSrcList[activeSrcIdx]);
      }
    }
  } catch(ex){}
});

function loadChannel(ch) {
  currentCh = ch.id;
  document.querySelectorAll('.ch-btn').forEach(function(b){
    b.classList.toggle('active', b.dataset.id === ch.id);
  });
  document.getElementById('channel-info').textContent = '▶ ' + ch.name + ' — ' + t.liveSuffix;
  if (ch.sources && ch.sources.length) {
    activeSrcList = ch.sources;
  } else if (ch.type === 'youtube') {
    activeSrcList = [{ type:'youtube', vid:ch.vid }];
  } else {
    activeSrcList = [{ type:'hls', src:ch.src }];
  }
  activeSrcIdx = 0;
  updateSourceBadge();
  playSrc(activeSrcList[0]);
}

// ── Channel picker — two dropdowns ────────────────────────────────────────
var seenLangs = [];
CHANNELS_ALL.forEach(function(c){ if (seenLangs.indexOf(c.lang) < 0) seenLangs.push(c.lang); });

var langSel = document.getElementById('ch-lang-sel');
var nameSel = document.getElementById('ch-name-sel');

if (langSel && nameSel) {
  // Populate category dropdown
  seenLangs.forEach(function(l) {
    var o = document.createElement('option');
    o.value = l;
    o.textContent = t.langNames[l] || l;
    if (l === locale) o.selected = true;
    langSel.appendChild(o);
  });

  function populateChannels(lang) {
    nameSel.innerHTML = '';
    var list = CHANNELS_ALL.filter(function(c){ return c.lang === lang; });
    list.forEach(function(ch) {
      var o = document.createElement('option');
      o.value = ch.id;
      o.textContent = ch.name;
      nameSel.appendChild(o);
    });
    if (list.length) loadChannel(list[0]);
  }

  langSel.addEventListener('change', function() { populateChannels(this.value); });
  nameSel.addEventListener('change', function() {
    var ch = CHANNELS_ALL.find(function(c){ return c.id === this.value; }, this);
    if (ch) loadChannel(ch);
  });

  populateChannels(locale);
}

// ─────────────────────────────────────────────────────────────────────────────
// MARKETS SIDEBAR
// ─────────────────────────────────────────────────────────────────────────────
function fmtNum(n, dec) {
  if (n == null || !isFinite(n)) return '—';
  return n.toLocaleString('en-US', { minimumFractionDigits: dec||0, maximumFractionDigits: dec||0 });
}

function chgHtml(c) {
  if (c == null || !isFinite(c)) return '<span class="mkt-chg neu">—</span>';
  var cls = c > 0 ? 'pos' : (c < 0 ? 'neg' : 'neu');
  var arrow = c > 0 ? '▲' : (c < 0 ? '▼' : '');
  return '<span class="mkt-chg ' + cls + '">' + arrow + Math.abs(c).toFixed(2) + '%</span>';
}

function mktRow(name, price, change) {
  return '<div class="mkt-row">' +
    '<span class="mkt-name">' + name + '</span>' +
    '<span class="mkt-price">' + price + '</span>' +
    chgHtml(change) +
    '</div>';
}

function fetchMarkets() {
  Promise.all([
    fetch('/api/markets').then(function(r){ return r.json(); }),
    fetch('/api/crypto').then(function(r){ return r.json(); }),
  ]).then(function(results) {
    var mkt = results[0];
    var crypto = results[1];

    // FX
    var fxHtml = '';
    if (mkt.irr) {
      if (mkt.irr.usd) fxHtml += mktRow('USD / Toman', fmtNum(mkt.irr.usd.price, 0)+' T', mkt.irr.usd.change);
      if (mkt.irr.eur) fxHtml += mktRow('EUR / Toman', fmtNum(mkt.irr.eur.price, 0)+' T', mkt.irr.eur.change);
    }
    if (mkt.eur_rsd) fxHtml += mktRow('EUR / RSD', fmtNum(mkt.eur_rsd.price, 2), mkt.eur_rsd.change);
    document.getElementById('mkt-fx').innerHTML = fxHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Commodities
    var commHtml = '';
    if (mkt.commodities) {
      if (mkt.commodities.gold)  commHtml += mktRow('Gold (oz)',  '$'+fmtNum(mkt.commodities.gold.price, 0),  mkt.commodities.gold.change);
      if (mkt.commodities.brent) commHtml += mktRow('Brent (bbl)','$'+fmtNum(mkt.commodities.brent.price, 2), mkt.commodities.brent.change);
    }
    document.getElementById('mkt-comm').innerHTML = commHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Indices (5 key ones)
    var WANT = ['SPX','NDX','DAX','NI225','HSI'];
    var idxHtml = '';
    (mkt.indices||[]).forEach(function(idx) {
      if (WANT.indexOf(idx.short) >= 0) {
        idxHtml += mktRow(idx.name, fmtNum(idx.price, 0), idx.change);
      }
    });
    document.getElementById('mkt-indices').innerHTML = idxHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Crypto top 5
    var cryptoHtml = '';
    var coins = Array.isArray(crypto) ? crypto.slice(0, 5) : [];
    coins.forEach(function(c) {
      var sym = (c.symbol||'').toUpperCase();
      var px  = c.current_price;
      var dec = px >= 1000 ? 0 : (px >= 1 ? 2 : 4);
      var chg = c.price_change_percentage_24h_in_currency || c.price_change_percentage_24h || null;
      cryptoHtml += mktRow(sym, '$'+fmtNum(px, dec), chg);
    });
    document.getElementById('mkt-crypto').innerHTML = cryptoHtml ||
      '<div style="font-size:11px;color:var(--silver-muted);padding:4px 0;">—</div>';

    // Timestamp
    var upd = document.getElementById('mkt-updated');
    if (upd && mkt.updated) {
      var d = new Date(mkt.updated);
      upd.textContent = '↻ ' + d.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' });
    }
  }).catch(function(e){ console.warn('Markets fetch error', e); });
}

fetchMarkets();
setInterval(fetchMarkets, 300000); // 5 min

// ─────────────────────────────────────────────────────────────────────────────
// TITLE NEWS — RSS feed, auto-refresh every 5 min
// ─────────────────────────────────────────────────────────────────────────────
var rssArticles = [], rssLangFilter = 'all', searchTerm = '';

function timeAgo(p) {
  if (!p) return '';
  try {
    var d = new Date(p), f = (Date.now()-d.getTime())/60000;
    if (f < 1)    return t.timeAgo.now;
    if (f < 60)   return Math.round(f) + t.timeAgo.min;
    if (f < 1440) return Math.round(f/60) + t.timeAgo.hr;
    return Math.round(f/1440) + t.timeAgo.days;
  } catch(e){ return ''; }
}

function renderRssList() {
  var list = document.getElementById('rss-list');
  if (!list) return;
  var q = searchTerm.toLowerCase();
  var filtered = rssArticles.filter(function(a) {
    if (rssLangFilter !== 'all' && a.lang !== rssLangFilter) return false;
    if (q) return (a.title||'').toLowerCase().indexOf(q) >= 0;
    return true;
  });
  if (!filtered.length) {
    list.innerHTML = '<div style="color:var(--silver-muted);font-size:12px;padding:16px 0;">' + (t.noResults||'No results.') + '</div>';
    return;
  }
  list.innerHTML = '';
  filtered.slice(0, 50).forEach(function(a) {
    var row = document.createElement('a');
    row.className = 'rss-row';
    row.href = a.link || '#';
    row.target = '_blank';
    row.rel = 'noopener noreferrer';
    row.innerHTML =
      '<span class="rss-src">' + escHtml(a.source||'') + '</span>' +
      '<span class="rss-title">' + escHtml(a.title||'') + '</span>' +
      '<span class="rss-time">' + timeAgo(a.pubDate) + '</span>';
    list.appendChild(row);
  });
  var meta = document.getElementById('news-meta');
  if (meta) meta.textContent = (t.metaSources||'{n} articles').replace('{n}', rssArticles.length);
}

function buildRssLangTabs(articles) {
  var langs = {};
  articles.forEach(function(a){ langs[a.lang] = (langs[a.lang]||0)+1; });
  var row = document.getElementById('rss-lang-row');
  if (!row) return;
  row.innerHTML = '';
  var allBtn = document.createElement('button');
  allBtn.className = 'lang-tab active';
  allBtn.textContent = t.allNews;
  allBtn.addEventListener('click', function() {
    rssLangFilter = 'all';
    document.querySelectorAll('#rss-lang-row .lang-tab').forEach(function(x){ x.classList.remove('active'); });
    allBtn.classList.add('active'); renderRssList();
  });
  row.appendChild(allBtn);
  Object.keys(langs).sort().forEach(function(l) {
    var tab = document.createElement('button');
    tab.className = 'lang-tab';
    tab.textContent = (t.langNames[l]||l) + ' ('+langs[l]+')';
    tab.addEventListener('click', function() {
      rssLangFilter = l;
      document.querySelectorAll('#rss-lang-row .lang-tab').forEach(function(x){ x.classList.remove('active'); });
      tab.classList.add('active'); renderRssList();
    });
    row.appendChild(tab);
  });
}

function fetchTitleNews() {
  var updEl = document.getElementById('rss-updated');
  if (updEl) updEl.textContent = '↻…';
  fetch('/api/news').then(function(r){ return r.json(); }).then(function(data) {
    rssArticles = data.articles || [];
    buildRssLangTabs(rssArticles);
    renderRssList();
    if (updEl) updEl.textContent = new Date().toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' });
  }).catch(function(e) {
    var list = document.getElementById('rss-list');
    if (list) list.innerHTML = '<div style="color:var(--silver-muted);font-size:12px;padding:16px 0;">' + (t.failedLoad||'Failed to load.') + '</div>';
  });
}

fetchTitleNews();
setInterval(fetchTitleNews, 300000); // 5 min

var se = document.getElementById('news-search');
if (se) se.addEventListener('input', function(){ searchTerm = this.value.trim(); renderRssList(); });

// ─────────────────────────────────────────────────────────────────────────────
// DETAIL NEWS — AHoosh own articles, static from content collection
// ─────────────────────────────────────────────────────────────────────────────
function renderDetailNews() {
  var grid = document.getElementById('detail-grid');
  if (!grid) return;
  if (!ownArticles || !ownArticles.length) {
    grid.innerHTML = '<div style="color:var(--silver-muted);font-size:12px;padding:16px 0;grid-column:1/-1;">Our editorial team is working on the first articles.</div>';
    return;
  }
  grid.innerHTML = '';
  ownArticles.forEach(function(a) {
    var card = document.createElement('a');
    card.className = 'news-card-full';
    card.href = '/articles/' + a.slug;
    card.innerHTML =
      '<div class="src-badge" style="background:rgba(215,161,61,0.2);color:var(--gold);">★ AHoosh</div>' +
      '<div class="headline">' + escHtml(a.title) + '</div>' +
      '<div class="date">' + timeAgo(a.pubDate) + '</div>';
    grid.appendChild(card);
  });
}

renderDetailNews();

// ─────────────────────────────────────────────────────────────────────────────
// UTILS
// ─────────────────────────────────────────────────────────────────────────────
function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

})();
</script>
