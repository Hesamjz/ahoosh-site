  };
  const T = DATA[LANG] || DATA.en;

  // ─── BUILD TESTS FROM T (questions get id+keying from META) ───
  function buildBig5Questions(){return BIG5_META.map(function(m,i){return{id:m.id,t:m.t,r:m.r,text:T.big5.questions[i]};});}
  function buildSEQuestions(){return SE_META.map(function(m,i){return{id:m.id,r:m.r,text:T.selfesteem.questions[i]};});}
  function big5LabelObjs(){return T.big5.labels.map(function(s,i){return{v:i+1,s:s};});}
  function seLabelObjs(){return T.selfesteem.labels.map(function(s,i){return{v:i+1,s:s};});}
  function buildSelfEffQuestions(){return SELFEFF_META.map(function(m,i){return{id:m.id,r:m.r,text:T.selfeff.questions[i]};});}
  function selfEffLabelObjs(){return T.selfeff.labels.map(function(s,i){return{v:i+1,s:s};});}
  function buildOptimismQuestions(){return LOT_META.map(function(m,i){return{id:m.id,text:T.optimism.questions[i]};});}
  function optimismLabelObjs(){return T.optimism.labels.map(function(s,i){return{v:i+1,s:s};});}
  function buildDiscQuestions(){const d=T.disc||DATA.en.disc;return DISC_META.map(function(m,i){return{id:m.id,dim:m.dim,text:d.questions[i]};});}
  function discLabelObjs(){const d=T.disc||DATA.en.disc;return d.labels.map(function(s,i){return{v:i+1,s:s};});}
  function buildGdmsQuestions(){const d=T.gdms||DATA.en.gdms;return GDMS_META.map(function(m,i){return{id:m.id,dim:m.dim,text:d.questions[i]};});}
  function gdmsLabelObjs(){const d=T.gdms||DATA.en.gdms;return d.labels.map(function(s,i){return{v:i+1,s:s};});}

  // Compose trait objects (name + interpretations from T, color/bg from TRAIT_STYLE)
  function big5Traits(){const out={};for(const k of ['E','A','C','N','O']){out[k]=Object.assign({},T.big5.traits[k],TRAIT_STYLE[k]);}return out;}
  function discTraits(){const d=T.disc||DATA.en.disc;const out={};for(const k of ['D','I','S','C']){out[k]=Object.assign({},d.traits[k],DISC_STYLE[k]);}return out;}
  function gdmsTraits(){const d=T.gdms||DATA.en.gdms;const out={};for(const k of ['R','I','D','A','S']){out[k]=Object.assign({},d.traits[k],GDMS_STYLE[k]);}return out;}

  const TESTS=[
    {id:'big5',title:T.big5.title,subtitle:T.big5.subtitle,icon:'🧠',color:'#7C3AED',desc:T.big5.desc,questions:buildBig5Questions(),labels:big5LabelObjs(),score:scoreBig5,resultType:'big5',traits:big5Traits(),traitOrder:['E','A','C','N','O'],tagline:T.big5.tagline,footer:T.big5.footer},
    {id:'selfesteem',title:T.selfesteem.title,subtitle:T.selfesteem.subtitle,icon:'🌟',color:'#0891B2',desc:T.selfesteem.desc,questions:buildSEQuestions(),labels:seLabelObjs(),score:scoreSE,resultType:'single',levels:T.selfesteem.levels,scaleName:T.selfesteem.scaleName,tagline:T.selfesteem.tagline,footer:T.selfesteem.footer},
    {id:'selfeff',title:T.selfeff.title,subtitle:T.selfeff.subtitle,icon:'💪',color:'#0D9488',desc:T.selfeff.desc,questions:buildSelfEffQuestions(),labels:selfEffLabelObjs(),score:scoreSelfEff,resultType:'single',levels:T.selfeff.levels,scaleName:T.selfeff.scaleName,tagline:T.selfeff.tagline,footer:T.selfeff.footer},
    {id:'optimism',title:T.optimism.title,subtitle:T.optimism.subtitle,icon:'🌅',color:'#F59E0B',desc:T.optimism.desc,questions:buildOptimismQuestions(),labels:optimismLabelObjs(),score:scoreOptimism,resultType:'single',levels:T.optimism.levels,scaleName:T.optimism.scaleName,tagline:T.optimism.tagline,footer:T.optimism.footer},
    (function(){const d=T.disc||DATA.en.disc;return{id:'disc',title:d.title,subtitle:d.subtitle,icon:'🎯',color:'#EF4444',desc:d.desc,questions:buildDiscQuestions(),labels:discLabelObjs(),score:scoreDisc,resultType:'big5',traits:discTraits(),traitOrder:['D','I','S','C'],tagline:d.tagline,footer:d.footer};}()),
    (function(){const d=T.gdms||DATA.en.gdms;return{id:'gdms',title:d.title,subtitle:d.subtitle,icon:'⚡',color:'#8B5CF6',desc:d.desc,questions:buildGdmsQuestions(),labels:gdmsLabelObjs(),score:scoreGdms,resultType:'big5',traits:gdmsTraits(),traitOrder:['R','I','D','A','S'],tagline:d.tagline,footer:d.footer};}()),
  ];

  function levelLabel(level){return level==='high'?T.ui.high:level==='low'?T.ui.low:T.ui.medium;}

  // ─── SHARED COMPONENTS ────────────────────────────────
  function ProgressHeader({title,current,total,onBack}){
    const pct=Math.round(current/total*100);
    return h('div',{className:'bg-white border-b border-gray-100 px-4 py-3 sticky top-0 z-10'},
      h('div',{className:'max-w-2xl mx-auto'},
        h('div',{className:'flex items-center justify-between mb-2'},
          h('button',{onClick:onBack,className:'text-gray-400 hover:text-navy text-sm font-medium focus:outline-none transition-colors'},T.ui.back),
          h('span',{className:'text-navy font-semibold text-sm truncate mx-4'},title),
          h('span',{className:'text-gray-400 text-xs font-medium whitespace-nowrap'},current+'/'+total)
        ),
        h('div',{className:'w-full bg-gray-100 rounded-full h-1.5'},
          h('div',{className:'bg-gold h-1.5 rounded-full transition-all duration-500',style:{width:pct+'%'}})
        )
      )
    );
  }

  function QuestionCard({question,answers,labels,onPick,onBack,current,total,testTitle}){
    const picked=answers[question.id];
    return h('div',{className:'bg-gray-50 flex flex-col'},
      h(ProgressHeader,{title:testTitle,current,total,onBack}),
      h('div',{className:'flex flex-col items-center justify-center px-4 py-8'},
        h('div',{className:'max-w-2xl w-full fade-in'},
          h('p',{className:'text-gray-400 text-xs font-semibold uppercase tracking-wider text-center mb-4'},T.ui.question+' '+current),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-5 text-center'},
            h('p',{className:'text-navy text-xl font-semibold leading-snug'},'"'+question.text+'"')
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-5'},
            h('p',{className:'text-gray-400 text-xs font-medium text-center mb-4'},T.ui.selectPrompt),
            h('div',{className:'flex flex-col sm:flex-row gap-2'},
              labels.map(function(opt){
                return h('button',{key:opt.v,onClick:function(){onPick(opt.v);},className:'flex-1 py-3 px-2 rounded-xl border-2 text-xs font-semibold text-center transition-all focus:outline-none '+(picked===opt.v?'border-gold bg-amber-50 text-navy':'border-gray-200 text-gray-500 hover:border-yellow-300')},opt.s);
              })
            )
          ),
          h('div',{className:'flex justify-start mt-4'},
            h('button',{onClick:onBack,disabled:current<=1,className:'text-gray-400 text-sm font-medium disabled:opacity-30 focus:outline-none'},T.ui.previous)
          )
        )
      )
    );
  }

  function TraitBar({name,pct,level,color,bg,interpretation}){
    return h('div',{className:'mb-7'},
      h('div',{className:'flex items-center justify-between mb-1.5'},
        h('div',{className:'flex items-center gap-2'},
          h('span',{className:'w-2.5 h-2.5 rounded-full',style:{background:color}}),
          h('span',{className:'font-semibold text-navy text-sm'},name),
          h('span',{className:'text-xs font-semibold px-2 py-0.5 rounded-full',style:{background:bg,color:color}},levelLabel(level))
        ),
        h('span',{className:'text-gray-400 text-sm font-semibold'},pct+'%')
      ),
      h('div',{className:'w-full bg-gray-100 rounded-full h-2.5 mb-1'},
        h('div',{className:'bar-fill h-2.5 rounded-full',style:{width:pct+'%',background:color}})
      ),
      h('div',{className:'flex justify-between text-gray-300 text-xs mb-2'},h('span',null,T.ui.axisLow),h('span',null,T.ui.axisHigh)),
      h('p',{className:'text-gray-600 text-sm leading-relaxed bg-gray-50 rounded-xl px-4 py-3'},interpretation)
    );
  }

  function ResultActions({onRetake,onHome,title}){
    return h('div',{className:'bg-white border-b border-gray-100 px-4 py-4 no-print'},
      h('div',{className:'max-w-2xl mx-auto flex items-center justify-between'},
        h('span',{className:'text-navy font-bold text-sm'},title),
        h('div',{className:'flex items-center gap-2'},
          h('button',{onClick:function(){window.print();},className:'text-gray-500 text-xs font-medium focus:outline-none'},T.ui.print),
          h('button',{onClick:onRetake,className:'border border-gray-300 text-gray-600 text-xs font-medium px-3 py-1.5 rounded-lg focus:outline-none'},T.ui.retake),
          h('button',{onClick:onHome,className:'bg-navy text-white text-xs font-medium px-3 py-1.5 rounded-lg focus:outline-none no-print'},T.ui.allTests)
        )
      )
    );
  }

  function ResultsWrapper({test,scores,onRetake,onHome}){
    const ORDER=test.traitOrder||[];
    const backBtn=h('div',{className:'mt-6 bg-navy rounded-2xl p-5 text-center no-print'},
      h('button',{onClick:onHome,className:'bg-gold text-navy font-bold text-sm px-6 py-2 rounded-lg'},T.ui.backToTests)
    );

    if(test.resultType==='single'){
      const{pct,level}=scores;
      const lv=test.levels[level];
      const color=pct>=70?'#10B981':pct>=45?'#F59E0B':'#EF4444';
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:test.title}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold mb-1'},test.title+T.ui.resultsSuffix),h('p',{className:'text-gray-400 text-sm'},test.scaleName)),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6 text-center'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},T.ui.yourScore),
            h('p',{className:'text-5xl font-bold mb-1'},pct),
            h('p',{className:'text-sm mb-3',style:{color:'rgba(138,155,176,0.7)'}},T.ui.outOf),
            h('span',{className:'inline-block text-sm font-semibold px-4 py-1.5 rounded-full',style:{background:color+'33',color:color}},lv.label)
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('div',{className:'w-full bg-gray-100 rounded-full h-4 mb-4'},h('div',{className:'bar-fill h-4 rounded-full',style:{width:pct+'%',background:color}})),
            h('p',{className:'text-gray-600 text-sm leading-relaxed'},lv.desc)
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},test.footer),
          backBtn
        )
      );
    }

    if(test.resultType==='big5'){
      const pMap=T.big5.profile;
      const topTwo=ORDER.map(function(k){return[k,scores[k]];}).sort(function(a,b){return b[1].pct-a[1].pct;}).slice(0,2);
      const joiner=LANG==='de'?' und ':LANG==='fa'?' و ':LANG==='sr'?' i ':' and ';
      const profileDesc=topTwo.map(function(x){return pMap[x[0]];}).join(joiner);
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:T.big5.title}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},T.big5.title+T.ui.resultsSuffix)),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},T.ui.yourProfile),
            h('p',{className:'font-semibold'},T.ui.characterizedAs,h('span',{className:'text-gold'},profileDesc),'.')
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4'},
            h('h2',{className:'text-navy font-semibold text-sm mb-4'},T.ui.scoreOverview),
            ORDER.map(function(k){const t=test.traits[k];const s=scores[k];return h('div',{key:k,className:'flex items-center gap-3 mb-3'},h('span',{className:'text-gray-500 text-xs w-36 flex-shrink-0'},t.name),h('div',{className:'flex-1 bg-gray-100 rounded-full h-2'},h('div',{className:'bar-fill h-2 rounded-full',style:{width:s.pct+'%',background:t.color}})),h('span',{className:'text-gray-400 text-xs font-semibold w-8 text-right'},s.pct+'%'));})
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('h2',{className:'text-navy font-semibold text-sm mb-6'},T.ui.detailedResults),
            ORDER.map(function(k){const t=test.traits[k];const s=scores[k];return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},test.footer),
          ASSESS_HUB && h('a',{href:'/assess/report',className:'block w-full text-center mt-2 mb-6 py-4 rounded-xl font-bold text-base no-print',style:{background:'#D7A13D',color:'#010A18',textDecoration:'none'}},'→ Get your full report'),
          backBtn
        )
      );
    }

    // Generic fallback
    return h('div',{className:'bg-gray-50'},
      h(ResultActions,{onRetake,onHome,title:test.title}),
      h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
        h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},test.title+T.ui.resultsSuffix)),
        h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4'},
          h('h2',{className:'text-navy font-semibold text-sm mb-5'},T.ui.yourScores),
          ORDER.map(function(k){const t=test.traits[k];const s=scores[k];if(!t||!s)return null;return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
        ),
        h('p',{className:'text-gray-400 text-xs text-center mb-4'},T.ui.forInfoOnly),
        backBtn
      )
    );
  }

  function SurveyRunner({test,onComplete,onBack}){
    const[idx,setIdx]=useState(0);
    const[answers,setAns]=useState({});
    const qs=test.questions;
    const q=qs[idx];
    function pick(v){
      const next=Object.assign({},answers);next[q.id]=v;setAns(next);
      setTimeout(function(){if(idx<qs.length-1)setIdx(function(i){return i+1;});else onComplete(next);},280);
    }
    return h(QuestionCard,{question:q,answers,labels:test.labels,onPick:pick,onBack:function(){idx>0?setIdx(function(i){return i-1;}):onBack();},current:idx+1,total:qs.length,testTitle:test.title});
  }

  function Home({onSelectTest}){
    const tagColors=T.tags||{};
    return h('div',{className:'bg-gray-50'},
      h('div',{className:'bg-navy px-6 py-10 text-center'},
        h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-3'},T.ui.kicker),
        h('h1',{className:'text-white text-3xl font-bold mb-3'},T.ui.heroTitle),
        h('p',{className:'text-silver/80 text-base max-w-xl mx-auto'},T.ui.heroSubtitle)
      ),
      h('div',{className:'max-w-2xl mx-auto px-4 pt-8 pb-16'},
        h('p',{className:'text-gray-400 text-xs font-semibold uppercase tracking-widest mb-4 text-center'},TESTS.length+' '+T.ui.available),
        h('div',{className:'space-y-4'},
          TESTS.map(function(test){
            return h('div',{key:test.id,onClick:function(){onSelectTest(test.id);},className:'card-hover bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 shadow-sm'},
              h('div',{className:'w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0',style:{background:'linear-gradient(135deg,'+test.color+'22,'+test.color+'44)'}},test.icon),
              h('div',{className:'flex-1 min-w-0'},
                h('div',{className:'flex items-start justify-between gap-2 mb-1'},
                  h('h3',{className:'text-navy font-bold text-base leading-tight'},test.title),
                  h('span',{className:'text-xs font-semibold px-2 py-0.5 rounded-full flex-shrink-0 '+(tagColors[test.tagline]||'bg-gray-100 text-gray-600')},test.tagline)
                ),
                h('p',{className:'text-gray-400 text-xs mb-2'},test.subtitle),
                h('p',{className:'text-gray-600 text-sm leading-relaxed'},test.desc)
              ),
              h('div',{className:'text-gray-300 text-xl flex-shrink-0 self-center'},'›')
            );
          })
        )
      )
    );
  }

  function GateScreen(props){
    const test=props.test, scores=props.scores, onDone=props.onDone;
    const[email,setEmail]=useState('');
    const[name,setName]=useState('');
    const[busy,setBusy]=useState(false);
    const[err,setErr]=useState('');
    function repScore(){
      if(scores&&typeof scores.pct==='number')return scores.pct;
      if(scores&&typeof scores==='object'){var v=Object.keys(scores).map(function(k){var x=scores[k];return x&&typeof x.pct==='number'?x.pct:null;}).filter(function(x){return x!=null;});if(v.length)return Math.round(v.reduce(function(a,b){return a+b;},0)/v.length);}
      return null;
    }
    function submit(skip){
      if(skip){onDone();return;}
      if(!email||email.indexOf('@')<1){setErr((T.ui&&T.ui.gateInvalid)||'Please enter a valid email.');return;}
      setBusy(true);
      fetch('/api/email-gate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:email.trim(),name:name.trim(),source:'assess_'+test.id,track:test.id,test_title:test.title,score:repScore(),scores:scores,result_type:test.resultType,consent:true})}).catch(function(){}).finally(function(){onDone();});
    }
    return h('div',{className:'bg-gray-50 flex items-center justify-center px-4 py-20',style:{minHeight:'70vh'}},
      h('div',{className:'bg-white rounded-2xl border border-gray-100 shadow-sm p-8 w-full text-center',style:{maxWidth:'420px'}},
        h('div',{className:'text-4xl mb-3'},'✅'),
        h('h2',{className:'text-navy text-xl font-bold mb-2'},(T.ui&&T.ui.gateTitle)||'Your results are ready'),
        h('p',{className:'text-gray-500 text-sm mb-5'},(T.ui&&T.ui.gateSub)||"Enter your email to see your full result — we'll send you a copy too."),
        h('input',{type:'text',value:name,placeholder:(T.ui&&T.ui.gateName)||'Your name (optional)',onChange:function(e){setName(e.target.value);},className:'w-full mb-3 px-4 py-3 rounded-xl border border-gray-200 text-sm'}),
        h('input',{type:'email',value:email,placeholder:'you@email.com',onChange:function(e){setEmail(e.target.value);setErr('');},onKeyDown:function(e){if(e.key==='Enter')submit(false);},className:'w-full mb-2 px-4 py-3 rounded-xl border border-gray-200 text-sm'}),
        err?h('p',{className:'text-red-500 text-xs mb-2'},err):null,
        h('button',{onClick:function(){submit(false);},disabled:busy,className:'w-full py-3 rounded-xl bg-gold text-navy font-bold text-sm mb-3',style:busy?{opacity:0.5}:{}},busy?'…':((T.ui&&T.ui.gateBtn)||'Show my results →')),
        h('button',{onClick:function(){submit(true);},className:'text-gray-400 text-xs underline'},(T.ui&&T.ui.gateSkip)||'Skip and view results')
      )
    );
  }

  function App(){
    // Always start on the test picker (Home) — in hub mode this now offers ALL tests,
    // not just Big Five. Each test computes real scores and renders ResultsWrapper.
    const[screen,setScreen]=useState('home');
    const[activeId,setActive]=useState(null);
    const[scores,setScores]=useState(null);
    const test=TESTS.find(function(t){return t.id===activeId;});
    function selectTest(id){setActive(id);setScreen('survey');window.scrollTo(0,0);}
    function handleComplete(ans){
      const scored=test.score(ans);
      setScores(scored);
      // Persist every completed test so a combined profile can be built later.
      try{
        var key='ahoosh_assess_'+test.id;
        localStorage.setItem(key,JSON.stringify({test_id:test.id,title:test.title,resultType:test.resultType,scores:scored,completed_at:new Date().toISOString()}));
      }catch(e){}
      // Data capture: gate the result behind an email (collect the lead, then reveal).
      setScreen('gate');
      window.scrollTo(0,0);
    }
    function goHome(){setScreen('home');setActive(null);setScores(null);window.scrollTo(0,0);}
    let content;
    if(screen==='home') content=h(Home,{onSelectTest:selectTest});
    else if(screen==='survey') content=h(SurveyRunner,{test,onComplete:handleComplete,onBack:goHome});
    else if(screen==='gate') content=h(GateScreen,{test,scores,onDone:function(){setScreen('results');window.scrollTo(0,0);}});
    else content=h(ResultsWrapper,{test,scores,onRetake:function(){selectTest(activeId);},onHome:goHome});
    return h('div',{dir:RTL?'rtl':'ltr'},content);
  }

  ReactDOM.createRoot(document.getElementById('root')).render(h(App));
  })();
  </script>
