      selfesteem:{
        title:'Selbstwertgefühl',subtitle:'Rosenberg-Skala · 10 Fragen · ~3 Min.',
        desc:'Der Goldstandard zur Messung des Selbstwertgefühls. Weltweit in klinischen, pädagogischen und HR-Kontexten eingesetzt.',
        tagline:'Selbst & Wohlbefinden',scaleName:'Rosenberg-Skala zum Selbstwertgefühl',
        footer:'Basierend auf der Rosenberg-Skala zum Selbstwertgefühl (gemeinfrei). Nur zu Informationszwecken.',
