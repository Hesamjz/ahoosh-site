  const T = DATA[LANG] || DATA.en;

  // ─── BUILD TESTS FROM T (questions get id+keying from META) ───
  function buildBig5Questions(){return BIG5_META.map(function(m,i){return{id:m.id,t:m.t,r:m.r,text:T.big5.questions[i]};});}
  function buildSEQuestions(){return SE_META.map(function(m,i){return{id:m.id,r:m.r,text:T.selfesteem.questions[i]};});}
  function big5LabelObjs(){return T.big5.labels.map(function(s,i){return{v:i+1,s:s};});}
  function seLabelObjs(){return T.selfesteem.labels.map(function(s,i){return{v:i+1,s:s};});}

  // Compose trait objects (name + interpretations from T, color/bg from TRAIT_STYLE)
  function big5Traits(){const out={};for(const k of ['E','A','C','N','O']){out[k]=Object.assign({},T.big5.traits[k],TRAIT_STYLE[k]);}return out;}

  const TESTS=[
    {id:'big5',title:T.big5.title,subtitle:T.big5.subtitle,icon:'🧠',color:'#7C3AED',desc:T.big5.desc,questions:buildBig5Questions(),labels:big5LabelObjs(),score:scoreBig5,resultType:'big5',traits:big5Traits(),traitOrder:['E','A','C','N','O'],tagline:T.big5.tagline,footer:T.big5.footer},
    {id:'selfesteem',title:T.selfesteem.title,subtitle:T.selfesteem.subtitle,icon:'🌟',color:'#0891B2',desc:T.selfesteem.desc,questions:buildSEQuestions(),labels:seLabelObjs(),score:scoreSE,resultType:'selfesteem',tagline:T.selfesteem.tagline,footer:T.selfesteem.footer},
  ];

  function levelLabel(level){return level==='high'?T.ui.high:level==='low'?T.ui.low:T.ui.medium;}

  // ─── SHARED COMPONENTS ────────────────────────────────
  function ProgressHeader({title,current,total,onBack}){
    const pct=Math.round(current/total*100);
    return h('div',{className:'bg-white border-b border-gray-100 px-4 py-3 sticky top-0 z-10'},
      h('div',{className:'max-w-2xl mx-auto'},
        h('div',{className:'flex items-center justify-between mb-2'},
          h('button',{onClick:onBack,className:'text-gray-400 hover:text-navy text-sm font-medium focus:outline-none transition-colors'},T.ui.back),
          h('span',{className:'text-navy font-semibold text-sm truncate mx-4'},title),
          h('span',{className:'text-gray-400 text-xs font-medium whitespace-nowrap'},current+'/'+total)
        ),
        h('div',{className:'w-full bg-gray-100 rounded-full h-1.5'},
          h('div',{className:'bg-gold h-1.5 rounded-full transition-all duration-500',style:{width:pct+'%'}})
        )
      )
    );
  }

  function QuestionCard({question,answers,labels,onPick,onBack,current,total,testTitle}){
    const picked=answers[question.id];
    return h('div',{className:'bg-gray-50 flex flex-col'},
      h(ProgressHeader,{title:testTitle,current,total,onBack}),
      h('div',{className:'flex flex-col items-center justify-center px-4 py-8'},
        h('div',{className:'max-w-2xl w-full fade-in'},
          h('p',{className:'text-gray-400 text-xs font-semibold uppercase tracking-wider text-center mb-4'},T.ui.question+' '+current),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-5 text-center'},
            h('p',{className:'text-navy text-xl font-semibold leading-snug'},'"'+question.text+'"')
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-5'},
            h('p',{className:'text-gray-400 text-xs font-medium text-center mb-4'},T.ui.selectPrompt),
            h('div',{className:'flex flex-col sm:flex-row gap-2'},
              labels.map(function(opt){
                return h('button',{key:opt.v,onClick:function(){onPick(opt.v);},className:'flex-1 py-3 px-2 rounded-xl border-2 text-xs font-semibold text-center transition-all focus:outline-none '+(picked===opt.v?'border-gold bg-amber-50 text-navy':'border-gray-200 text-gray-500 hover:border-yellow-300')},opt.s);
