---
// Shared assess mini-app body. The React/Tailwind CDN scripts must be added
// by each page wrapper via <Fragment slot="head"> (see AssessHead below).
// Pass `banner` to show a locale notice above the app (fa/de/sr while the
// validated translations of the test items are in progress).
interface Props { banner?: string }
const { banner } = Astro.props;
---

{banner && (
  <div style="background:rgba(215,161,61,0.1);border-bottom:1px solid rgba(215,161,61,0.25);padding:12px 24px;text-align:center;font-size:13px;color:#D7A13D;">
    {banner}
  </div>
)}


  <style is:global>
    @media print { .no-print { display:none!important; } }
    .bar-fill { transition: width .7s ease; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }
    .fade-in { animation: fadeIn .3s ease both; }
    .card-hover { transition: all .2s; cursor: pointer; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,.5); }

    /* ── Dark theme overrides for assess page ── */
    #root { background: #060F1E; min-height: 60vh; }
    #root .bg-gray-50  { background: #060F1E !important; }
    #root .bg-white    { background: rgba(8,22,50,0.95) !important; }

    /* Card borders */
    #root .border-gray-100 { border-color: rgba(215,161,61,0.15) !important; }
    #root .border-gray-200 { border-color: rgba(215,161,61,0.18) !important; }
    #root .border-b        { border-bottom-color: rgba(215,161,61,0.12) !important; }

    /* Text */
    #root .text-navy   { color: #e8eaf0 !important; }
    #root .text-gray-600 { color: #8a9bb0 !important; }
    #root .text-gray-500 { color: #7a8b9e !important; }
    #root .text-gray-400 { color: #5e6e82 !important; }
    #root .text-gray-300 { color: #3a4a5c !important; }

    /* Progress bar track */
    #root .bg-gray-100 { background: rgba(255,255,255,0.08) !important; }

    /* Selected Likert button */
    #root .bg-amber-50 { background: rgba(215,161,61,0.15) !important; }

    /* Shadows */
    #root .shadow-sm { box-shadow: 0 2px 12px rgba(0,0,0,0.5) !important; }

    /* Tag badges */
    #root .bg-violet-100 { background: rgba(124,58,237,0.18) !important; }
    #root .text-violet-700 { color: #a78bfa !important; }
    #root .bg-pink-100 { background: rgba(236,72,153,0.18) !important; }
    #root .text-pink-700 { color: #f472b6 !important; }
    #root .bg-sky-100 { background: rgba(14,165,233,0.18) !important; }
    #root .text-sky-700 { color: #38bdf8 !important; }
    #root .bg-emerald-100 { background: rgba(16,185,129,0.18) !important; }
    #root .text-emerald-700 { color: #34d399 !important; }
    #root .bg-gray-100.rounded-full { background: rgba(255,255,255,0.08) !important; color: #8a9bb0 !important; }

    /* Sticky question header */
    #root .sticky { background: rgba(6,15,30,0.97) !important; backdrop-filter: blur(8px); }
  </style>

  <div id="root" class="antialiased"></div>

  <script is:inline>
  (function(){
  const {useState} = React;
  const h = React.createElement;

  // ─── BIG FIVE (IPIP-50) ───────────────────────────────
  const BIG5_TRAITS = {
    E:{name:'Extraversion',color:'#F59E0B',bg:'#FEF3C7',high:'You are energized by social situations, enjoy being around people, and tend to be outgoing. You feel comfortable in group settings.',medium:'You balance social engagement with alone time. You can be outgoing when needed but also appreciate quieter moments.',low:'You tend to be reserved and prefer smaller groups. You recharge alone — a strength in roles requiring deep focus.'},
    A:{name:'Agreeableness',color:'#10B981',bg:'#D1FAE5',high:'You are warm, cooperative, and considerate. You value harmony and excel in team environments requiring empathy.',medium:'You balance cooperation with assertiveness. Compassionate when needed, but you hold your ground.',low:'You are direct and results-focused. Comfortable with conflict — a strength in negotiation and leadership.'},
    C:{name:'Conscientiousness',color:'#3B82F6',bg:'#DBEAFE',high:'You are highly organized, reliable, and goal-driven. You plan ahead and follow through. You excel in structured environments.',medium:'Reasonably organized. Diligent when motivated, though you may prefer some flexibility.',low:'Flexible and spontaneous. You adapt as things unfold and may thrive in dynamic environments.'},
    N:{name:'Emotional Stability',color:'#EF4444',bg:'#FEE2E2',high:'You remain calm under pressure, recover quickly from setbacks, and maintain balance in stressful situations.',medium:'You experience typical emotional ups and downs and handle most stress reasonably well.',low:'You experience emotions intensely. This sensitivity can be a strength in empathy-requiring roles.'},
    O:{name:'Openness',color:'#8B5CF6',bg:'#EDE9FE',high:'Intellectually curious, creative, and open to new experiences. You enjoy complexity and abstract thinking.',medium:'You balance practicality with curiosity, engaging with creativity when the context calls for it.',low:'Practical and grounded. You prefer proven approaches — a strength in roles that reward consistency.'},
  };
  const BIG5_Q=[
    {id:1,text:"I am the life of the party.",t:'E',r:false},{id:2,text:"I insult people.",t:'A',r:true},{id:3,text:"I am always prepared.",t:'C',r:false},{id:4,text:"I get stressed out easily.",t:'N',r:false},{id:5,text:"I have a rich vocabulary.",t:'O',r:false},
    {id:6,text:"I don't talk a lot.",t:'E',r:true},{id:7,text:"I am interested in people.",t:'A',r:false},{id:8,text:"I leave my belongings around.",t:'C',r:true},{id:9,text:"I am relaxed most of the time.",t:'N',r:true},{id:10,text:"I have difficulty understanding abstract ideas.",t:'O',r:true},
    {id:11,text:"I feel comfortable around people.",t:'E',r:false},{id:12,text:"I am not really interested in others.",t:'A',r:true},{id:13,text:"I pay attention to details.",t:'C',r:false},{id:14,text:"I worry about things.",t:'N',r:false},{id:15,text:"I have a vivid imagination.",t:'O',r:false},
    {id:16,text:"I keep in the background.",t:'E',r:true},{id:17,text:"I sympathize with others' feelings.",t:'A',r:false},{id:18,text:"I make a mess of things.",t:'C',r:true},{id:19,text:"I seldom feel blue.",t:'N',r:true},{id:20,text:"I am not interested in abstract ideas.",t:'O',r:true},
    {id:21,text:"I start conversations.",t:'E',r:false},{id:22,text:"I am not interested in other people's problems.",t:'A',r:true},{id:23,text:"I get chores done right away.",t:'C',r:false},{id:24,text:"I am easily disturbed.",t:'N',r:false},{id:25,text:"I have excellent ideas.",t:'O',r:false},
    {id:26,text:"I have little to say.",t:'E',r:true},{id:27,text:"I have a soft heart.",t:'A',r:false},{id:28,text:"I often forget to put things back in their proper place.",t:'C',r:true},{id:29,text:"I am not easily bothered by things.",t:'N',r:true},{id:30,text:"I do not have a good imagination.",t:'O',r:true},
    {id:31,text:"I talk to a lot of different people at parties.",t:'E',r:false},{id:32,text:"I don't have a soft side.",t:'A',r:true},{id:33,text:"I like order.",t:'C',r:false},{id:34,text:"I get upset easily.",t:'N',r:false},{id:35,text:"I am quick to understand things.",t:'O',r:false},
    {id:36,text:"I don't like to draw attention to myself.",t:'E',r:true},{id:37,text:"I take time out for others.",t:'A',r:false},{id:38,text:"I shirk my duties.",t:'C',r:true},{id:39,text:"I don't get irritated easily.",t:'N',r:true},{id:40,text:"I avoid difficult reading material.",t:'O',r:true},
    {id:41,text:"I don't mind being the center of attention.",t:'E',r:false},{id:42,text:"I feel little concern for others.",t:'A',r:true},{id:43,text:"I follow a schedule.",t:'C',r:false},{id:44,text:"I change my mood a lot.",t:'N',r:false},{id:45,text:"I use difficult words.",t:'O',r:false},
    {id:46,text:"I am quiet around strangers.",t:'E',r:true},{id:47,text:"I feel others' emotions.",t:'A',r:false},{id:48,text:"I don't see things through.",t:'C',r:true},{id:49,text:"I rarely feel depressed.",t:'N',r:true},{id:50,text:"I have difficulty imagining things.",t:'O',r:true},
  ];
  function scoreBig5(ans){const s={E:0,A:0,C:0,N:0,O:0};for(const q of BIG5_Q){const r=ans[q.id];if(!r)continue;s[q.t]+=q.r?6-r:r;}const res={};for(const[t,raw]of Object.entries(s)){const d=t==='N'?60-raw:raw;const pct=Math.max(0,Math.min(100,Math.round((d-10)/40*100)));res[t]={raw,pct,level:pct>=65?'high':pct>=35?'medium':'low'};}return res;}

  // ─── SELF-ESTEEM (Rosenberg) ──────────────────────────
  const SE_Q=[{id:1,text:"On the whole, I am satisfied with myself.",r:false},{id:2,text:"At times I think I am no good at all.",r:true},{id:3,text:"I feel that I have a number of good qualities.",r:false},{id:4,text:"I am able to do things as well as most other people.",r:false},{id:5,text:"I feel I do not have much to be proud of.",r:true},{id:6,text:"I certainly feel useless at times.",r:true},{id:7,text:"I feel that I am a person of worth, at least on an equal plane with others.",r:false},{id:8,text:"I wish I could have more respect for myself.",r:true},{id:9,text:"All in all, I am inclined to feel that I am a failure.",r:true},{id:10,text:"I take a positive attitude toward myself.",r:false}];
  const SE_LABELS=[{v:1,s:"Strongly Disagree"},{v:2,s:"Disagree"},{v:3,s:"Agree"},{v:4,s:"Strongly Agree"}];
  function scoreSE(ans){let total=0;for(const q of SE_Q){const r=ans[q.id];if(!r)continue;total+=q.r?5-r:r;}const pct=Math.max(0,Math.min(100,Math.round((total-10)/30*100)));let level,label,desc;if(pct>=70){level='high';label='High Self-Esteem';desc='You have a strong, stable sense of your own worth. You approach challenges with confidence and recover well from setbacks. This is a significant asset in leadership and high-pressure roles.';}else if(pct>=45){level='medium';label='Moderate Self-Esteem';desc='You have a reasonably positive self-image with some areas of self-doubt. This is typical and healthy — you can build confidence further through experience and reflection.';}else{level='low';label='Low Self-Esteem';desc='You may struggle with self-doubt and negative self-evaluation. This can affect performance and relationships. Professional support or coaching can be very helpful.';}return{total,pct,level,label,desc};}

  // ─── EMOTIONAL INTELLIGENCE (SREIT) ──────────────────
  const EQ_TRAITS={PE:{name:'Perceiving Emotions',color:'#EC4899',bg:'#FCE7F3',high:'Excellent at reading emotional cues in yourself and others. You pick up on subtle moods and body language.',medium:'Reasonable emotional awareness with some blind spots.',low:'May miss emotional cues from others. Developing this skill can significantly improve relationships.'},MO:{name:'Managing Own Emotions',color:'#F97316',bg:'#FFEDD5',high:'You regulate your emotions effectively, staying composed under pressure and bouncing back from setbacks.',medium:'Generally manage emotions well, though high-pressure situations can be challenging.',low:'May find strong emotions hard to regulate. Mindfulness and stress management techniques can help.'},MO2:{name:"Managing Others' Emotions",color:'#14B8A6',bg:'#CCFBF1',high:'Skilled at helping others manage their emotional states. You naturally calm tense situations.',medium:'Can support others emotionally but may struggle in highly charged interpersonal situations.',low:"May find it difficult to navigate others' emotional states. Empathy training can be valuable."},UE:{name:'Utilizing Emotions',color:'#6366F1',bg:'#E0E7FF',high:'You harness emotions to motivate yourself and others, channelling feelings into productive action.',medium:'Sometimes use emotions constructively, with room to develop this further.',low:'Emotions may feel disruptive rather than useful. Learning to channel them can boost performance.'}};
  const EQ_Q=[{id:1,text:"I know when to speak about my personal problems to others.",t:'PE',r:false},{id:2,text:"When I am faced with obstacles, I remember times I faced similar obstacles and overcame them.",t:'MO',r:false},{id:3,text:"I expect that I will do well on most things I try.",t:'MO',r:false},{id:4,text:"Other people find it easy to confide in me.",t:'MO2',r:false},{id:5,text:"I find it hard to understand the non-verbal messages of other people.",t:'PE',r:true},{id:6,text:"Some of the major events of my life have led me to re-evaluate what is important and not important.",t:'UE',r:false},{id:7,text:"When my mood changes, I see new possibilities.",t:'UE',r:false},{id:8,text:"Emotions are one of the things that make my life worth living.",t:'UE',r:false},{id:9,text:"I am aware of my emotions as I experience them.",t:'PE',r:false},{id:10,text:"I expect good things to happen.",t:'MO',r:false},{id:11,text:"I like to share my emotions with others.",t:'MO2',r:false},{id:12,text:"When I experience a positive emotion, I know how to make it last.",t:'MO',r:false},{id:13,text:"I arrange events others enjoy.",t:'MO2',r:false},{id:14,text:"I seek out activities that make me happy.",t:'MO',r:false},{id:15,text:"I am aware of the non-verbal messages I send to others.",t:'PE',r:false},{id:16,text:"I present myself in a way that makes a good impression on others.",t:'MO2',r:false},{id:17,text:"When I am in a positive mood, solving problems is easy for me.",t:'UE',r:false},{id:18,text:"By looking at their facial expressions, I recognize the emotions people are experiencing.",t:'PE',r:false},{id:19,text:"I know why my emotions change.",t:'PE',r:false},{id:20,text:"When I am in a positive mood, I am able to come up with new ideas.",t:'UE',r:false},{id:21,text:"I have control over my emotions.",t:'MO',r:false},{id:22,text:"I easily recognize my emotions as I experience them.",t:'PE',r:false},{id:23,text:"I motivate myself by imagining a good outcome to tasks I take on.",t:'MO',r:false},{id:24,text:"I compliment others when they have done something well.",t:'MO2',r:false},{id:25,text:"I am aware of the non-verbal messages other people send.",t:'PE',r:false},{id:26,text:"When another person tells me about an important event in their life, I almost feel as though I experienced it myself.",t:'PE',r:false},{id:27,text:"When I feel a change in emotions, I tend to come up with new ideas.",t:'UE',r:false},{id:28,text:"When I am faced with a challenge, I give up because I believe I will fail.",t:'MO',r:true},{id:29,text:"I know what other people are feeling just by looking at them.",t:'PE',r:false},{id:30,text:"I help other people feel better when they are down.",t:'MO2',r:false},{id:31,text:"I use good moods to help myself keep trying in the face of obstacles.",t:'MO',r:false},{id:32,text:"I can tell how people are feeling by listening to the tone of their voice.",t:'PE',r:false},{id:33,text:"It is difficult for me to understand why people feel the way they do.",t:'PE',r:true}];
  const EQ_LABELS=[{v:1,s:"Not at all"},{v:2,s:"Somewhat"},{v:3,s:"Neutral"},{v:4,s:"Often"},{v:5,s:"Very much"}];
  function scoreEQ(ans){const sums={PE:0,MO:0,MO2:0,UE:0};const cnts={PE:0,MO:0,MO2:0,UE:0};for(const q of EQ_Q){const r=ans[q.id];if(!r)continue;sums[q.t]+=q.r?6-r:r;cnts[q.t]++;}const res={};for(const t of Object.keys(sums)){const avg=cnts[t]>0?sums[t]/cnts[t]:3;const pct=Math.round((avg-1)/4*100);res[t]={pct,level:pct>=65?'high':pct>=35?'medium':'low'};}const overall=Math.round(Object.values(res).reduce((a,b)=>a+b.pct,0)/4);return{...res,overall};}

  // ─── CORE TRAITS (IPIP 3-factor: Extraversion / Neuroticism / Conscientiousness) ───────────────────────
  const EYS_TRAITS={E:{name:'Extraversion',color:'#F59E0B',bg:'#FEF3C7',high:'You are outgoing, sociable, and energized by others.',medium:'Moderately social — comfortable in groups but also content alone.',low:'Reserved and introspective. You prefer calm environments.'},N:{name:'Neuroticism',color:'#EF4444',bg:'#FEE2E2',high:'You experience emotions strongly and may be prone to anxiety or mood shifts.',medium:'Emotionally typical — some stress sensitivity but generally stable.',low:'Emotionally stable, calm, and resilient under pressure.'},P:{name:'Conscientiousness',color:'#3B82F6',bg:'#DBEAFE',high:'Highly organized, disciplined, and thorough.',medium:'Reasonably organized and dependable.',low:'Flexible and spontaneous; may struggle with strict routines.'}};
  const EYS_Q=[{id:1,text:"I am the life of the party.",t:'E',r:false},{id:2,text:"I feel comfortable around people.",t:'E',r:false},{id:3,text:"I start conversations.",t:'E',r:false},{id:4,text:"I talk to a lot of different people at parties.",t:'E',r:false},{id:5,text:"I don't mind being the center of attention.",t:'E',r:false},{id:6,text:"I don't talk a lot.",t:'E',r:true},{id:7,text:"I keep in the background.",t:'E',r:true},{id:8,text:"I have little to say.",t:'E',r:true},{id:9,text:"I don't like to draw attention to myself.",t:'E',r:true},{id:10,text:"I am quiet around strangers.",t:'E',r:true},{id:11,text:"I get stressed out easily.",t:'N',r:false},{id:12,text:"I worry about things.",t:'N',r:false},{id:13,text:"I am easily disturbed.",t:'N',r:false},{id:14,text:"I get upset easily.",t:'N',r:false},{id:15,text:"I change my mood a lot.",t:'N',r:false},{id:16,text:"I am relaxed most of the time.",t:'N',r:true},{id:17,text:"I seldom feel blue.",t:'N',r:true},{id:18,text:"I am not easily bothered by things.",t:'N',r:true},{id:19,text:"I don't get irritated easily.",t:'N',r:true},{id:20,text:"I rarely feel depressed.",t:'N',r:true},{id:21,text:"I am always prepared.",t:'P',r:false},{id:22,text:"I pay attention to details.",t:'P',r:false},{id:23,text:"I get chores done right away.",t:'P',r:false},{id:24,text:"I like order.",t:'P',r:false},{id:25,text:"I follow a schedule.",t:'P',r:false},{id:26,text:"I leave my belongings around.",t:'P',r:true},{id:27,text:"I make a mess of things.",t:'P',r:true},{id:28,text:"I often forget to put things back in their proper place.",t:'P',r:true},{id:29,text:"I shirk my duties.",t:'P',r:true},{id:30,text:"I don't see things through.",t:'P',r:true}];
  const EYS_LABELS=[{v:1,s:"Very Inaccurate"},{v:2,s:"Mod. Inaccurate"},{v:3,s:"Neither"},{v:4,s:"Mod. Accurate"},{v:5,s:"Very Accurate"}];
  function scoreEYS(ans){const s={E:0,N:0,P:0};for(const q of EYS_Q){const r=ans[q.id];if(!r)continue;s[q.t]+=q.r?6-r:r;}const res={};for(const[t,raw]of Object.entries(s)){const pct=Math.max(0,Math.min(100,Math.round((raw-10)/40*100)));res[t]={raw,pct,level:pct>=65?'high':pct>=35?'medium':'low'};}return res;}

  // ─── LEADERSHIP STYLE (original) ─────────────────────
  const LS_TRAITS={DI:{name:'Directive Leadership',color:'#DC2626',bg:'#FEE2E2',high:'You lead with clear direction, decisive action, and high standards. You take charge and drive results.',medium:'You balance directing with listening. You give guidance but invite input.',low:'You tend to step back and let others lead. You prefer consensus over command.'},CO:{name:'Collaborative Leadership',color:'#059669',bg:'#D1FAE5',high:'You build strong teams, invest in people, and lead through relationships and shared ownership.',medium:'You value collaboration but balance it with decisiveness when needed.',low:'May prefer working independently. Team dynamics may feel slow or frustrating.'},ST:{name:'Strategic Thinking',color:'#7C3AED',bg:'#EDE9FE',high:'You think long-term, connect the dots across systems, and anticipate future challenges.',medium:'You balance day-to-day execution with some forward thinking.',low:'You prefer tangible, immediate tasks. Big-picture thinking may feel abstract.'},AD:{name:'Adaptability',color:'#0891B2',bg:'#CFFAFE',high:'You thrive in change, stay calm in uncertainty, and adjust your approach rapidly.',medium:'You handle moderate change well, with some discomfort in extreme uncertainty.',low:'You prefer stability and predictable environments. Frequent change can feel unsettling.'}};
  const LS_Q=[{id:1,text:"I make decisions quickly and confidently, even with limited information.",t:'DI',r:false},{id:2,text:"I clearly communicate expectations and hold people accountable.",t:'DI',r:false},{id:3,text:"I step in and take charge when a group lacks direction.",t:'DI',r:false},{id:4,text:"I set high standards and push others to meet them.",t:'DI',r:false},{id:5,text:"I prefer to be the one making the final call.",t:'DI',r:false},{id:6,text:"I prefer asking for consensus rather than deciding alone.",t:'DI',r:true},{id:7,text:"I invest significant time in developing the people around me.",t:'CO',r:false},{id:8,text:"I make sure every team member feels heard and valued.",t:'CO',r:false},{id:9,text:"I believe the best outcomes come from diverse perspectives.",t:'CO',r:false},{id:10,text:"I share credit freely and celebrate the team's success.",t:'CO',r:false},{id:11,text:"I prioritize team trust over short-term efficiency.",t:'CO',r:false},{id:12,text:"I am more focused on tasks than on relationships.",t:'CO',r:true},{id:13,text:"I regularly think about where my organization will be in 3–5 years.",t:'ST',r:false},{id:14,text:"I connect day-to-day decisions to long-term goals.",t:'ST',r:false},{id:15,text:"I identify risks and opportunities others often overlook.",t:'ST',r:false},{id:16,text:"I enjoy complex, ambiguous problems with no obvious solution.",t:'ST',r:false},{id:17,text:"I think about industry trends and how they affect my work.",t:'ST',r:false},{id:18,text:"I find abstract planning less useful than practical action.",t:'ST',r:true},{id:19,text:"I adjust my leadership style based on the situation.",t:'AD',r:false},{id:20,text:"I stay calm and focused when plans suddenly change.",t:'AD',r:false}];
  const LS_LABELS=[{v:1,s:"Never"},{v:2,s:"Rarely"},{v:3,s:"Sometimes"},{v:4,s:"Often"},{v:5,s:"Always"}];
  function scoreLS(ans){const s={DI:0,CO:0,ST:0,AD:0};const c={DI:0,CO:0,ST:0,AD:0};for(const q of LS_Q){const r=ans[q.id];if(!r)continue;s[q.t]+=q.r?6-r:r;c[q.t]++;}const res={};for(const t of Object.keys(s)){const avg=c[t]>0?s[t]/c[t]:3;const pct=Math.max(0,Math.min(100,Math.round((avg-1)/4*100)));res[t]={pct,level:pct>=65?'high':pct>=35?'medium':'low'};}return res;}

  // ─── TEST CATALOGUE ───────────────────────────────────
  const TESTS=[
    {id:'big5',title:'Big Five Personality',subtitle:'IPIP-50 · 50 questions · ~10 min',icon:'🧠',color:'#7C3AED',desc:'The most widely used personality framework. Measures 5 core traits that predict workplace behavior, team dynamics, and career fit.',questions:BIG5_Q,labels:[{v:1,s:"Very Inaccurate"},{v:2,s:"Mod. Inaccurate"},{v:3,s:"Neither"},{v:4,s:"Mod. Accurate"},{v:5,s:"Very Accurate"}],score:scoreBig5,resultType:'big5',traits:BIG5_TRAITS,traitOrder:['E','A','C','N','O'],tagline:'Personality'},
    {id:'eq',title:'Emotional Intelligence',subtitle:'SREIT · 33 questions · ~8 min',icon:'❤️',color:'#EC4899',desc:'Measures your ability to perceive, manage, and use emotions effectively — a key predictor of leadership success and team cohesion.',questions:EQ_Q,labels:EQ_LABELS,score:scoreEQ,resultType:'eq',traits:EQ_TRAITS,traitOrder:['PE','MO','MO2','UE'],tagline:'Emotional Intelligence'},
    {id:'eysenck',title:'Core Traits Snapshot',subtitle:'IPIP · 30 questions · ~7 min',icon:'⚡',color:'#D97706',desc:'A focused 3-factor personality model measuring Extraversion, Neuroticism (emotional stability), and Conscientiousness.',questions:EYS_Q,labels:EYS_LABELS,score:scoreEYS,resultType:'standard',traits:EYS_TRAITS,traitOrder:['E','N','P'],tagline:'Personality'},
    {id:'selfesteem',title:'Self-Esteem',subtitle:'Rosenberg Scale · 10 questions · ~3 min',icon:'🌟',color:'#0891B2',desc:'The gold standard for self-esteem measurement. Used in clinical, educational, and HR contexts worldwide.',questions:SE_Q,labels:SE_LABELS,score:scoreSE,resultType:'selfesteem',tagline:'Self & Wellbeing'},
    {id:'leadership',title:'Leadership Style',subtitle:'Original · 20 questions · ~5 min',icon:'🎯',color:'#059669',desc:'Identifies your dominant leadership orientation across 4 dimensions: Directive, Collaborative, Strategic, and Adaptive.',questions:LS_Q,labels:LS_LABELS,score:scoreLS,resultType:'standard',traits:LS_TRAITS,traitOrder:['DI','CO','ST','AD'],tagline:'Leadership'},
  ];

  // ─── SHARED COMPONENTS ────────────────────────────────
  function ProgressHeader({title,current,total,onBack}){
    const pct=Math.round(current/total*100);
    return h('div',{className:'bg-white border-b border-gray-100 px-4 py-3 sticky top-0 z-10'},
      h('div',{className:'max-w-2xl mx-auto'},
        h('div',{className:'flex items-center justify-between mb-2'},
          h('button',{onClick:onBack,className:'text-gray-400 hover:text-navy text-sm font-medium focus:outline-none transition-colors'},'← Back'),
          h('span',{className:'text-navy font-semibold text-sm truncate mx-4'},title),
          h('span',{className:'text-gray-400 text-xs font-medium whitespace-nowrap'},current+'/'+total)
        ),
        h('div',{className:'w-full bg-gray-100 rounded-full h-1.5'},
          h('div',{className:'bg-gold h-1.5 rounded-full transition-all duration-500',style:{width:pct+'%'}})
        )
      )
    );
  }

  function QuestionCard({question,answers,labels,onPick,onBack,current,total,testTitle}){
    const picked=answers[question.id];
    return h('div',{className:'bg-gray-50 flex flex-col'},
      h(ProgressHeader,{title:testTitle,current,total,onBack}),
      h('div',{className:'flex flex-col items-center justify-center px-4 py-8'},
        h('div',{className:'max-w-2xl w-full fade-in'},
          h('p',{className:'text-gray-400 text-xs font-semibold uppercase tracking-wider text-center mb-4'},'Question '+current),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-5 text-center'},
            h('p',{className:'text-navy text-xl font-semibold leading-snug'},'"'+question.text+'"')
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-5'},
            h('p',{className:'text-gray-400 text-xs font-medium text-center mb-4'},'Select the most accurate response'),
            h('div',{className:'flex flex-col sm:flex-row gap-2'},
              labels.map(function(opt){
                return h('button',{key:opt.v,onClick:function(){onPick(opt.v);},className:'flex-1 py-3 px-2 rounded-xl border-2 text-xs font-semibold text-center transition-all focus:outline-none '+(picked===opt.v?'border-gold bg-amber-50 text-navy':'border-gray-200 text-gray-500 hover:border-yellow-300')},opt.s);
              })
            )
          ),
          h('div',{className:'flex justify-start mt-4'},
            h('button',{onClick:onBack,disabled:current<=1,className:'text-gray-400 text-sm font-medium disabled:opacity-30 focus:outline-none'},'← Previous')
          )
        )
      )
    );
  }

  function TraitBar({name,pct,level,color,bg,interpretation}){
    return h('div',{className:'mb-7'},
      h('div',{className:'flex items-center justify-between mb-1.5'},
        h('div',{className:'flex items-center gap-2'},
          h('span',{className:'w-2.5 h-2.5 rounded-full',style:{background:color}}),
          h('span',{className:'font-semibold text-navy text-sm'},name),
          h('span',{className:'text-xs font-semibold px-2 py-0.5 rounded-full',style:{background:bg,color:color}},level==='high'?'High':level==='low'?'Low':'Medium')
        ),
        h('span',{className:'text-gray-400 text-sm font-semibold'},pct+'%')
      ),
      h('div',{className:'w-full bg-gray-100 rounded-full h-2.5 mb-1'},
        h('div',{className:'bar-fill h-2.5 rounded-full',style:{width:pct+'%',background:color}})
      ),
      h('div',{className:'flex justify-between text-gray-300 text-xs mb-2'},h('span',null,'Low'),h('span',null,'High')),
      h('p',{className:'text-gray-600 text-sm leading-relaxed bg-gray-50 rounded-xl px-4 py-3'},interpretation)
    );
  }

  function ResultActions({onRetake,onHome,title}){
    return h('div',{className:'bg-white border-b border-gray-100 px-4 py-4 no-print'},
      h('div',{className:'max-w-2xl mx-auto flex items-center justify-between'},
        h('span',{className:'text-navy font-bold text-sm'},title),
        h('div',{className:'flex items-center gap-2'},
          h('button',{onClick:function(){window.print();},className:'text-gray-500 text-xs font-medium focus:outline-none'},'🖨 Print'),
          h('button',{onClick:onRetake,className:'border border-gray-300 text-gray-600 text-xs font-medium px-3 py-1.5 rounded-lg focus:outline-none'},'Retake'),
          h('button',{onClick:onHome,className:'bg-navy text-white text-xs font-medium px-3 py-1.5 rounded-lg focus:outline-none no-print'},'All Tests')
        )
      )
    );
  }

  function ResultsWrapper({test,scores,onRetake,onHome}){
    const ORDER=test.traitOrder||[];
    const backBtn=h('div',{className:'mt-6 bg-navy rounded-2xl p-5 text-center no-print'},
      h('button',{onClick:onHome,className:'bg-gold text-navy font-bold text-sm px-6 py-2 rounded-lg'},'← Back to Tests')
    );

    if(test.resultType==='selfesteem'){
      const{pct,label,desc}=scores;
      const color=pct>=70?'#10B981':pct>=45?'#F59E0B':'#EF4444';
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:'Self-Esteem'}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold mb-1'},'Self-Esteem Results'),h('p',{className:'text-gray-400 text-sm'},'Rosenberg Self-Esteem Scale')),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6 text-center'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},'Your Score'),
            h('p',{className:'text-5xl font-bold mb-1'},pct),
            h('p',{className:'text-sm mb-3',style:{color:'rgba(138,155,176,0.7)'}},'out of 100'),
            h('span',{className:'inline-block text-sm font-semibold px-4 py-1.5 rounded-full',style:{background:color+'33',color:color}},label)
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('div',{className:'w-full bg-gray-100 rounded-full h-4 mb-4'},h('div',{className:'bar-fill h-4 rounded-full',style:{width:pct+'%',background:color}})),
            h('p',{className:'text-gray-600 text-sm leading-relaxed'},desc)
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},'Based on the Rosenberg Self-Esteem Scale (public domain). For informational purposes only.'),
          backBtn
        )
      );
    }

    if(test.resultType==='eq'){
      const{overall,...traitScores}=scores;
      const oc=overall>=65?'#10B981':overall>=35?'#F59E0B':'#EF4444';
      const ol=overall>=65?'High EQ':overall>=35?'Moderate EQ':'Developing EQ';
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:'Emotional Intelligence'}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},'Emotional Intelligence Results')),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6 text-center'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},'Overall EQ Score'),
            h('p',{className:'text-5xl font-bold mb-1'},overall),
            h('p',{className:'text-sm mb-2',style:{color:'rgba(138,155,176,0.7)'}},'out of 100'),
            h('span',{className:'inline-block text-sm font-semibold px-4 py-1.5 rounded-full',style:{background:oc+'33',color:oc}},ol)
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('h2',{className:'text-navy font-semibold text-sm mb-5'},'EQ Breakdown'),
            ORDER.map(function(k){const t=test.traits[k];const s=traitScores[k];if(!t||!s)return null;return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},'Based on the Schutte Self-Report Emotional Intelligence Test. For informational purposes only.'),
          backBtn
        )
      );
    }

    if(test.resultType==='big5'){
      const pMap={E:'sociable',A:'agreeable',C:'organized',N:'calm & resilient',O:'curious'};
      const topTwo=ORDER.map(function(k){return[k,scores[k]];}).sort(function(a,b){return b[1].pct-a[1].pct;}).slice(0,2);
      const profileDesc=topTwo.map(function(x){return pMap[x[0]];}).join(' and ');
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:'Big Five Personality'}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},'Big Five Personality Results')),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},'Your Profile'),
            h('p',{className:'font-semibold'},'You are most strongly characterized as ',h('span',{className:'text-gold'},profileDesc),'.')
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4'},
            h('h2',{className:'text-navy font-semibold text-sm mb-4'},'Score Overview'),
            ORDER.map(function(k){const t=test.traits[k];const s=scores[k];return h('div',{key:k,className:'flex items-center gap-3 mb-3'},h('span',{className:'text-gray-500 text-xs w-36 flex-shrink-0'},t.name),h('div',{className:'flex-1 bg-gray-100 rounded-full h-2'},h('div',{className:'bar-fill h-2 rounded-full',style:{width:s.pct+'%',background:t.color}})),h('span',{className:'text-gray-400 text-xs font-semibold w-8 text-right'},s.pct+'%'));})
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('h2',{className:'text-navy font-semibold text-sm mb-6'},'Detailed Results'),
            ORDER.map(function(k){const t=test.traits[k];const s=scores[k];return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},'Based on the IPIP-50 (public domain). For informational purposes only.'),
          backBtn
        )
      );
    }

    // Generic (Core Traits, Leadership)
    return h('div',{className:'bg-gray-50'},
      h(ResultActions,{onRetake,onHome,title:test.title}),
      h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
        h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},test.title+' Results')),
        h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4'},
          h('h2',{className:'text-navy font-semibold text-sm mb-5'},'Your Scores'),
          ORDER.map(function(k){const t=test.traits[k];const s=scores[k];if(!t||!s)return null;return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
        ),
        h('p',{className:'text-gray-400 text-xs text-center mb-4'},'For informational purposes only.'),
        backBtn
      )
    );
  }

  function SurveyRunner({test,onComplete,onBack}){
    const[idx,setIdx]=useState(0);
    const[answers,setAns]=useState({});
    const qs=test.questions;
    const q=qs[idx];
    function pick(v){
      const next=Object.assign({},answers);next[q.id]=v;setAns(next);
      setTimeout(function(){if(idx<qs.length-1)setIdx(function(i){return i+1;});else onComplete(next);},280);
    }
    return h(QuestionCard,{question:q,answers,labels:test.labels,onPick:pick,onBack:function(){idx>0?setIdx(function(i){return i-1;}):onBack();},current:idx+1,total:qs.length,testTitle:test.title});
  }

  function Home({onSelectTest}){
    const tagColors={'Personality':'bg-violet-100 text-violet-700','Emotional Intelligence':'bg-pink-100 text-pink-700','Self & Wellbeing':'bg-sky-100 text-sky-700','Leadership':'bg-emerald-100 text-emerald-700'};
    return h('div',{className:'bg-gray-50'},
      h('div',{className:'bg-navy px-6 py-10 text-center'},
        h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-3'},'HR Assessments'),
        h('h1',{className:'text-white text-3xl font-bold mb-3'},'Workplace Assessments'),
        h('p',{className:'text-silver/80 text-base max-w-xl mx-auto'},'Science-based personality and HR assessments. Free, instant results. Choose a test to begin.')
      ),
      h('div',{className:'max-w-2xl mx-auto px-4 pt-8 pb-16'},
        h('p',{className:'text-gray-400 text-xs font-semibold uppercase tracking-widest mb-4 text-center'},TESTS.length+' Assessments Available'),
        h('div',{className:'space-y-4'},
          TESTS.map(function(test){
            return h('div',{key:test.id,onClick:function(){onSelectTest(test.id);},className:'card-hover bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 shadow-sm'},
              h('div',{className:'w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0',style:{background:'linear-gradient(135deg,'+test.color+'22,'+test.color+'44)'}},test.icon),
              h('div',{className:'flex-1 min-w-0'},
                h('div',{className:'flex items-start justify-between gap-2 mb-1'},
                  h('h3',{className:'text-navy font-bold text-base leading-tight'},test.title),
                  h('span',{className:'text-xs font-semibold px-2 py-0.5 rounded-full flex-shrink-0 '+(tagColors[test.tagline]||'bg-gray-100 text-gray-600')},test.tagline)
                ),
                h('p',{className:'text-gray-400 text-xs mb-2'},test.subtitle),
                h('p',{className:'text-gray-600 text-sm leading-relaxed'},test.desc)
              ),
              h('div',{className:'text-gray-300 text-xl flex-shrink-0 self-center'},'›')
            );
          })
        )
      )
    );
  }

  function App(){
    const[screen,setScreen]=useState('home');
    const[activeId,setActive]=useState(null);
    const[scores,setScores]=useState(null);
    const test=TESTS.find(function(t){return t.id===activeId;});
    function selectTest(id){setActive(id);setScreen('survey');window.scrollTo(0,0);}
    function handleComplete(ans){setScores(test.score(ans));setScreen('results');window.scrollTo(0,0);}
    function goHome(){setScreen('home');setActive(null);setScores(null);window.scrollTo(0,0);}
    if(screen==='home') return h(Home,{onSelectTest:selectTest});
    if(screen==='survey') return h(SurveyRunner,{test,onComplete:handleComplete,onBack:goHome});
    if(screen==='results') return h(ResultsWrapper,{test,scores,onRetake:function(){selectTest(activeId);},onHome:goHome});
  }

  ReactDOM.createRoot(document.getElementById('root')).render(h(App));
  })();
  </script>

