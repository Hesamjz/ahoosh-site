---
// Shared assess mini-app body. The React/Tailwind CDN scripts must be added
// by each page wrapper via <Fragment slot="head"> (see AssessHead).
// Locale-aware: pass `lang` (en/de/fa/sr). All questions, labels, traits,
// interpretations and UI strings are translated. Scoring/keying is
// language-agnostic (BIG5_META / SE_META), so every locale scores identically.
interface Props { banner?: string; lang?: string; assessMode?: boolean }
const { banner, lang = 'en', assessMode = false } = Astro.props;
---

{banner && (
  <div style="background:rgba(215,161,61,0.1);border-bottom:1px solid rgba(215,161,61,0.25);padding:12px 24px;text-align:center;font-size:13px;color:#D7A13D;">
    {banner}
  </div>
)}


  <style is:global>
    @media print { .no-print { display:none!important; } }
    .bar-fill { transition: width .7s ease; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }
    .fade-in { animation: fadeIn .3s ease both; }
    .card-hover { transition: all .2s; cursor: pointer; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,.5); }

    /* ── Dark theme overrides for assess page ── */
    #root { background: #060F1E; min-height: 60vh; }
    #root .bg-gray-50  { background: #060F1E !important; }
    #root .bg-white    { background: rgba(8,22,50,0.95) !important; }

    /* Card borders */
    #root .border-gray-100 { border-color: rgba(215,161,61,0.15) !important; }
    #root .border-gray-200 { border-color: rgba(215,161,61,0.18) !important; }
    #root .border-b        { border-bottom-color: rgba(215,161,61,0.12) !important; }

    /* Text */
    #root .text-navy   { color: #e8eaf0 !important; }
    #root .text-gray-600 { color: #8a9bb0 !important; }
    #root .text-gray-500 { color: #7a8b9e !important; }
    #root .text-gray-400 { color: #5e6e82 !important; }
    #root .text-gray-300 { color: #3a4a5c !important; }

    /* Progress bar track */
    #root .bg-gray-100 { background: rgba(255,255,255,0.08) !important; }

    /* Selected Likert button */
    #root .bg-amber-50 { background: rgba(215,161,61,0.15) !important; }

    /* Shadows */
    #root .shadow-sm { box-shadow: 0 2px 12px rgba(0,0,0,0.5) !important; }

    /* Tag badges */
    #root .bg-violet-100 { background: rgba(124,58,237,0.18) !important; }
    #root .text-violet-700 { color: #a78bfa !important; }
    #root .bg-pink-100 { background: rgba(236,72,153,0.18) !important; }
    #root .text-pink-700 { color: #f472b6 !important; }
    #root .bg-sky-100 { background: rgba(14,165,233,0.18) !important; }
    #root .text-sky-700 { color: #38bdf8 !important; }
    #root .bg-emerald-100 { background: rgba(16,185,129,0.18) !important; }
    #root .text-emerald-700 { color: #34d399 !important; }
    #root .bg-gray-100.rounded-full { background: rgba(255,255,255,0.08) !important; color: #8a9bb0 !important; }

    /* Sticky question header */
    #root .sticky { background: rgba(6,15,30,0.97) !important; backdrop-filter: blur(8px); }

    /* ── Business Tools Section ── */
    .biz-tools-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.5rem 0;
    }
    .biz-tools-header { text-align: center; margin-bottom: 2rem; }
    .biz-tools-eyebrow {
      display: inline-block;
      background: rgba(215,161,61,0.12);
      color: #D7A13D;
      border: 1px solid rgba(215,161,61,0.25);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      margin-bottom: 0.75rem;
    }
    .biz-tools-title {
      font-size: clamp(1.4rem, 3.5vw, 1.9rem);
      color: #e8eaf0;
      margin: 0 0 0.5rem;
      font-weight: 700;
    }
    .biz-tools-sub { color: #8a9bb0; font-size: 0.95rem; margin: 0; }
    .biz-tools-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media (max-width: 640px) { .biz-tools-grid { grid-template-columns: 1fr; } }
    .biz-tool-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background: rgba(8,22,50,0.95);
      border: 1px solid rgba(215,161,61,0.18);
      border-radius: 16px;
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
      position: relative;
    }
    .biz-tool-card:hover {
      border-color: rgba(215,161,61,0.5);
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.5);
    }
    .btc-icon {
      width: 44px; height: 44px;
      background: rgba(215,161,61,0.12);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: #D7A13D;
      flex-shrink: 0;
    }
    .btc-icon svg { width: 22px; height: 22px; }
    .btc-icon-ai { background: rgba(167,139,250,0.12); color: #a78bfa; }
    .btc-badge {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #D7A13D;
      margin-bottom: 0.4rem;
    }
    .btc-badge-ai { color: #a78bfa; }
    .btc-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #e8eaf0;
      margin: 0 0 0.5rem;
    }
    .btc-desc {
      font-size: 0.87rem;
      color: #8a9bb0;
      line-height: 1.6;
      margin: 0 0 0.75rem;
    }
    .btc-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }
    .btc-tags span {
      font-size: 0.68rem;
      background: rgba(255,255,255,0.06);
      color: #8a9bb0;
      border-radius: 4px;
      padding: 0.2rem 0.5rem;
      font-weight: 500;
    }
    .btc-arrow {
      position: absolute;
      top: 1.25rem; right: 1.25rem;
      color: rgba(215,161,61,0.4);
      font-size: 1.2rem;
      transition: color 0.2s, transform 0.2s;
    }
    .biz-tool-card:hover .btc-arrow { color: #D7A13D; transform: translateX(4px); }

    .assess-divider {
      text-align: center;
      margin: 2.5rem auto 0;
      max-width: 900px;
      padding: 0 1.5rem;
      position: relative;
    }
    .assess-divider::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 1.5rem; right: 1.5rem;
      border-top: 1px solid rgba(215,161,61,0.12);
    }
    .assess-divider span {
      position: relative;
      background: #060F1E;
      padding: 0 1rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #5e6e82;
    }
  </style>

  {!assessMode && (
    <>
      <!-- ── Business Tools Section ── -->
      <div class="biz-tools-section">
        <div class="biz-tools-header">
          <span class="biz-tools-eyebrow">Business Tools</span>
          <h2 class="biz-tools-title">Analyze Your Business — Free</h2>
          <p class="biz-tools-sub">Instant, AI-powered insights. No signup required.</p>
        </div>
        <div class="biz-tools-grid">
          <a href="/tools/seo-audit" class="biz-tool-card">
            <div class="btc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
              </svg>
            </div>
            <div class="btc-content">
              <div class="btc-badge">Powered by Google Lighthouse</div>
              <h3 class="btc-title">SEO &amp; Performance Audit</h3>
              <p class="btc-desc">Paste your URL — get performance scores, Core Web Vitals, SEO gaps, and the top issues holding your site back. Takes ~15 seconds.</p>
              <div class="btc-tags">
                <span>Performance Score</span>
                <span>Core Web Vitals</span>
                <span>SEO Issues</span>
                <span>Accessibility</span>
              </div>
            </div>
            <div class="btc-arrow">→</div>
          </a>

          <a href="/tools/business-qa" class="biz-tool-card">
            <div class="btc-icon btc-icon-ai">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
              </svg>
            </div>
            <div class="btc-content">
              <div class="btc-badge btc-badge-ai">Powered by Claude AI</div>
              <h3 class="btc-title">Business Diagnostic</h3>
              <p class="btc-desc">Answer 10 questions about your business. Get an honest AI analysis: real strengths, critical challenges, quick wins, and your 90-day focus.</p>
              <div class="btc-tags">
                <span>Strengths &amp; Challenges</span>
                <span>Quick Wins</span>
                <span>90-Day Priority</span>
                <span>Strategy</span>
              </div>
            </div>
            <div class="btc-arrow">→</div>
          </a>
        </div>
      </div>

      <div class="assess-divider">
        <span>Personal &amp; HR Assessments</span>
      </div>
    </>
  )}

  <div id="root" class="antialiased" data-lang={lang} data-hub={assessMode ? '1' : '0'}></div>

  <script is:inline>
  (function(){
  const {useState} = React;
  const h = React.createElement;
  const LANG = (document.getElementById('root').dataset.lang) || 'en';
  const RTL = LANG === 'fa';
  const ASSESS_HUB = document.getElementById('root').dataset.hub === '1';

  // ─── LANGUAGE-AGNOSTIC METADATA (drives scoring; never translated) ───
  // Big Five (IPIP-50): {id, t∈E/A/C/N/O, r=reverse-key}
  const BIG5_META=[
    {id:1,t:'E',r:false},{id:2,t:'A',r:true},{id:3,t:'C',r:false},{id:4,t:'N',r:false},{id:5,t:'O',r:false},
    {id:6,t:'E',r:true},{id:7,t:'A',r:false},{id:8,t:'C',r:true},{id:9,t:'N',r:true},{id:10,t:'O',r:true},
    {id:11,t:'E',r:false},{id:12,t:'A',r:true},{id:13,t:'C',r:false},{id:14,t:'N',r:false},{id:15,t:'O',r:false},
    {id:16,t:'E',r:true},{id:17,t:'A',r:false},{id:18,t:'C',r:true},{id:19,t:'N',r:true},{id:20,t:'O',r:true},
    {id:21,t:'E',r:false},{id:22,t:'A',r:true},{id:23,t:'C',r:false},{id:24,t:'N',r:false},{id:25,t:'O',r:false},
    {id:26,t:'E',r:true},{id:27,t:'A',r:false},{id:28,t:'C',r:true},{id:29,t:'N',r:true},{id:30,t:'O',r:true},
    {id:31,t:'E',r:false},{id:32,t:'A',r:true},{id:33,t:'C',r:false},{id:34,t:'N',r:false},{id:35,t:'O',r:false},
    {id:36,t:'E',r:true},{id:37,t:'A',r:false},{id:38,t:'C',r:true},{id:39,t:'N',r:true},{id:40,t:'O',r:true},
    {id:41,t:'E',r:false},{id:42,t:'A',r:true},{id:43,t:'C',r:false},{id:44,t:'N',r:false},{id:45,t:'O',r:false},
    {id:46,t:'E',r:true},{id:47,t:'A',r:false},{id:48,t:'C',r:true},{id:49,t:'N',r:true},{id:50,t:'O',r:true},
  ];
  // Rosenberg Self-Esteem: {id, r=reverse-key}
  const SE_META=[{id:1,r:false},{id:2,r:true},{id:3,r:false},{id:4,r:false},{id:5,r:true},{id:6,r:true},{id:7,r:false},{id:8,r:true},{id:9,r:true},{id:10,r:false}];

  // ─── TRAIT STYLING (language-agnostic; keyed by trait letter) ───
  const TRAIT_STYLE={
    E:{color:'#F59E0B',bg:'#FEF3C7'},
    A:{color:'#10B981',bg:'#D1FAE5'},
    C:{color:'#3B82F6',bg:'#DBEAFE'},
    N:{color:'#EF4444',bg:'#FEE2E2'},
    O:{color:'#8B5CF6',bg:'#EDE9FE'},
  };
  const DISC_STYLE={D:{color:'#EF4444',bg:'#FEE2E2'},I:{color:'#F59E0B',bg:'#FEF3C7'},S:{color:'#10B981',bg:'#D1FAE5'},C:{color:'#3B82F6',bg:'#DBEAFE'}};
  const GDMS_STYLE={R:{color:'#3B82F6',bg:'#DBEAFE'},I:{color:'#8B5CF6',bg:'#EDE9FE'},D:{color:'#10B981',bg:'#D1FAE5'},A:{color:'#EF4444',bg:'#FEE2E2'},S:{color:'#F59E0B',bg:'#FEF3C7'}};

  // ─── SCORING (reads keying from META; identical math across locales) ───
  function scoreBig5(ans){const s={E:0,A:0,C:0,N:0,O:0};for(const q of BIG5_META){const r=ans[q.id];if(!r)continue;s[q.t]+=q.r?6-r:r;}const res={};for(const[t,raw]of Object.entries(s)){const d=t==='N'?60-raw:raw;const pct=Math.max(0,Math.min(100,Math.round((d-10)/40*100)));res[t]={raw,pct,level:pct>=65?'high':pct>=35?'medium':'low'};}return res;}
  function scoreSE(ans){let total=0;for(const q of SE_META){const r=ans[q.id];if(!r)continue;total+=q.r?5-r:r;}const pct=Math.max(0,Math.min(100,Math.round((total-10)/30*100)));let level;if(pct>=70)level='high';else if(pct>=45)level='medium';else level='low';return{total,pct,level};}
  // Self-Efficacy (GSE): 10 items, all positively keyed, 4-point scale, sum 10-40
  const SELFEFF_META=[{id:1,r:false},{id:2,r:false},{id:3,r:false},{id:4,r:false},{id:5,r:false},{id:6,r:false},{id:7,r:false},{id:8,r:false},{id:9,r:false},{id:10,r:false}];
  function scoreSelfEff(ans){let total=0;for(const q of SELFEFF_META){const r=ans[q.id];if(!r)continue;total+=q.r?5-r:r;}const pct=Math.max(0,Math.min(100,Math.round((total-10)/30*100)));let level;if(pct>=70)level='high';else if(pct>=45)level='medium';else level='low';return{total,pct,level};}
  // Optimism (LOT-R): 5-point scale (v1-5 → 0-4); items 2,5,6,8 are fillers (f) and not scored; 3,7,9 reverse-keyed
  const LOT_META=[{id:1,r:false,f:false},{id:2,f:true},{id:3,r:true,f:false},{id:4,r:false,f:false},{id:5,f:true},{id:6,f:true},{id:7,r:true,f:false},{id:8,f:true},{id:9,r:true,f:false},{id:10,r:false,f:false}];
  function scoreOptimism(ans){let total=0;for(const q of LOT_META){if(q.f)continue;const v=ans[q.id];if(!v)continue;const s=v-1;total+=q.r?4-s:s;}const pct=Math.max(0,Math.min(100,Math.round(total/24*100)));let level;if(pct>=67)level='high';else if(pct>=34)level='medium';else level='low';return{total,pct,level};}
  // DISC: 24 items, 4 dims (D/I/S/C), 5-pt Likert, all positively keyed
  const DISC_META=[
    {id:1,dim:'D'},{id:2,dim:'D'},{id:3,dim:'D'},{id:4,dim:'D'},{id:5,dim:'D'},{id:6,dim:'D'},
    {id:7,dim:'I'},{id:8,dim:'I'},{id:9,dim:'I'},{id:10,dim:'I'},{id:11,dim:'I'},{id:12,dim:'I'},
    {id:13,dim:'S'},{id:14,dim:'S'},{id:15,dim:'S'},{id:16,dim:'S'},{id:17,dim:'S'},{id:18,dim:'S'},
    {id:19,dim:'C'},{id:20,dim:'C'},{id:21,dim:'C'},{id:22,dim:'C'},{id:23,dim:'C'},{id:24,dim:'C'},
  ];
  function scoreDisc(ans){const s={D:0,I:0,S:0,C:0};for(const q of DISC_META){const r=ans[q.id];if(!r)continue;s[q.dim]+=r;}const res={};for(const[dim,raw]of Object.entries(s)){const pct=Math.max(0,Math.min(100,Math.round((raw-6)/24*100)));res[dim]={raw,pct,level:pct>=65?'high':pct>=35?'medium':'low'};}return res;}
  // GDMS: 25 items, 5 styles (R/I/D/A/S), 5-pt Likert, all positively keyed
  const GDMS_META=[
    {id:1,dim:'R'},{id:2,dim:'R'},{id:3,dim:'R'},{id:4,dim:'R'},{id:5,dim:'R'},
    {id:6,dim:'I'},{id:7,dim:'I'},{id:8,dim:'I'},{id:9,dim:'I'},{id:10,dim:'I'},
    {id:11,dim:'D'},{id:12,dim:'D'},{id:13,dim:'D'},{id:14,dim:'D'},{id:15,dim:'D'},
    {id:16,dim:'A'},{id:17,dim:'A'},{id:18,dim:'A'},{id:19,dim:'A'},{id:20,dim:'A'},
    {id:21,dim:'S'},{id:22,dim:'S'},{id:23,dim:'S'},{id:24,dim:'S'},{id:25,dim:'S'},
  ];
  function scoreGdms(ans){const s={R:0,I:0,D:0,A:0,S:0};for(const q of GDMS_META){const r=ans[q.id];if(!r)continue;s[q.dim]+=r;}const res={};for(const[dim,raw]of Object.entries(s)){const pct=Math.max(0,Math.min(100,Math.round((raw-5)/20*100)));res[dim]={raw,pct,level:pct>=65?'high':pct>=35?'medium':'low'};}return res;}

  // ─── TRANSLATABLE CONTENT ─────────────────────────────
  const DATA={
    en:{
      ui:{
        kicker:'HR Assessments',heroTitle:'Workplace Assessments',
        heroSubtitle:'Science-based personality and HR assessments. Free, instant results. Choose a test to begin.',
        available:'Assessments Available',back:'← Back',previous:'← Previous',question:'Question',
        selectPrompt:'Select the most accurate response',print:'🖨 Print',retake:'Retake',allTests:'All Tests',
        backToTests:'← Back to Tests',resultsSuffix:' Results',yourScore:'Your Score',outOf:'out of 100',
        yourProfile:'Your Profile',characterizedAs:'You are most strongly characterized as ',
        scoreOverview:'Score Overview',detailedResults:'Detailed Results',yourScores:'Your Scores',
        high:'High',medium:'Medium',low:'Low',axisLow:'Low',axisHigh:'High',
        tagPersonality:'Personality',tagSelf:'Self & Wellbeing',forInfoOnly:'For informational purposes only.',
      },
      tags:{Personality:'bg-violet-100 text-violet-700','Self & Wellbeing':'bg-sky-100 text-sky-700'},
      big5:{
        title:'Big Five Personality',subtitle:'IPIP-50 · 50 questions · ~10 min',
        desc:'The most widely used personality framework. Measures 5 core traits that predict workplace behavior, team dynamics, and career fit.',
        tagline:'Personality',footer:'Based on the IPIP-50 (public domain). For informational purposes only.',
        labels:["Very Inaccurate","Mod. Inaccurate","Neither","Mod. Accurate","Very Accurate"],
        profile:{E:'sociable',A:'agreeable',C:'organized',N:'calm & resilient',O:'curious'},
        traits:{
          E:{name:'Extraversion',high:'You are energized by social situations, enjoy being around people, and tend to be outgoing. You feel comfortable in group settings.',medium:'You balance social engagement with alone time. You can be outgoing when needed but also appreciate quieter moments.',low:'You tend to be reserved and prefer smaller groups. You recharge alone — a strength in roles requiring deep focus.'},
          A:{name:'Agreeableness',high:'You are warm, cooperative, and considerate. You value harmony and excel in team environments requiring empathy.',medium:'You balance cooperation with assertiveness. Compassionate when needed, but you hold your ground.',low:'You are direct and results-focused. Comfortable with conflict — a strength in negotiation and leadership.'},
          C:{name:'Conscientiousness',high:'You are highly organized, reliable, and goal-driven. You plan ahead and follow through. You excel in structured environments.',medium:'Reasonably organized. Diligent when motivated, though you may prefer some flexibility.',low:'Flexible and spontaneous. You adapt as things unfold and may thrive in dynamic environments.'},
          N:{name:'Emotional Stability',high:'You remain calm under pressure, recover quickly from setbacks, and maintain balance in stressful situations.',medium:'You experience typical emotional ups and downs and handle most stress reasonably well.',low:'You experience emotions intensely. This sensitivity can be a strength in empathy-requiring roles.'},
          O:{name:'Openness',high:'Intellectually curious, creative, and open to new experiences. You enjoy complexity and abstract thinking.',medium:'You balance practicality with curiosity, engaging with creativity when the context calls for it.',low:'Practical and grounded. You prefer proven approaches — a strength in roles that reward consistency.'},
        },
        questions:["I am the life of the party.","I insult people.","I am always prepared.","I get stressed out easily.","I have a rich vocabulary.","I don't talk a lot.","I am interested in people.","I leave my belongings around.","I am relaxed most of the time.","I have difficulty understanding abstract ideas.","I feel comfortable around people.","I am not really interested in others.","I pay attention to details.","I worry about things.","I have a vivid imagination.","I keep in the background.","I sympathize with others' feelings.","I make a mess of things.","I seldom feel blue.","I am not interested in abstract ideas.","I start conversations.","I am not interested in other people's problems.","I get chores done right away.","I am easily disturbed.","I have excellent ideas.","I have little to say.","I have a soft heart.","I often forget to put things back in their proper place.","I am not easily bothered by things.","I do not have a good imagination.","I talk to a lot of different people at parties.","I don't have a soft side.","I like order.","I get upset easily.","I am quick to understand things.","I don't like to draw attention to myself.","I take time out for others.","I shirk my duties.","I don't get irritated easily.","I avoid difficult reading material.","I don't mind being the center of attention.","I feel little concern for others.","I follow a schedule.","I change my mood a lot.","I use difficult words.","I am quiet around strangers.","I feel others' emotions.","I don't see things through.","I rarely feel depressed.","I have difficulty imagining things."],
      },
      selfesteem:{
        title:'Self-Esteem',subtitle:'Rosenberg Scale · 10 questions · ~3 min',
        desc:'The gold standard for self-esteem measurement. Used in clinical, educational, and HR contexts worldwide.',
        tagline:'Self & Wellbeing',scaleName:'Rosenberg Self-Esteem Scale',
        footer:'Based on the Rosenberg Self-Esteem Scale (public domain). For informational purposes only.',
        labels:["Strongly Disagree","Disagree","Agree","Strongly Agree"],
        levels:{
          high:{label:'High Self-Esteem',desc:'You have a strong, stable sense of your own worth. You approach challenges with confidence and recover well from setbacks. This is a significant asset in leadership and high-pressure roles.'},
          medium:{label:'Moderate Self-Esteem',desc:'You have a reasonably positive self-image with some areas of self-doubt. This is typical and healthy — you can build confidence further through experience and reflection.'},
