        h('div',{className:'flex items-center gap-2'},
          h('button',{onClick:function(){window.print();},className:'text-gray-500 text-xs font-medium focus:outline-none'},T.ui.print),
          h('button',{onClick:onRetake,className:'border border-gray-300 text-gray-600 text-xs font-medium px-3 py-1.5 rounded-lg focus:outline-none'},T.ui.retake),
          h('button',{onClick:onHome,className:'bg-navy text-white text-xs font-medium px-3 py-1.5 rounded-lg focus:outline-none no-print'},T.ui.allTests)
        )
      )
    );
  }

  function ResultsWrapper({test,scores,onRetake,onHome}){
    const ORDER=test.traitOrder||[];
    const backBtn=h('div',{className:'mt-6 bg-navy rounded-2xl p-5 text-center no-print'},
      h('button',{onClick:onHome,className:'bg-gold text-navy font-bold text-sm px-6 py-2 rounded-lg'},T.ui.backToTests)
    );

    if(test.resultType==='selfesteem'){
      const{pct,level}=scores;
      const lv=T.selfesteem.levels[level];
      const color=pct>=70?'#10B981':pct>=45?'#F59E0B':'#EF4444';
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:T.selfesteem.title}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold mb-1'},T.selfesteem.title+T.ui.resultsSuffix),h('p',{className:'text-gray-400 text-sm'},T.selfesteem.scaleName)),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6 text-center'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},T.ui.yourScore),
            h('p',{className:'text-5xl font-bold mb-1'},pct),
            h('p',{className:'text-sm mb-3',style:{color:'rgba(138,155,176,0.7)'}},T.ui.outOf),
            h('span',{className:'inline-block text-sm font-semibold px-4 py-1.5 rounded-full',style:{background:color+'33',color:color}},lv.label)
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('div',{className:'w-full bg-gray-100 rounded-full h-4 mb-4'},h('div',{className:'bar-fill h-4 rounded-full',style:{width:pct+'%',background:color}})),
            h('p',{className:'text-gray-600 text-sm leading-relaxed'},lv.desc)
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},test.footer),
          backBtn
        )
      );
    }

    if(test.resultType==='big5'){
      const pMap=T.big5.profile;
      const topTwo=ORDER.map(function(k){return[k,scores[k]];}).sort(function(a,b){return b[1].pct-a[1].pct;}).slice(0,2);
      const joiner=LANG==='de'?' und ':LANG==='fa'?' و ':LANG==='sr'?' i ':' and ';
      const profileDesc=topTwo.map(function(x){return pMap[x[0]];}).join(joiner);
      return h('div',{className:'bg-gray-50'},
        h(ResultActions,{onRetake,onHome,title:T.big5.title}),
        h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
          h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},T.big5.title+T.ui.resultsSuffix)),
          h('div',{className:'bg-navy text-white rounded-2xl p-6 mb-6'},
            h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-2'},T.ui.yourProfile),
            h('p',{className:'font-semibold'},T.ui.characterizedAs,h('span',{className:'text-gold'},profileDesc),'.')
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4'},
            h('h2',{className:'text-navy font-semibold text-sm mb-4'},T.ui.scoreOverview),
            ORDER.map(function(k){const t=test.traits[k];const s=scores[k];return h('div',{key:k,className:'flex items-center gap-3 mb-3'},h('span',{className:'text-gray-500 text-xs w-36 flex-shrink-0'},t.name),h('div',{className:'flex-1 bg-gray-100 rounded-full h-2'},h('div',{className:'bar-fill h-2 rounded-full',style:{width:s.pct+'%',background:t.color}})),h('span',{className:'text-gray-400 text-xs font-semibold w-8 text-right'},s.pct+'%'));})
          ),
          h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6'},
            h('h2',{className:'text-navy font-semibold text-sm mb-6'},T.ui.detailedResults),
            ORDER.map(function(k){const t=test.traits[k];const s=scores[k];return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
          ),
          h('p',{className:'text-gray-400 text-xs text-center mb-4'},test.footer),
          backBtn
        )
      );
    }

    // Generic fallback
    return h('div',{className:'bg-gray-50'},
      h(ResultActions,{onRetake,onHome,title:test.title}),
      h('div',{className:'max-w-2xl mx-auto px-4 py-8'},
        h('div',{className:'text-center mb-6'},h('h1',{className:'text-navy text-2xl font-bold'},test.title+T.ui.resultsSuffix)),
        h('div',{className:'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4'},
          h('h2',{className:'text-navy font-semibold text-sm mb-5'},T.ui.yourScores),
          ORDER.map(function(k){const t=test.traits[k];const s=scores[k];if(!t||!s)return null;return h(TraitBar,{key:k,name:t.name,pct:s.pct,level:s.level,color:t.color,bg:t.bg,interpretation:t[s.level]});})
        ),
        h('p',{className:'text-gray-400 text-xs text-center mb-4'},T.ui.forInfoOnly),
        backBtn
      )
    );
  }

  function SurveyRunner({test,onComplete,onBack}){
    const[idx,setIdx]=useState(0);
    const[answers,setAns]=useState({});
    const qs=test.questions;
    const q=qs[idx];
    function pick(v){
      const next=Object.assign({},answers);next[q.id]=v;setAns(next);
      setTimeout(function(){if(idx<qs.length-1)setIdx(function(i){return i+1;});else onComplete(next);},280);
    }
    return h(QuestionCard,{question:q,answers,labels:test.labels,onPick:pick,onBack:function(){idx>0?setIdx(function(i){return i-1;}):onBack();},current:idx+1,total:qs.length,testTitle:test.title});
  }

  function Home({onSelectTest}){
    const tagColors=T.tags||{};
    return h('div',{className:'bg-gray-50'},
      h('div',{className:'bg-navy px-6 py-10 text-center'},
        h('p',{className:'text-gold text-xs font-semibold uppercase tracking-widest mb-3'},T.ui.kicker),
        h('h1',{className:'text-white text-3xl font-bold mb-3'},T.ui.heroTitle),
        h('p',{className:'text-silver/80 text-base max-w-xl mx-auto'},T.ui.heroSubtitle)
      ),
      h('div',{className:'max-w-2xl mx-auto px-4 pt-8 pb-16'},
        h('p',{className:'text-gray-400 text-xs font-semibold uppercase tracking-widest mb-4 text-center'},TESTS.length+' '+T.ui.available),
        h('div',{className:'space-y-4'},
          TESTS.map(function(test){
            return h('div',{key:test.id,onClick:function(){onSelectTest(test.id);},className:'card-hover bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 shadow-sm'},
              h('div',{className:'w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0',style:{background:'linear-gradient(135deg,'+test.color+'22,'+test.color+'44)'}},test.icon),
              h('div',{className:'flex-1 min-w-0'},
                h('div',{className:'flex items-start justify-between gap-2 mb-1'},
                  h('h3',{className:'text-navy font-bold text-base leading-tight'},test.title),
                  h('span',{className:'text-xs font-semibold px-2 py-0.5 rounded-full flex-shrink-0 '+(tagColors[test.tagline]||'bg-gray-100 text-gray-600')},test.tagline)
                ),
                h('p',{className:'text-gray-400 text-xs mb-2'},test.subtitle),
                h('p',{className:'text-gray-600 text-sm leading-relaxed'},test.desc)
              ),
              h('div',{className:'text-gray-300 text-xl flex-shrink-0 self-center'},'›')
            );
          })
        )
      )
    );
  }

  function App(){
    const[screen,setScreen]=useState('home');
    const[activeId,setActive]=useState(null);
    const[scores,setScores]=useState(null);
    const test=TESTS.find(function(t){return t.id===activeId;});
    function selectTest(id){setActive(id);setScreen('survey');window.scrollTo(0,0);}
    function handleComplete(ans){setScores(test.score(ans));setScreen('results');window.scrollTo(0,0);}
    function goHome(){setScreen('home');setActive(null);setScores(null);window.scrollTo(0,0);}
    let content;
    if(screen==='home') content=h(Home,{onSelectTest:selectTest});
    else if(screen==='survey') content=h(SurveyRunner,{test,onComplete:handleComplete,onBack:goHome});
    else content=h(ResultsWrapper,{test,scores,onRetake:function(){selectTest(activeId);},onHome:goHome});
    return h('div',{dir:RTL?'rtl':'ltr'},content);
  }

  ReactDOM.createRoot(document.getElementById('root')).render(h(App));
  })();
  </script>
