---
// React + Tailwind CDN deps for the assess mini-app. Use inside
// <Fragment slot="head"> of each assess page wrapper.
---
<script is:inline src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script is:inline src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script is:inline>
      tailwind = { config: { theme: { extend: { colors: { navy:'#0A1628', gold:'#D4AF37', silver:'#8A9BB0' }, fontFamily: { sans: ['Inter','system-ui','sans-serif'] } } } } };
    </script>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
