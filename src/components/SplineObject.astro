---
/**
 * SplineObject.astro — AHoosh.ai no-React Spline embed (opt-in).
 *
 * The "make Spline ours" path: instead of @splinetool/react-spline (pulls React),
 * use the framework-agnostic <spline-viewer> web component, loaded lazily from CDN
 * only when the element scrolls into view and only if motion is allowed. Shows a
 * gold loader until ready. NOT used anywhere yet — drop it on a page once we have a
 * hosted scene URL and have signed off on the runtime's bundle cost.
 *
 * Usage:  <SplineObject scene="https://prod.spline.design/XXXX/scene.splinecode" class="hero-3d" />
 */
interface Props {
  scene: string;
  class?: string;
}
const { scene, class: className } = Astro.props;
---

<div class={className} data-spline-scene={scene} style="position:relative;width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
  <span class="spline-loader" aria-hidden="true"></span>
</div>

<script>
  const mount = () => {
    document.querySelectorAll<HTMLElement>('[data-spline-scene]').forEach((host) => {
      if (host.dataset.splineMounted) return;
      const io = new IntersectionObserver(async (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          io.disconnect();
          host.dataset.splineMounted = '1';
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          if (!customElements.get('spline-viewer')) {
            await import(/* @vite-ignore */ 'https://unpkg.com/@splinetool/viewer@latest/build/spline-viewer.js');
          }
          const el = document.createElement('spline-viewer');
          el.setAttribute('url', host.dataset.splineScene!);
          el.style.width = '100%';
          el.style.height = '100%';
          host.innerHTML = '';
          host.appendChild(el);
        }
      }, { rootMargin: '200px' });
      io.observe(host);
    });
  };
  if ('requestIdleCallback' in window) (window as any).requestIdleCallback(mount);
  else setTimeout(mount, 500);
</script>

<style>
  .spline-loader {
    display: block; width: 28px; height: 28px;
    border: 2px solid rgba(224,169,63,0.3);
    border-top-color: var(--gold, #e0a93f);
    border-radius: 50%;
    animation: spline-spin 0.8s linear infinite;
  }
  @keyframes spline-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .spline-loader { animation: none; } }
</style>
