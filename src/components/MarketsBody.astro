---
// Shared markets page body — all four locales render this with their strings.
// Price logic lives here ONCE; locale pages only pass translations.
interface Strings {
  eyebrow: string;
  h1: string;
  subtitle: string;
  fxHeading: string;
  commoditiesHeading: string;
  cryptoHeading: string;
  bridgeTitle: string;
  bridgeText: string;
  bridgeCta: string;
  disclaimerLabel: string;
  disclaimerText: string;
  sourcesHtml: string;
  updatedLabel: string;
  names: Record<string, string>;
}
interface Props {
  t: Strings;
  contactHref: string;
}
const { t, contactHref } = Astro.props;
---

<!-- Hero -->
<section style="background:linear-gradient(160deg,#03142E 0%,#010A18 100%);padding:40px 24px 28px;border-bottom:1px solid rgba(215,161,61,0.1);">
  <div style="max-width:1040px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <div class="section-eyebrow" style="margin-bottom:6px;">{t.eyebrow}</div>
      <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(20px,4vw,28px);color:var(--silver);margin:0;line-height:1.2;" set:html={t.h1} />
      <p style="font-size:13px;color:var(--silver-dim);margin-top:6px;">{t.subtitle}</p>
    </div>
    <div id="last-updated" style="font-size:11px;color:var(--silver-muted);"></div>
  </div>
</section>

<!-- Dashboard -->
<div style="max-width:1040px;margin:0 auto;padding:24px 24px 48px;">

  <section style="margin-bottom:32px;">
    <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;">{t.fxHeading}</div>
    <div id="fx-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;">
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
    </div>
  </section>

  <section style="margin-bottom:32px;">
    <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;">{t.commoditiesHeading}</div>
    <div id="commodity-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;">
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
    </div>
  </section>

  <section style="margin-bottom:40px;">
    <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;">{t.cryptoHeading}</div>
    <div id="crypto-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;">
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
      <div class="price-skeleton"></div><div class="price-skeleton"></div>
    </div>
  </section>

  <!-- Consulting bridge -->
  <div style="background:rgba(215,161,61,0.07);border:1px solid rgba(215,161,61,0.2);border-radius:8px;padding:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
    <div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:15px;color:var(--silver);margin-bottom:4px;">{t.bridgeTitle}</div>
      <div style="font-size:13px;color:var(--silver-dim);">{t.bridgeText}</div>
    </div>
    <a href={contactHref} class="btn-primary" style="white-space:nowrap;flex-shrink:0;">{t.bridgeCta}</a>
  </div>

  <!-- Attribution + disclaimer -->
  <div style="margin-top:24px;font-size:11px;color:var(--silver-muted);line-height:1.8;">
    <strong style="color:var(--silver-dim);">{t.disclaimerLabel}</strong> {t.disclaimerText}<br/>
    <Fragment set:html={t.sourcesHtml} />
  </div>
</div>

<style is:global>
  .price-skeleton {
    height: 88px;
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.07) 50%, rgba(255,255,255,0.04) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border-radius: 6px;
    border: 1px solid rgba(215,161,61,0.08);
  }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

  .price-card {
    background: rgba(10,30,60,0.85);
    border: 1px solid rgba(215,161,61,0.22);
    border-radius: 6px;
    padding: 14px;
    transition: border-color 150ms ease;
  }
  .price-card:hover { border-color: rgba(215,161,61,0.5); }
  .price-card .symbol {
    font-family: var(--font-head);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #e8eaf0;
    margin-bottom: 2px;
    direction: ltr;
  }
  .price-card .name {
    font-size: 10px;
    color: #8a9bb0;
    margin-bottom: 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .price-card .price {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 17px;
    color: #D7A13D;
    line-height: 1;
    margin-bottom: 6px;
    direction: ltr;
  }
  .price-card .change {
    font-size: 11px;
    font-weight: 600;
    direction: ltr;
  }
  .change-up   { color: #34d399; }
  .change-down { color: #f87171; }
  .change-flat { color: #8a9bb0; }

  @keyframes flashUp   { 0%{background:rgba(52,211,153,0.25)} 100%{background:rgba(10,30,60,0.85)} }
  @keyframes flashDown { 0%{background:rgba(248,113,113,0.25)} 100%{background:rgba(10,30,60,0.85)} }
  .flash-up   { animation: flashUp   0.8s ease forwards; }
  .flash-down { animation: flashDown 0.8s ease forwards; }
</style>

<script is:inline define:vars={{ NAMES: t.names, UPDATED_LABEL: t.updatedLabel }}>
(function () {

  const nm = (sym, fallback) => NAMES[sym] || fallback;

  const FALLBACK = {
    fx: [
      { symbol: 'EUR/USD', name: nm('EUR/USD','Euro / US Dollar'),       price: 1.1539,  change: null },
      { symbol: 'EUR/GBP', name: nm('EUR/GBP','Euro / British Pound'),   price: 0.8623,  change: null },
      { symbol: 'EUR/CHF', name: nm('EUR/CHF','Euro / Swiss Franc'),     price: 0.9222,  change: null },
      { symbol: 'EUR/RSD', name: nm('EUR/RSD','Euro / Serbian Dinar'),   price: 117.38,  change: null },
      { symbol: 'EUR/TRY', name: nm('EUR/TRY','Euro / Turkish Lira'),    price: 53.24,   change: null },
      { symbol: 'USD/IRR', name: nm('USD/IRR','US Dollar / Iranian Rial (market)'), price: 1769800, change: null },
      { symbol: 'EUR/IRR', name: nm('EUR/IRR','Euro / Iranian Rial (market)'),      price: 2043100, change: null },
    ],
    commodities: [
      { symbol: 'XAU/USD', name: nm('XAU/USD','Gold oz'),     price: 4079.90, change: null },
      { symbol: 'XAG/USD', name: nm('XAG/USD','Silver oz'),   price: 64.21,   change: null },
      { symbol: 'BRENT',   name: nm('BRENT','Brent Crude'),   price: 93.55,   change: null },
      { symbol: 'WTI',     name: nm('WTI','WTI Crude'),       price: 90.51,   change: null },
    ],
    crypto: [
      { symbol: 'BTC', name: 'Bitcoin',   price: 67500,  change: null },
      { symbol: 'ETH', name: 'Ethereum',  price: 3820,   change: null },
      { symbol: 'BNB', name: 'BNB',       price: 620,    change: null },
      { symbol: 'SOL', name: 'Solana',    price: 165,    change: null },
      { symbol: 'XRP', name: 'XRP',       price: 0.542,  change: null },
      { symbol: 'ADA', name: 'Cardano',   price: 0.463,  change: null },
      { symbol: 'AVAX',name: 'Avalanche', price: 37.2,   change: null },
      { symbol: 'DOGE',name: 'Dogecoin',  price: 0.154,  change: null },
    ],
  };

  function fmt(price) {
    if (price >= 10000) return price.toLocaleString('en-US', { maximumFractionDigits: 0 });
    if (price >= 1000)  return price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (price >= 10)    return price.toFixed(2);
    if (price >= 1)     return price.toFixed(3);
    return price.toFixed(4);
  }

  function changeClass(c) {
    if (c === null || c === undefined) return 'change-flat';
    if (c > 0) return 'change-up';
    if (c < 0) return 'change-down';
    return 'change-flat';
  }

  function changeLabel(c) {
    if (c === null || c === undefined) return '—';
    const sign = c > 0 ? '▲ +' : c < 0 ? '▼ ' : '';
    return sign + Math.abs(c).toFixed(2) + '%';
  }

  const prevPrices = {};

  function buildCard(item) {
    const d = document.createElement('div');
    d.className = 'price-card';
    d.dataset.symbol = item.symbol;
    d.innerHTML =
      '<div class="symbol">' + item.symbol + '</div>' +
      '<div class="name">' + item.name + '</div>' +
      '<div class="price">' + fmt(item.price) + '</div>' +
      '<div class="change ' + changeClass(item.change) + '">' + changeLabel(item.change) + '</div>';
    prevPrices[item.symbol] = item.price;
    return d;
  }

  function updateCard(card, item) {
    const prev = prevPrices[item.symbol];
    const priceEl  = card.querySelector('.price');
    const changeEl = card.querySelector('.change');
    if (priceEl)  priceEl.textContent = fmt(item.price);
    if (changeEl) {
      changeEl.textContent  = changeLabel(item.change);
      changeEl.className    = 'change ' + changeClass(item.change);
    }
    if (prev !== undefined && item.price !== prev) {
      card.classList.remove('flash-up','flash-down');
      void card.offsetWidth;
      card.classList.add(item.price > prev ? 'flash-up' : 'flash-down');
    }
    prevPrices[item.symbol] = item.price;
  }

  function render(data) {
    ['fx', 'commodities', 'crypto'].forEach(function(key) {
      const gridId = key === 'commodities' ? 'commodity-grid' : key + '-grid';
      const grid = document.getElementById(gridId);
      if (!grid) return;
      const items = data[key] || [];
      const existing = grid.querySelectorAll('.price-card');
      if (existing.length === 0 || existing.length !== items.length) {
        grid.innerHTML = '';
        items.forEach(function(item) { grid.appendChild(buildCard(item)); });
      } else {
        items.forEach(function(item, i) { updateCard(existing[i], item); });
      }
    });

    const lu = document.getElementById('last-updated');
    if (lu) {
      const now = new Date();
      lu.textContent = UPDATED_LABEL + ' ' + now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }
  }

  async function fetchLive() {
    try {
      const fxResp = await fetch(
        'https://api.frankfurter.dev/v1/latest?base=EUR&symbols=USD,GBP,CHF,TRY',
        { signal: AbortSignal.timeout(8000) }
      ).catch(function(){ return null; });
      const fxData = fxResp && fxResp.ok ? await fxResp.json() : null;

      const mResp = await fetch('/api/markets', {
        signal: AbortSignal.timeout(15000),
      }).catch(function(){ return null; });
      const mData = mResp && mResp.ok ? await mResp.json() : null;

      const cgResp = await fetch(
        'https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=8&page=1&price_change_percentage=24h',
        { signal: AbortSignal.timeout(12000) }
      ).catch(function(){ return null; });
      const cgData = cgResp && cgResp.ok ? await cgResp.json() : null;

      const result = JSON.parse(JSON.stringify(FALLBACK));

      const rates = (fxData && fxData.rates) || {};
      const m = mData || {};
      const irrUsd = (m.irr && m.irr.usd) || null;
      const irrEur = (m.irr && m.irr.eur) || null;
      const rsd = m.eur_rsd || null;
      result.fx = [
        { symbol: 'EUR/USD', name: nm('EUR/USD','Euro / US Dollar'),     price: rates.USD || FALLBACK.fx[0].price, change: null },
        { symbol: 'EUR/GBP', name: nm('EUR/GBP','Euro / British Pound'), price: rates.GBP || FALLBACK.fx[1].price, change: null },
        { symbol: 'EUR/CHF', name: nm('EUR/CHF','Euro / Swiss Franc'),   price: rates.CHF || FALLBACK.fx[2].price, change: null },
        { symbol: 'EUR/RSD', name: nm('EUR/RSD','Euro / Serbian Dinar'), price: (rsd && rsd.price) || FALLBACK.fx[3].price, change: null },
        { symbol: 'EUR/TRY', name: nm('EUR/TRY','Euro / Turkish Lira'),  price: rates.TRY || FALLBACK.fx[4].price, change: null },
        { symbol: 'USD/IRR', name: nm('USD/IRR','US Dollar / Iranian Rial (market)'),
          price: (irrUsd && irrUsd.price) || FALLBACK.fx[5].price,
          change: irrUsd ? irrUsd.change : null },
        { symbol: 'EUR/IRR', name: nm('EUR/IRR','Euro / Iranian Rial (market)'),
          price: (irrEur && irrEur.price) || FALLBACK.fx[6].price,
          change: irrEur ? irrEur.change : null },
      ];

      const com = m.commodities || {};
      result.commodities = [
        { symbol: 'XAU/USD', name: nm('XAU/USD','Gold oz'),     price: (com.gold   && com.gold.price)   || FALLBACK.commodities[0].price, change: com.gold   ? com.gold.change   : null },
        { symbol: 'XAG/USD', name: nm('XAG/USD','Silver oz'),   price: (com.silver && com.silver.price) || FALLBACK.commodities[1].price, change: com.silver ? com.silver.change : null },
        { symbol: 'BRENT',   name: nm('BRENT','Brent Crude'),   price: (com.brent  && com.brent.price)  || FALLBACK.commodities[2].price, change: com.brent  ? com.brent.change  : null },
        { symbol: 'WTI',     name: nm('WTI','WTI Crude'),       price: (com.wti    && com.wti.price)    || FALLBACK.commodities[3].price, change: com.wti    ? com.wti.change    : null },
      ];

      if (cgData && Array.isArray(cgData)) {
        result.crypto = cgData.slice(0, 8).map(function(c) {
          return {
            symbol: c.symbol.toUpperCase(),
            name: c.name,
            price: c.current_price,
            change: c.price_change_percentage_24h
              ? parseFloat(c.price_change_percentage_24h.toFixed(2))
              : null,
          };
        });
      }

      render(result);
    } catch (e) {
      render(FALLBACK);
    }
  }

  fetchLive();
  setInterval(fetchLive, 60000);

})();
</script>
