---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Writing" description="AHoosh insights on AI, B2B operations, and digital transformation.">
  <section style="max-width: 800px; margin: 0 auto; padding: var(--space-12) var(--space-4);">
    <h1 style="font-size: clamp(28px, 5vw, 40px); font-weight: 600; margin-bottom: var(--space-6);">
      Writing
    </h1>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-secondary);">First posts coming soon.</p>
    ) : (
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4);">
        {posts.map((post) => (
          <li style="border-bottom: 1px solid var(--color-border); padding-bottom: var(--space-4);">
            <a href={`/writing/${post.id}`} style="text-decoration: none;">
              <h2 style="font-size: clamp(20px, 3vw, 26px); font-weight: 500; color: var(--color-navy); margin-bottom: var(--space-1);">
                {post.data.title}
              </h2>
              <p style="font-size: 14px; color: var(--color-text-muted); margin-bottom: var(--space-1);">
                {post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              {post.data.description && (
                <p style="font-size: 15px; color: var(--color-text-secondary); margin: 0;">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
