---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent" description="Thanks for getting in touch. We'll respond within 1–2 business days.">

  <section style="
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
  ">
    <div style="text-align:center;max-width:420px;">

      <!-- Checkmark icon -->
      <div style="
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 64px; height: 64px;
        border-radius: 50%;
        background: rgba(215,161,61,0.12);
        margin-bottom: 24px;
      ">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#D7A13D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <div class="section-eyebrow">Message received</div>

      <h1 style="
        font-family: var(--font-head);
        font-weight: 700;
        font-size: clamp(22px, 6vw, 32px);
        letter-spacing: -0.01em;
        color: var(--silver);
        margin: 8px 0 16px;
      ">We'll be in touch soon</h1>

      <p style="font-size:14px;color:var(--silver-dim);line-height:1.7;margin-bottom:36px;">
        Your message is on its way to Hesam. Expect a reply within 1–2 business days — usually much sooner.
      </p>

      <div style="display:flex;flex-direction:column;gap:12px;max-width:280px;margin:0 auto;">
        <a href="/" style="
          display: block;
          background: var(--gold);
          color: #03142E;
          font-family: var(--font-head);
          font-weight: 700;
          font-size: 13px;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          padding: 14px 24px;
          border-radius: 2px;
          text-decoration: none;
          min-height: 44px;
          display: flex;
          align-items: center;
          justify-content: center;
        ">Back to home</a>

        <a href="/consulting" style="
          display: flex;
          align-items: center;
          justify-content: center;
          min-height: 44px;
          font-size: 13px;
          color: var(--silver-dim);
          text-decoration: none;
          border: 1px solid rgba(215,161,61,0.2);
          border-radius: 2px;
          padding: 12px 24px;
        ">View our services</a>
      </div>

    </div>
  </section>

</BaseLayout>
