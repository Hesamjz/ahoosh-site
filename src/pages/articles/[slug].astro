---
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // English articles only — translations live under fa/ de/ sr/ subfolders
  // and are served by the locale routes (/fa/articles/... etc.)
  return posts
    .filter((post) => !/^(fa|de|sr)\//.test(post.id))
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPost post={post}>
  <Content />
</BlogPost>
