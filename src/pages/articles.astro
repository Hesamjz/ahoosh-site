---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft && !/^(fa|de|sr)\//.test(p.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect unique tags
const allTags = ['All', ...new Set(posts.flatMap((p) => p.data.tags ?? []))];
---

<BaseLayout title="Articles" description="Practitioner perspectives on AI, B2B operations, and building in emerging markets.">

  <!-- Hero -->
  <section style="
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
    padding: 48px 24px 40px;
    text-align: center;
    border-bottom: 1px solid rgba(215,161,61,0.1);
  ">
    <div class="section-eyebrow">Articles</div>
    <h1 style="
      font-family: var(--font-head);
      font-weight: 700;
      font-size: clamp(24px, 6vw, 36px);
      letter-spacing: -0.01em;
      color: var(--silver);
      margin-bottom: 10px;
    ">Intelligence,<br>Written Down</h1>
    <p style="font-size:14px;color:var(--silver-dim);line-height:1.6;max-width:380px;margin:0 auto;">Practitioner perspectives on AI, B2B operations, and building in emerging markets.</p>
  </section>

  <!-- Category filter pills (static for now — JS enhancement later) -->
  <div style="
    padding: 20px 24px 8px;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    max-width: 680px;
    margin: 0 auto;
  ">
    <span style="
      flex-shrink:0;display:inline-block;
      background:var(--gold);border:1px solid var(--gold);color:var(--navy-dark);
      font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;
      padding:6px 12px;border-radius:999px;cursor:pointer;
    ">All</span>
    <span style="flex-shrink:0;display:inline-block;border:1px solid rgba(215,161,61,0.3);color:var(--silver-dim);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 12px;border-radius:999px;">AI Operations</span>
    <span style="flex-shrink:0;display:inline-block;border:1px solid rgba(215,161,61,0.3);color:var(--silver-dim);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 12px;border-radius:999px;">Strategy</span>
    <span style="flex-shrink:0;display:inline-block;border:1px solid rgba(215,161,61,0.3);color:var(--silver-dim);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 12px;border-radius:999px;">Emerging Markets</span>
    <span style="flex-shrink:0;display:inline-block;border:1px solid rgba(215,161,61,0.3);color:var(--silver-dim);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 12px;border-radius:999px;">FX &amp; Trade</span>
  </div>

  <!-- Article list -->
  <div style="padding:16px 24px 40px;max-width:680px;margin:0 auto;">

    {posts.length > 0 ? posts.map((post) => (
      <a href={`/articles/${post.id}`} style="display:block;text-decoration:none;">
        <div style="
          background: rgba(255,255,255,0.03);
          border: 1px solid rgba(215,161,61,0.1);
          border-radius: 6px;
          padding: 20px;
          margin-bottom: 12px;
          transition: border-color 150ms ease;
        ">
          <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">
            {(post.data as any).tags?.[0] ?? 'Article'}
          </div>
          <div style="font-family:var(--font-head);font-weight:600;font-size:15px;line-height:1.4;color:var(--silver);margin-bottom:8px;">
            {post.data.title}
          </div>
          {post.data.description && (
            <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">
              {post.data.description}
            </p>
          )}
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:var(--silver-muted);">
              {post.data.pubDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
            </span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Read →</span>
          </div>
        </div>
      </a>
    )) : (
      /* Placeholder cards when no posts exist yet */
      <>
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:20px;margin-bottom:12px;">
          <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">AI Operations</div>
          <div style="font-family:var(--font-head);font-weight:600;font-size:15px;line-height:1.4;color:var(--silver);margin-bottom:8px;">Why Most AI Implementations Fail in the First 90 Days</div>
          <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">The tools are not the problem. The process assumptions underneath them are.</p>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:var(--silver-muted);">June 2026 · 6 min read</span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Coming soon</span>
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:20px;margin-bottom:12px;">
          <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">B2B Transformation</div>
          <div style="font-family:var(--font-head);font-weight:600;font-size:15px;line-height:1.4;color:var(--silver);margin-bottom:8px;">The Emerging Market AI Stack: What Actually Works</div>
          <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">After years of implementations across different markets and industries — here is what we keep using.</p>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:var(--silver-muted);">May 2026 · 9 min read</span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Coming soon</span>
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:20px;margin-bottom:12px;">
          <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">Emerging Markets</div>
          <div style="font-family:var(--font-head);font-weight:600;font-size:15px;line-height:1.4;color:var(--silver);margin-bottom:8px;">Operating Between Markets: A Year of Running AHoosh from Belgrade</div>
          <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">The systems, the surprises, and the compounding advantages of building with AI at the intersection of research, market data, and consulting.</p>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:var(--silver-muted);">April 2026 · 7 min read</span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Coming soon</span>
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:20px;">
          <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">PhD Research</div>
          <div style="font-family:var(--font-head);font-weight:600;font-size:15px;line-height:1.4;color:var(--silver);margin-bottom:8px;">What Academic Research on AI Gets Wrong About B2B Reality</div>
          <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">Field notes from someone living in both worlds simultaneously.</p>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:var(--silver-muted);">March 2026 · 5 min read</span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Coming soon</span>
          </div>
        </div>
      </>
    )}
  </div>

</BaseLayout>
