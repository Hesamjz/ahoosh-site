---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Website Audit — AHoosh Assess"
  description="Free website performance, SEO, and accessibility audit. Get your digital presence score and an AI-powered diagnosis."
  locale="en"
>
<style>
  :root { --gold:#D7A13D; --navy:#010A18; --card-bg:rgba(8,22,50,0.92); }
  body  { background:#010A18; color:#c8d4e0; }
  .wrap { max-width:760px; margin:0 auto; padding:40px 20px 80px; }
  h1   { font-size:clamp(22px,4vw,32px); color:#e8eaf0; margin:0 0 8px; }
  .sub { color:#7a8b9e; font-size:15px; margin:0 0 36px; }

  /* Step headers */
  .step-header {
    display:flex; align-items:center; gap:12px;
    margin:0 0 20px;
  }
  .step-num {
    width:28px; height:28px; border-radius:50%;
    background:rgba(215,161,61,0.15); border:1px solid rgba(215,161,61,0.4);
    color:var(--gold); font-size:13px; font-weight:700;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .step-title { font-size:16px; font-weight:600; color:#e8eaf0; }
  .step-desc  { font-size:13px; color:#7a8b9e; margin:0 0 24px 40px; }

  /* URL row */
  .url-row { display:flex; gap:10px; flex-wrap:wrap; margin-left:40px; }
  .url-row input {
    flex:1; min-width:220px; padding:13px 16px;
    background:rgba(255,255,255,0.06); border:1px solid rgba(215,161,61,0.3);
    border-radius:8px; color:#e8eaf0; font-size:15px;
  }
  .url-row input::placeholder { color:#4a5a6e; }
  .url-row input:focus { outline:none; border-color:#D7A13D; }
  .btn-audit {
    padding:13px 28px; background:#D7A13D; color:#010A18;
    font-weight:700; border:none; border-radius:8px; font-size:15px;
    cursor:pointer; white-space:nowrap;
  }
  .btn-audit:disabled { opacity:0.5; cursor:not-allowed; }

  /* Status */
  .status { margin:12px 0 0 40px; font-size:14px; color:#7a8b9e; min-height:20px; }

  /* Score cards */
  .scores { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:16px; margin:32px 0 20px; }
  .score-card {
    background:var(--card-bg); border:1px solid rgba(215,161,61,0.15);
    border-radius:12px; padding:20px; text-align:center;
  }
  .score-num { font-size:40px; font-weight:700; line-height:1; margin-bottom:6px; }
  .score-label { font-size:12px; text-transform:uppercase; letter-spacing:0.08em; color:#7a8b9e; }
  .score-green  { color:#34d399; }
  .score-orange { color:#fbbf24; }
  .score-red    { color:#f87171; }

  /* Vitals & opps */
  .vitals, .opps {
    background:var(--card-bg); border:1px solid rgba(215,161,61,0.15);
    border-radius:12px; padding:20px; margin-bottom:16px;
  }
  .vitals h3, .opps h3 {
    margin:0 0 16px; font-size:13px;
    text-transform:uppercase; letter-spacing:0.1em; color:var(--gold);
  }
  .vital-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.05); font-size:14px; }
  .vital-row:last-child { border-bottom:none; }
  .vital-val { color:#e8eaf0; font-weight:600; }
  .opp { padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.05); font-size:13px; color:#8a9bb0; }
  .opp:last-child { border-bottom:none; }
  .opp strong { color:#e8eaf0; display:block; margin-bottom:2px; font-size:14px; }

  /* Divider */
  .section-divider { border:none; border-top:1px solid rgba(255,255,255,0.07); margin:40px 0; }

  /* Social checklist */
  .checklist { display:flex; flex-direction:column; gap:12px; margin-left:40px; margin-bottom:24px; }
  .check-item {
    background:var(--card-bg); border:1px solid rgba(255,255,255,0.07);
    border-radius:10px; padding:14px 16px;
    display:flex; align-items:center; justify-content:space-between; gap:12px;
  }
  .check-item.answered { border-color:rgba(215,161,61,0.2); }
  .check-q { font-size:14px; color:#c8d4e0; line-height:1.4; flex:1; }
  .check-btns { display:flex; gap:6px; flex-shrink:0; }
  .chk {
    padding:5px 12px; border-radius:6px; font-size:12px; font-weight:600;
    border:1px solid rgba(255,255,255,0.12); background:transparent;
    color:#7a8b9e; cursor:pointer; transition:all .15s;
  }
  .chk:hover { border-color:rgba(215,161,61,0.4); color:#c8d4e0; }
  .chk.sel-yes  { background:rgba(52,211,153,0.15); border-color:#34d399; color:#34d399; }
  .chk.sel-part { background:rgba(251,191,36,0.12); border-color:#fbbf24; color:#fbbf24; }
  .chk.sel-no   { background:rgba(248,113,113,0.12); border-color:#f87171; color:#f87171; }

  /* Social save row */
  .social-actions { display:flex; align-items:center; gap:16px; margin-left:40px; margin-bottom:8px; }
  .btn-social-save {
    padding:10px 24px; background:rgba(215,161,61,0.12);
    border:1px solid rgba(215,161,61,0.4); color:var(--gold);
    font-size:14px; font-weight:700; border-radius:8px; cursor:pointer;
    transition:all .2s;
  }
  .btn-social-save:hover { background:rgba(215,161,61,0.22); }
  .social-saved-msg { font-size:13px; color:#34d399; display:none; }
  .social-score-row { font-size:13px; color:#7a8b9e; margin-left:40px; margin-bottom:32px; }
  .social-score-row span { color:var(--gold); font-weight:700; }

  /* Combined digital score band */
  .digital-band {
    background:var(--card-bg); border:1px solid rgba(215,161,61,0.25);
    border-radius:12px; padding:20px; margin:0 0 32px;
  }
  .digital-band-head {
    display:flex; justify-content:space-between; align-items:baseline;
    font-size:14px; font-weight:700; color:#e8eaf0; margin-bottom:8px;
  }
  .digital-band-head .band-score { color:var(--gold); font-size:16px; }
  .digital-band p { font-size:13px; color:#8a9bb0; line-height:1.6; margin:0; }

  /* Report button */
  .btn-report {
    display:block; width:100%; padding:16px;
    background:rgba(215,161,61,0.12); border:1px solid rgba(215,161,61,0.4);
    color:#D7A13D; font-size:16px; font-weight:700; border-radius:10px;
    cursor:pointer; text-align:center; text-decoration:none;
    transition:all .2s;
  }
  .btn-report:hover { background:rgba(215,161,61,0.22); }
  .hidden { display:none; }
  #results { display:none; }
  #results.visible { display:block; }
</style>

<div class="wrap">
  <div style="margin-bottom:28px;">
    <a href="/assess" style="color:#7a8b9e;font-size:13px;text-decoration:none;">← Back to Assess Hub</a>
  </div>

  <h1>Website &amp; Digital Presence Audit</h1>
  <p class="sub">Two parts: an automated website scan + a quick self-report on your social and content presence.</p>

  <!-- ── STEP 1: Automated Scan ── -->
  <div class="step-header">
    <div class="step-num">1</div>
    <div class="step-title">Automated Website Scan</div>
  </div>
  <p class="step-desc">Enter your URL — we'll check performance, Core Web Vitals, and top fix opportunities.</p>

  <div class="url-row">
    <input type="url" id="url-input" placeholder="https://yourwebsite.com" autocomplete="off" />
    <button class="btn-audit" id="btn-audit">Audit</button>
  </div>
  <div class="status" id="status"></div>

  <div id="results">
    <div class="scores" id="scores-grid"></div>
    <div class="vitals" id="vitals-box">
      <h3>Core Web Vitals</h3>
      <div id="vitals-list"></div>
    </div>
    <div class="opps" id="opps-box">
      <h3>Top Opportunities</h3>
      <div id="opps-list"></div>
    </div>
  </div>

  <hr class="section-divider" />

  <!-- ── STEP 2: Social & Content Self-Report ── -->
  <div class="step-header">
    <div class="step-num">2</div>
    <div class="step-title">Social &amp; Content Presence</div>
  </div>
  <p class="step-desc">12 quick questions about your digital footprint beyond the website. Answer Yes / Partial / No.</p>

  <div class="checklist" id="checklist">

    <div class="check-item" data-id="1">
      <span class="check-q">You publish new content (blog, articles, or resources) at least once a month</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="2">
      <span class="check-q">Your website has a dedicated blog, insights, or resources section</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="3">
      <span class="check-q">Your website content (pages, copy) has been updated in the last 6 months</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="4">
      <span class="check-q">Your homepage has a clear, single call-to-action (contact, book, buy, etc.)</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="5">
      <span class="check-q">You are active on at least one social media platform (posting 3+ times per week)</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="6">
      <span class="check-q">Your social media profiles link back to your website</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="7">
      <span class="check-q">You produce video content (YouTube, Reels, TikTok, or similar)</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="8">
      <span class="check-q">Your Google Business Profile is complete, verified, and regularly updated</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="9">
      <span class="check-q">You actively collect customer reviews and respond to them</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="10">
      <span class="check-q">You have an email newsletter or actively collect email subscribers</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="11">
      <span class="check-q">You track website analytics and review them at least monthly (GA4, Plausible, etc.)</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

    <div class="check-item" data-id="12">
      <span class="check-q">You run paid digital advertising (Google Ads, Meta Ads, or other channels)</span>
      <div class="check-btns">
        <button class="chk" data-v="2">Yes</button>
        <button class="chk" data-v="1">Partial</button>
        <button class="chk" data-v="0">No</button>
      </div>
    </div>

  </div><!-- /checklist -->

  <div class="social-actions">
    <button class="btn-social-save" id="btn-social-save">Save Answers</button>
    <span class="social-saved-msg" id="social-saved-msg">✓ Saved</span>
  </div>
  <div class="social-score-row" id="social-score-row" style="display:none;">
    Social &amp; Content score: <span id="social-score-val">—</span> / 100
  </div>

  <!-- ── Combined Website & Digital score band ── -->
  <div class="digital-band" id="digital-band" style="display:none;">
    <div class="digital-band-head">
      <span>Website &amp; Digital score: <span id="digital-band-label"></span></span>
      <span class="band-score" id="digital-band-score">—</span>
    </div>
    <p id="digital-band-text"></p>
  </div>

  <!-- ── Generate Report ── -->
  <a class="btn-report" href="/assess/report" id="btn-report">
    Generate AI Report →
  </a>
</div>

<script>
  /* ── Scoring bands (shared scale with the Business track) ── */
  const DIGITAL_BANDS = [
    { min: 0,  max: 25,  label: 'Starting out' },
    { min: 26, max: 50,  label: 'Developing' },
    { min: 51, max: 75,  label: 'Established' },
    { min: 76, max: 100, label: 'Advanced' },
  ];
  const DIGITAL_INTERPRETATIONS = {
    'Starting out':
      'Your digital presence is at an early stage, so most potential customers never find you. ' +
      'Start with the basics: page speed, one clear call-to-action, and a complete Google Business Profile.',
    'Developing':
      'The foundation exists but it is patchy. ' +
      'Fixing the weakest scores — usually page speed or publishing rhythm — will move you faster than adding anything new.',
    'Established':
      'Your website and channels work, and the remaining gaps are polish rather than plumbing. ' +
      'Regular content and collecting customer reviews are the likely next wins.',
    'Advanced':
      'Your digital presence is strong across the board. ' +
      'Keep the publishing rhythm and focus on converting the traffic you already earn.',
  };

  function getDigitalBand(score) {
    const s = Math.max(0, Math.min(100, Math.round(score)));
    return DIGITAL_BANDS.find(b => s >= b.min && s <= b.max) || DIGITAL_BANDS[0];
  }

  /* Combined score: 60% PageSpeed average + 40% social self-report.
     If only one part exists, use it alone. Returns null when neither exists. */
  function computeDigitalScore() {
    let ps = null;
    try {
      const web = JSON.parse(localStorage.getItem('ahoosh_assess_website') || 'null');
      if (web && web.scores) {
        const vals = Object.values(web.scores).filter(v => typeof v === 'number');
        if (vals.length) ps = vals.reduce((a, b) => a + b, 0) / vals.length;
      }
    } catch {}
    let social = null;
    const keys = Object.keys(answers);
    if (keys.length > 0) {
      const total = keys.reduce((acc, k) => acc + parseInt(answers[k]), 0);
      social = Math.round(total / 24 * 100);
    }
    if (ps !== null && social !== null) return Math.round(0.6 * ps + 0.4 * social);
    if (ps !== null) return Math.round(ps);
    if (social !== null) return social;
    return null;
  }

  function renderDigitalBand() {
    const score = computeDigitalScore();
    const box = document.getElementById('digital-band');
    if (score === null || !box) return;
    const band = getDigitalBand(score);
    document.getElementById('digital-band-score').textContent = score + ' / 100';
    document.getElementById('digital-band-label').textContent = band.label;
    document.getElementById('digital-band-text').textContent = DIGITAL_INTERPRETATIONS[band.label];
    box.style.display = 'block';
  }

  /* ── PageSpeed audit ── */
  const input   = document.getElementById('url-input');
  const btn     = document.getElementById('btn-audit');
  const status  = document.getElementById('status');
  const results = document.getElementById('results');

  function scoreColor(n) {
    if (n >= 90) return 'score-green';
    if (n >= 50) return 'score-orange';
    return 'score-red';
  }

  function renderScores(scores) {
    const labels = { performance:'Performance', accessibility:'Accessibility', seo:'SEO', best_practices:'Best Practices' };
    document.getElementById('scores-grid').innerHTML = Object.entries(scores).map(([k,v]) =>
      `<div class="score-card">
        <div class="score-num ${scoreColor(v)}">${v}</div>
        <div class="score-label">${labels[k]||k}</div>
      </div>`
    ).join('');
  }

  function renderVitals(vitals) {
    const labels = { lcp:'Largest Contentful Paint', cls:'Cumulative Layout Shift', fid:'Total Blocking Time', fcp:'First Contentful Paint', ttfb:'Time to First Byte', speed_index:'Speed Index' };
    document.getElementById('vitals-list').innerHTML = Object.entries(vitals)
      .filter(([,v]) => v)
      .map(([k,v]) => `<div class="vital-row"><span>${labels[k]||k}</span><span class="vital-val">${v}</span></div>`)
      .join('');
  }

  function renderOpps(opps) {
    const el = document.getElementById('opps-list');
    if (!opps.length) { el.innerHTML = '<p style="color:#5e6e82;font-size:13px;margin:0;">No major issues found.</p>'; return; }
    el.innerHTML = opps.map(o => `<div class="opp"><strong>${o.title}</strong>${o.savings ? o.savings : ''}</div>`).join('');
  }

  btn.addEventListener('click', async () => {
    const url = input.value.trim();
    if (!url) { status.textContent = 'Enter a URL first.'; return; }
    try { new URL(url); } catch { status.textContent = 'Invalid URL — include https://'; return; }

    btn.disabled = true;
    results.classList.remove('visible');
    status.textContent = 'Scanning your site… heavy sites can take up to a minute.';
    var tick = setTimeout(function(){ status.textContent = 'Still scanning… almost there (larger sites take a little longer).'; }, 22000);

    async function runAudit(attempt) {
      var ctrl = new AbortController();
      var to = setTimeout(function(){ ctrl.abort(); }, 75000); // patient client timeout > server's 55s run
      try {
        const res  = await fetch(`/api/pagespeed?url=${encodeURIComponent(url)}`, { signal: ctrl.signal });
        clearTimeout(to);
        const data = await res.json();

        if (!data.ok) {
          if (attempt < 2) { status.textContent = 'The scan service was busy — retrying once…'; return runAudit(attempt + 1); }
          status.textContent = 'Audit failed: ' + (data.error || 'the scan service is busy. Please try again in a moment.');
          return;
        }

        localStorage.setItem('ahoosh_assess_website', JSON.stringify({
          url: data.url,
          strategy: data.strategy,
          scores: data.scores,
          vitals: data.vitals,
          opportunities: data.opportunities,
          audited_at: data.fetched_at,
        }));

        renderScores(data.scores);
        renderVitals(data.vitals);
        renderOpps(data.opportunities || []);
        results.classList.add('visible');
        status.textContent = '✓ Audit complete. Review your scores below, then fill Step 2.';
        renderDigitalBand();
      } catch (e) {
        clearTimeout(to);
        if (attempt < 2) { status.textContent = 'The scan timed out — retrying once…'; return runAudit(attempt + 1); }
        status.textContent = 'The scan is taking too long right now. Please try again in a minute — or continue with Step 2 and run the scan later.';
      }
    }

    try { await runAudit(1); } finally { clearTimeout(tick); btn.disabled = false; }
  });

  /* Pre-fill URL from previous session */
  var prev = localStorage.getItem('ahoosh_assess_website');
  if (prev) {
    try { var p = JSON.parse(prev); if (p.url) input.value = p.url; } catch {}
  }

  /* ── Social checklist ── */
  var answers = {}; // { qId: value 0|1|2 }

  /* Load saved answers */
  var savedSocial = localStorage.getItem('ahoosh_assess_social');
  if (savedSocial) {
    try {
      var ss = JSON.parse(savedSocial);
      if (ss.answers) answers = ss.answers;
    } catch {}
  }

  /* Render saved state on load */
  function applyAnswers() {
    document.querySelectorAll('.check-item').forEach(function(item) {
      var id = item.getAttribute('data-id');
      var val = answers[id];
      if (val === undefined || val === null) return;
      item.classList.add('answered');
      item.querySelectorAll('.chk').forEach(function(btn) {
        btn.classList.remove('sel-yes','sel-part','sel-no');
        if (parseInt(btn.getAttribute('data-v')) === parseInt(val)) {
          if (val == 2) btn.classList.add('sel-yes');
          else if (val == 1) btn.classList.add('sel-part');
          else btn.classList.add('sel-no');
        }
      });
    });
    updateScoreDisplay();
  }

  function updateScoreDisplay() {
    var keys = Object.keys(answers);
    if (keys.length === 0) return;
    var total = keys.reduce(function(acc, k) { return acc + parseInt(answers[k]); }, 0);
    var pct = Math.round(total / 24 * 100);
    var scoreRow = document.getElementById('social-score-row');
    document.getElementById('social-score-val').textContent = pct;
    scoreRow.style.display = 'block';
    renderDigitalBand();
  }

  /* Button click handling */
  document.getElementById('checklist').addEventListener('click', function(e) {
    var btn = e.target.closest('.chk');
    if (!btn) return;
    var item = btn.closest('.check-item');
    var id   = item.getAttribute('data-id');
    var val  = parseInt(btn.getAttribute('data-v'));

    answers[id] = val;
    item.classList.add('answered');

    item.querySelectorAll('.chk').forEach(function(b) {
      b.classList.remove('sel-yes','sel-part','sel-no');
    });
    if (val === 2) btn.classList.add('sel-yes');
    else if (val === 1) btn.classList.add('sel-part');
    else btn.classList.add('sel-no');

    updateScoreDisplay();
  });

  /* Save button */
  document.getElementById('btn-social-save').addEventListener('click', function() {
    var keys = Object.keys(answers);
    var total = keys.reduce(function(acc, k) { return acc + parseInt(answers[k]); }, 0);
    var pct   = Math.round(total / 24 * 100);
    var digitalScore = computeDigitalScore();
    var payload = {
      answers: answers,
      score: pct,
      answered: keys.length,
      digital_score: digitalScore,
      digital_band: digitalScore === null ? null : getDigitalBand(digitalScore).label,
      completed_at: new Date().toISOString(),
    };
    try {
      localStorage.setItem('ahoosh_assess_social', JSON.stringify(payload));
      var msg = document.getElementById('social-saved-msg');
      msg.style.display = 'inline';
      setTimeout(function() { msg.style.display = 'none'; }, 2000);
    } catch(e) {}
    updateScoreDisplay();
  });

  applyAnswers();
</script>
</BaseLayout>
