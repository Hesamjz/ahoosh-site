---
import BaseLayout from '../layouts/BaseLayout.astro';

const updated = '21 July 2026';

const processors = [
  ['Cloudflare', 'Hosting, security and database', 'Page requests, IP address, saved assessment records'],
  ['Cloudflare Workers AI', 'Writes the read of your personality result', 'Your assessment scores and answers'],
  ['Anthropic (Claude)', 'Writes the business report and Q&A answers', 'Your business assessment inputs'],
  ['Brevo', 'Sends your results email; holds the mailing list', 'Your email address and name'],
  ['Resend', 'Sends contact-form emails', 'Your contact-form details'],
  ['Google PageSpeed Insights', 'Measures the site you submit for scanning', 'The URL you enter'],
  ['Tawk.to', 'Live chat widget', 'Your chat messages'],
  ['Google Fonts', 'Serves the fonts on this site', 'Your IP address'],
  ['Lemon Squeezy', 'Merchant of record for purchases', 'Your payment and billing details'],
];

const toc = [
  ['what-we-collect', 'What we collect and why'],
  ['cookies', 'Cookies and similar technologies'],
  ['assessments', 'The assessments'],
  ['who-we-share-with', 'Who we share it with'],
  ['international-transfers', 'International transfers'],
  ['legal-basis', 'Our legal basis'],
  ['security', 'Data security'],
  ['retention', 'How long we keep it'],
  ['your-rights', 'Your rights'],
  ['children', 'Children'],
  ['changes', 'Changes and questions'],
];
---

<BaseLayout
  title="Privacy Policy"
  description="What ahoosh.ai collects — including assessment answers — where it goes, why, how it is secured, and your rights under the GDPR."
>
  <section class="legal">
    <div class="legal-wrap">

      <header class="legal-head">
        <h1>Privacy Policy</h1>
        <p class="legal-updated">Last updated: {updated}</p>
      </header>

      <p class="legal-lede">
        This policy sets out what data ahoosh.ai collects, why, who we share it with, and what
        you can ask us to do about it. We do not sell your data, and we do not run advertising
        trackers. If anything here is unclear, one email answers it:
        <a class="inline" href="mailto:contact@ahoosh.ai">contact@ahoosh.ai</a>.
      </p>

      <nav class="legal-toc" aria-label="On this page">
        <span class="legal-toc-title">On this page</span>
        <ol>
          {toc.map(([id, label]) => <li><a href={`#${id}`}>{label}</a></li>)}
        </ol>
      </nav>

      <article class="legal-body">

        <h2 id="what-we-collect">What we collect and why</h2>
        <p>
          Our principle is to collect only what the thing you asked for actually needs. In practice
          that means four categories.
        </p>

        <h3>Assessment answers and results</h3>
        <p>
          When you complete an assessment, we hold the answers you gave, the scores calculated from
          them, and the written interpretation produced for you. This is what lets us show you a
          result and email you a copy. Answers to the personality and leadership assessments are
          <strong>psychological data</strong>, which the law treats as sensitive — the section below
          explains exactly how we handle them.
        </p>

        <h3>Things you submit to the tools</h3>
        <p>
          The website assessment and SEO tool take the URL you enter and return what the scan finds.
          The business assessment and Business Q&amp;A take what you type about your company.
        </p>

        <h3>Contact details</h3>
        <p>
          Your email address, and optionally your name, when you ask to receive results or use the
          contact form. The contact form also takes your company and your message, so we can reply
          usefully.
        </p>

        <h3>Technical data</h3>
        <p>
          Your IP address, logged by Cloudflare to keep the site up and block abuse, and stored
          alongside an assessment record when one is saved. If you use the chat widget, the
          conversation is handled by Tawk.to.
        </p>

        <h2 id="cookies">Cookies and similar technologies</h2>
        <p>
          We do not use advertising or tracking cookies, and we run no ad networks on this site. The
          site sets only what it needs to function: a small number of functional cookies from
          Cloudflare for security, and — only if you open it — a session cookie from Tawk.to for the
          chat widget. Google Fonts loads fonts directly from Google's servers, which sees your IP
          address for that request alone. None of this is used to build a profile of you or to track
          you across other sites.
        </p>

        <h2 id="assessments">The assessments</h2>

        <div class="legal-callout">
          <p>
            <strong>They are a self-reflection tool, not a diagnosis.</strong> The personality and
            leadership assessments are informational. They are not clinical, not psychiatric, and not
            a diagnostic instrument. They do not identify any condition, and we do not use them to
            make any decision about you — no screening, no scoring, no automated decision-making.
          </p>
        </div>

        <p>
          <strong>Nothing is stored until you give us your email.</strong> You can take any assessment
          and choose "skip and view results" — in that case nothing about you leaves your browser.
          The moment you enter your email to see or receive the full result is the moment your
          answers, scores and profile are stored and sent to you.
        </p>
        <p>
          <strong>That submission is your explicit consent</strong> to us storing your assessment data
          and emailing it to you. You can withdraw it at any time and we delete everything. Withdrawing
          consent does not affect processing that was lawful before you withdrew it.
        </p>
        <p>
          A copy of your result is delivered to our own inbox, so that we can give you a considered
          read if you ask for one. It is not passed to anyone else.
        </p>

        <h2 id="who-we-share-with">Who we share it with</h2>
        <p>
          We never sell or rent your data, and we use no ad networks or data brokers. We do rely on
          a small number of service providers to run the site. This is all of them — there are no
          others.
        </p>

        <div class="legal-table-scroll">
          <table class="legal-table">
            <thead>
              <tr><th>Provider</th><th>What it does for us</th><th>What it sees</th></tr>
            </thead>
            <tbody>
              {processors.map(([name, does, sees]) => (
                <tr><td class="p-name">{name}</td><td>{does}</td><td>{sees}</td></tr>
              ))}
            </tbody>
          </table>
        </div>

        <p>
          Two of these are AI providers, and we want to be explicit about it: your assessment answers
          are sent to <strong>Cloudflare Workers AI</strong> and <strong>Anthropic</strong> so that the
          written interpretation and business report can be produced. That is the only reason they are
          sent, and they are not used to train anything on our instruction.
        </p>
        <p>
          We may also disclose data where the law compels us to, and we will tell you if that happens
          unless we are legally barred from doing so.
        </p>

        <h2 id="international-transfers">International transfers</h2>
        <p>
          Some of the providers above are based outside the EEA, mainly in the United States. Where
          that is the case, we rely on their Standard Contractual Clauses, or another safeguard
          recognised under the GDPR, as the legal basis for sending data there. You can ask us for
          details of the specific safeguard a given provider uses.
        </p>

        <h2 id="legal-basis">Our legal basis</h2>
        <p>
          We rely on <strong>your explicit consent</strong> for assessment answers, results, and any
          email we send you; on <strong>legitimate interest</strong> for security logging and keeping
          the site running; and on <strong>contract</strong> for whatever is needed to deliver
          something you have bought.
        </p>

        <h2 id="security">Data security</h2>
        <p>
          Traffic to and from the site is encrypted in transit. Each provider we use only receives the
          data it needs to do its job for us, listed plainly in the table above. No system is
          unbreakable — if a breach affecting your data ever happens, we will tell you and, where the
          law requires it, the relevant supervisory authority, without unnecessary delay.
        </p>

        <h2 id="retention">How long we keep it</h2>
        <p>
          Assessment answers and results are kept while they remain useful to you — so you can revisit
          them, and so we can advise you if you ask — and are <strong>deleted on request</strong>,
          without question. Contact messages are kept as long as needed to reply and follow up. Your
          email stays on the list until you unsubscribe. Security logs roll over on Cloudflare's
          schedule. Purchase records are kept as long as tax law requires and no longer.
        </p>

        <h2 id="your-rights">Your rights</h2>
        <p>Under the GDPR you can ask us to:</p>
        <ul>
          <li><strong>Give you access</strong> — a copy of everything we hold on you, assessment answers included.</li>
          <li><strong>Correct</strong> anything that is wrong.</li>
          <li><strong>Erase</strong> your data, including your assessment record.</li>
          <li><strong>Restrict or stop</strong> processing it.</li>
          <li><strong>Port it</strong> — hand it over in a machine-readable file.</li>
          <li><strong>Honour a withdrawal of consent</strong> — at any time, without a reason.</li>
        </ul>
        <p>
          One email to <a class="inline" href="mailto:contact@ahoosh.ai">contact@ahoosh.ai</a> exercises
          any of these. There are no forms and no hoops. You also have the right to complain to a
          data-protection supervisory authority — in the EU, the authority where you live or work; in
          Serbia, the Commissioner for Information of Public Importance and Personal Data Protection.
        </p>

        <h2 id="children">Children</h2>
        <p>
          This site is not directed at anyone under 18, and the assessments are built for adults in a
          business context. We do not knowingly collect data from children. If you believe a child has
          sent us data, email us and we will delete it.
        </p>

        <h2 id="changes">Changes and questions</h2>
        <p>
          If this policy changes we will update it here and change the date at the top, so you can
          always see which version applies. Questions, or anything you want us to do with your data:
          <a class="inline" href="mailto:contact@ahoosh.ai">contact@ahoosh.ai</a>.
        </p>

        <p class="legal-controller">
          Data controller: AHoosh, operated by H. Jafarzadeh, Belgrade, Serbia ·
          <a class="inline" href="mailto:contact@ahoosh.ai">contact@ahoosh.ai</a>
        </p>

      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { padding: 150px 0 120px; position: relative; z-index: 2; }
  .legal-wrap { max-width: 760px; margin: 0 auto; padding: 0 24px; }

  /* Head — quiet, like a document, not a hero */
  .legal-head { border-bottom: 1px solid rgba(240,242,245,.1); padding-bottom: 26px; margin-bottom: 34px; }
  .legal-head h1 {
    font-family: var(--font-head); font-weight: 800;
    font-size: clamp(1.9rem, 4vw, 2.6rem); line-height: 1.1;
    letter-spacing: -.01em; color: var(--silver); margin: 0;
  }
  .legal-updated {
    margin: 12px 0 0; font-size: .8rem; letter-spacing: .02em;
    color: var(--dim, #828ca2);
  }

  .legal-lede {
    font-size: 1.06rem; line-height: 1.8; color: var(--silver);
    margin: 0 0 36px;
  }

  /* Table of contents */
  .legal-toc {
    border: 1px solid rgba(240,242,245,.1); border-radius: 12px;
    background: rgba(7,22,40,.45); padding: 22px 26px; margin: 0 0 52px;
  }
  .legal-toc-title {
    display: block; font-family: var(--font-head); font-weight: 700;
    text-transform: uppercase; letter-spacing: .18em; font-size: .62rem;
    color: var(--gold); margin-bottom: 14px;
  }
  .legal-toc ol { margin: 0; padding: 0; list-style: none; counter-reset: toc; }
  .legal-toc li { counter-increment: toc; margin: 0 0 9px; }
  .legal-toc li:last-child { margin-bottom: 0; }
  .legal-toc li::before {
    content: counter(toc) '.'; color: var(--gold); opacity: .55;
    font-size: .82rem; margin-right: 10px;
  }
  .legal-toc a {
    color: var(--silver-dim, #cdd6e6); font-size: .92rem;
    border-bottom: 1px solid transparent; transition: color .25s, border-color .25s;
  }
  .legal-toc a:hover { color: var(--gold-light, #f4d98b); border-color: rgba(215,161,61,.4); }

  /* Body */
  .legal-body p { color: var(--silver-dim); font-size: 1rem; line-height: 1.85; margin: 0 0 20px; }
  .legal-body h2 {
    font-family: var(--font-head); font-weight: 800;
    font-size: 1.24rem; line-height: 1.25; letter-spacing: .01em;
    color: var(--silver); margin: 58px 0 20px;
    padding-top: 22px; border-top: 1px solid rgba(240,242,245,.08);
  }
  .legal-body h3 {
    font-family: var(--font-body, inherit); font-weight: 700;
    font-size: 1rem; color: var(--silver); margin: 30px 0 10px;
  }
  .legal-body ul { list-style: none; margin: 0 0 22px; padding: 0; }
  .legal-body li {
    position: relative; color: var(--silver-dim); font-size: 1rem;
    line-height: 1.8; padding-left: 22px; margin-bottom: 10px;
  }
  .legal-body li::before {
    content: ''; position: absolute; left: 0; top: .78em;
    width: 5px; height: 5px; border-radius: 50%; background: var(--gold); opacity: .8;
  }
  .legal-body strong { color: var(--silver); font-weight: 600; }
  .legal-body a.inline, .legal-body a:not(.inline) {
    color: var(--gold-light, #f4d98b); border-bottom: 1px solid rgba(215,161,61,.35);
    transition: color .25s, border-color .25s;
  }
  .legal-body a:hover { color: var(--silver); border-color: var(--silver); }

  /* Callout — used once, for the thing that actually matters */
  .legal-callout {
    border-left: 2px solid var(--gold);
    background: rgba(215,161,61,.05);
    padding: 20px 24px; margin: 26px 0 28px; border-radius: 0 10px 10px 0;
  }
  .legal-callout p { margin: 0; font-size: .98rem; }

  /* Processor table */
  .legal-table-scroll { overflow-x: auto; margin: 26px 0 28px; }
  .legal-table {
    width: 100%; border-collapse: collapse; font-size: .9rem; min-width: 520px;
  }
  .legal-table th {
    text-align: left; font-family: var(--font-head); font-weight: 700;
    text-transform: uppercase; letter-spacing: .12em; font-size: .6rem;
    color: var(--gold); padding: 0 18px 12px 0;
    border-bottom: 1px solid rgba(215,161,61,.25);
  }
  .legal-table td {
    padding: 15px 18px 15px 0; color: var(--silver-dim);
    line-height: 1.6; border-bottom: 1px solid rgba(240,242,245,.07);
    vertical-align: top;
  }
  .legal-table td.p-name { color: var(--silver); font-weight: 600; white-space: nowrap; }
  .legal-table tr:last-child td { border-bottom: none; }

  .legal-controller {
    margin-top: 50px; padding-top: 24px;
    border-top: 1px solid rgba(240,242,245,.1);
    font-size: .84rem !important; color: var(--dim, #828ca2) !important;
  }

  @media (max-width: 820px) {
    .legal { padding: 120px 0 80px; }
    .legal-wrap { padding: 0 20px; }
    .legal-toc { padding: 18px 20px; margin-bottom: 40px; }
    .legal-body h2 { margin-top: 44px; }
  }
</style>
