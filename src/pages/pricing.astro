---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Access Plans"
  description="AHoosh data and research access plans are in development. Contact AHoosh directly for consulting, research, or data support."
>

  <section style="background:linear-gradient(160deg,#03142E 0%,#010A18 100%);padding:130px 24px 80px;text-align:center;min-height:60vh;display:flex;align-items:center;">
    <div style="max-width:540px;margin:0 auto;">
      <div class="section-eyebrow" style="margin-bottom:14px;">Access Plans</div>
      <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(24px,5vw,36px);color:var(--silver);margin:0 0 20px;line-height:1.3;">
        Coming Later
      </h1>
      <p style="font-size:15px;color:var(--silver-dim);line-height:1.8;margin-bottom:32px;">
        AHoosh is currently developing its data and research access model.
        Pricing is not public yet.
      </p>
      <p style="font-size:14px;color:var(--silver-dim);line-height:1.7;margin-bottom:36px;">
        For consulting, research, or custom data support,
        contact AHoosh directly.
      </p>
      <a href="/contact" class="btn-primary" style="display:inline-block;min-width:220px;">Contact AHoosh</a>
    </div>
  </section>

</BaseLayout>
