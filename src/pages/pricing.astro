---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pricing"
  description="Simple, transparent pricing for AHoosh AI consulting and the AHM-Hub markets platform. Start free, scale when you're ready."
>

  <!-- Hero -->
  <section style="background:linear-gradient(160deg,#03142E 0%,#010A18 100%);padding:56px 24px 40px;text-align:center;">
    <div class="section-eyebrow" style="margin-bottom:10px;">Pricing</div>
    <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(26px,5vw,40px);color:var(--silver);margin:0 0 12px;line-height:1.2;">
      Invest once. Compound forever.
    </h1>
    <p style="font-size:15px;color:var(--silver-dim);max-width:520px;margin:0 auto;line-height:1.7;">
      All plans include access to live FX, gold, and crypto data for MENA, Balkans, and EU operators.
      AI strategy outputs scale with your tier.
    </p>
  </section>

  <!-- Pricing cards -->
  <div style="max-width:960px;margin:0 auto;padding:40px 24px 64px;">

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;align-items:start;">

      <!-- Operator -->
      <div style="
        background:rgba(255,255,255,0.04);
        border:1px solid rgba(215,161,61,0.15);
        border-radius:8px;
        padding:28px 24px;
      ">
        <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--silver-dim);margin-bottom:8px;">Operator</div>
        <div style="font-family:var(--font-head);font-size:36px;font-weight:700;color:var(--gold);line-height:1;margin-bottom:4px;">$19<span style="font-size:16px;font-weight:400;color:var(--silver-dim)">/mo</span></div>
        <p style="font-size:12px;color:var(--silver-muted);margin:0 0 24px;">For active cross-border operators who need real data.</p>
        <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Real-time FX, gold, and crypto data</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> 5 AI Strategy outputs/month (SWOT, BMC)</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> 5 custom watchlists</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Forum verified-operator badge</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> MENA + Balkans + EU corridor data</li>
        </ul>
        <a href="/contact" class="btn-primary" style="width:100%;display:block;text-align:center;box-sizing:border-box;">Get Started</a>
      </div>

      <!-- Pro — highlighted -->
      <div style="
        background:rgba(215,161,61,0.06);
        border:1px solid rgba(215,161,61,0.4);
        border-radius:8px;
        padding:28px 24px;
        position:relative;
      ">
        <div style="
          position:absolute;top:-12px;left:50%;transform:translateX(-50%);
          background:var(--gold);color:#010A18;
          font-family:var(--font-head);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
          padding:4px 14px;border-radius:20px;white-space:nowrap;
        ">Most Popular</div>
        <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">Pro</div>
        <div style="font-family:var(--font-head);font-size:36px;font-weight:700;color:var(--gold);line-height:1;margin-bottom:4px;">$79<span style="font-size:16px;font-weight:400;color:var(--silver-dim)">/mo</span></div>
        <p style="font-size:12px;color:var(--silver-muted);margin:0 0 24px;">For founders and consultants building market-entry strategies.</p>
        <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Everything in Operator</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> 20 AI Strategy outputs/month</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Full PESTEL + Market-Entry plans</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> 36-month financial projections</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> 3 country deep-dives/month</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Priority forum support</li>
        </ul>
        <a href="/contact" class="btn-primary" style="width:100%;display:block;text-align:center;box-sizing:border-box;background:var(--gold);color:#010A18;">Get Started</a>
      </div>

      <!-- Business -->
      <div style="
        background:rgba(255,255,255,0.04);
        border:1px solid rgba(215,161,61,0.15);
        border-radius:8px;
        padding:28px 24px;
      ">
        <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--silver-dim);margin-bottom:8px;">Business</div>
        <div style="font-family:var(--font-head);font-size:36px;font-weight:700;color:var(--gold);line-height:1;margin-bottom:4px;">$299<span style="font-size:16px;font-weight:400;color:var(--silver-dim)">/mo</span></div>
        <p style="font-size:12px;color:var(--silver-muted);margin:0 0 24px;">For teams and agencies running cross-border operations at scale.</p>
        <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Everything in Pro</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Unlimited AI Strategy outputs</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> API access for data + AI outputs</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> 5 team seats</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> White-label PDF reports</li>
          <li style="font-size:13px;color:var(--silver-dim);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">✓</span> Slack / Teams webhook</li>
        </ul>
        <a href="/contact" class="btn-primary" style="width:100%;display:block;text-align:center;box-sizing:border-box;">Get Started</a>
      </div>

    </div>

    <!-- Free tier note -->
    <div style="text-align:center;margin-top:32px;padding:20px;border:1px solid rgba(215,161,61,0.1);border-radius:6px;background:rgba(255,255,255,0.02);">
      <div style="font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--silver);margin-bottom:4px;">Free tier also available</div>
      <div style="font-size:12px;color:var(--silver-muted);">15-minute delayed data · 1 SWOT/month · Forum read + post access · No credit card required</div>
    </div>

    <!-- Waitlist CTA -->
    <div style="text-align:center;margin-top:20px;">
      <p style="font-size:13px;color:var(--silver-muted);">
        Platform launching soon —
        <a href="/contact" style="color:var(--gold);text-decoration:underline;text-underline-offset:3px;">join the waitlist</a>
        to get early access.
      </p>
    </div>

    <!-- FAQ strip -->
    <div style="margin-top:56px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:24px;text-align:center;">Common Questions</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
        <div>
          <div style="font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--silver);margin-bottom:6px;">Can I cancel anytime?</div>
          <div style="font-size:12px;color:var(--silver-dim);line-height:1.6;">Yes. Monthly plans, no contracts, no cancellation fees.</div>
        </div>
        <div>
          <div style="font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--silver);margin-bottom:6px;">Do you offer a trial?</div>
          <div style="font-size:12px;color:var(--silver-dim);line-height:1.6;">14-day free trial on all paid plans. No credit card until you decide to stay.</div>
        </div>
        <div>
          <div style="font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--silver);margin-bottom:6px;">What currencies can I pay in?</div>
          <div style="font-size:12px;color:var(--silver-dim);line-height:1.6;">USD primary. USDT and BTC accepted via crypto. EUR pricing available for EU customers.</div>
        </div>
        <div>
          <div style="font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--silver);margin-bottom:6px;">Is AHoosh consulting included?</div>
          <div style="font-size:12px;color:var(--silver-dim);line-height:1.6;">No — platform and consulting are separate. Hub users get priority access to consulting slots at a discount. <a href="/consulting" style="color:var(--gold);">See consulting →</a></div>
        </div>
      </div>
    </div>

    <!-- Consulting bridge CTA -->
    <div style="margin-top:48px;background:rgba(215,161,61,0.07);border:1px solid rgba(215,161,61,0.2);border-radius:8px;padding:28px;text-align:center;">
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:6px;">Need something beyond the platform?</div>
      <div style="font-size:13px;color:var(--silver-dim);margin-bottom:20px;max-width:480px;margin-left:auto;margin-right:auto;">AHoosh consulting bridges the gap — take the AI-generated strategy and operationalize it with a human expert who's lived the cross-border B2B life.</div>
      <a href="/consulting" class="btn-primary">See Consulting Services</a>
    </div>

  </div>

</BaseLayout>
