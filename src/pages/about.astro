---
import BaseLayout from '../layouts/BaseLayout.astro';
// Phase 2 — About: founder-forward page with aurora 3D, circle-reveal portrait,
// and a horizontal PINNED career timeline. Spec: Part II → PAGE 2 (Segments A–D).
const timeline = [
  { date: '2010–2014', title: 'Operations & industry roots', body: 'Started in operations and project work across industries — learning how companies actually run, and where they waste effort.' },
  { date: '2014–2018', title: 'E-commerce & digital', body: 'Moved into e-commerce and digital operations: catalogues, channels, and the messy reality of selling at scale.' },
  { date: '2018–2022', title: 'Digital transformation & BD', body: '12+ years in, leading transformation and business development across different markets — turning manual processes into systems.' },
  { date: '2022–2024', title: 'Founded AHoosh · PhD begins', body: 'Founded AHoosh and began a PhD in Software Engineering & E-Business at the University of Belgrade (Faculty of Organizational Sciences).' },
  { date: '2024–Now', title: 'AHoosh.ai · research', body: 'Building an AI-augmented consulting practice, with peer-reviewed Springer publications on AI in B2B e-business.' },
];
const values = [
  { t: 'Clarity before motion', d: 'Decisions fail from acting before the picture is clear. The work starts by making it clear.' },
  { t: 'Directness', d: 'No pitch theatre, no generic decks. A straight conversation about what you actually need.' },
  { t: 'Practicality', d: 'Research without action is wasted. Every engagement ends with something you can use.' },
  { t: 'Research-first', d: 'AI tools, market data and proper method — combined, not as buzzwords.' },
];
---

<BaseLayout
  title="About"
  description="Hesam Jafarzadeh — researcher, consultant, and operator. Founder of AHoosh.ai, PhD researcher in Software Engineering and E-Business at the University of Belgrade, combining AI tools, market data, research methods, and practical business experience."
>
  <!-- ══ SEGMENT A — HERO PORTRAIT ══ -->
  <section class="s-about-hero" style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 24px;position:relative;">
    <div class="about-role-tag" style="display:inline-block;background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:600;letter-spacing:0.08em;padding:6px 14px;border-radius:999px;margin-bottom:24px;">Founder · Researcher · Consultant</div>
    <h1 class="about-hero-name" style="font-family:var(--font-head);font-weight:700;font-size:clamp(36px,8vw,80px);letter-spacing:-0.03em;line-height:1;color:var(--silver);margin-bottom:32px;text-shadow:0 2px 30px rgba(0,0,0,0.5);">Hesam Jafarzadeh</h1>
    <div class="hero-portrait" style="width:180px;height:180px;border-radius:50%;overflow:hidden;border:2px solid rgba(215,161,61,0.45);box-shadow:0 0 40px rgba(215,161,61,0.2);margin-bottom:28px;clip-path:circle(50%);">
      <img src="/assets/hesam.png" alt="Hesam Jafarzadeh" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;" onerror="this.parentElement.style.display='none';" />
    </div>
    <p class="hero-intro-text" style="font-size:clamp(15px,2.2vw,18px);line-height:1.75;color:var(--silver-dim);max-width:560px;">Researcher, consultant and operator with 15+ years across industries. AHoosh is my attempt at a new kind of consulting practice — AI tools, market data and research, applied to real decisions.</p>
    <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--silver-muted);">The path ↓</div>
  </section>

  <!-- ══ SEGMENT B — HORIZONTAL PINNED CAREER TIMELINE ══ -->
  <section class="timeline-wrapper" style="width:100vw;overflow:hidden;position:relative;">
    <div class="timeline-track" style="display:flex;width:500vw;">
      {timeline.map((stop) => (
        <div class="timeline-stop" style="width:100vw;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 24px;">
          <div style="max-width:520px;">
            <div class="timeline-date" style="font-family:var(--font-head);font-weight:700;font-size:clamp(28px,5vw,52px);color:var(--gold);letter-spacing:-0.02em;margin-bottom:16px;">{stop.date}</div>
            <div class="timeline-title" style="font-family:var(--font-head);font-weight:600;font-size:clamp(20px,3vw,30px);color:var(--silver);margin-bottom:16px;">{stop.title}</div>
            <div class="timeline-body" style="font-size:15px;line-height:1.8;color:var(--silver-dim);">{stop.body}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ SEGMENT C — VALUES + WORKING STYLE ══ -->
  <section class="s-values" style="min-height:120vh;display:flex;flex-direction:column;justify-content:center;padding:80px 24px;max-width:1000px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <div class="values-eyebrow section-eyebrow">How I work</div>
      <h2 class="values-heading section-title" style="font-size:clamp(26px,4vw,40px);">What the practice runs on</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:18px;margin-bottom:56px;">
      {values.map((v) => (
        <div class="value-item card-dark" style="padding:26px;">
          <div style="font-family:var(--font-head);font-weight:600;font-size:16px;color:var(--silver);margin-bottom:10px;">{v.t}</div>
          <div style="font-size:13px;line-height:1.65;color:var(--silver-dim);">{v.d}</div>
        </div>
      ))}
    </div>
    <div class="working-style-section" style="max-width:680px;margin:0 auto;text-align:center;">
      <p style="font-size:15px;line-height:1.85;color:var(--silver-dim);margin-bottom:16px;">AHoosh is not an agency — it is a founder-led practice. You get direct access to me and a focused team assembled for your context. Each engagement starts from the actual problem and ends with something practical.</p>
      <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:20px;">
        {['CBAP','PhD researcher · Belgrade','Springer publications','15+ years','AI & market intelligence'].map((p) => (
          <span style="background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:500;padding:6px 12px;border-radius:999px;">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ SEGMENT D — CTA ══ -->
  <section class="s-about-cta" style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:0 24px;">
    <div style="max-width:560px;">
      <h2 class="about-cta-text" style="font-family:var(--font-head);font-weight:700;font-size:clamp(28px,6vw,52px);letter-spacing:-0.025em;line-height:1.1;color:var(--silver);margin-bottom:28px;">Let's work together</h2>
      <div style="display:flex;flex-direction:column;gap:14px;align-items:center;">
        <a href="/contact" class="contact-btn btn-primary" style="min-width:240px;">Contact AHoosh</a>
        <a href="https://www.linkedin.com/in/hesam-jafarzadeh-43697679" target="_blank" rel="noopener" class="download-cv link-gold" style="font-size:13px;">View full background on LinkedIn →</a>
      </div>
    </div>
  </section>

  <script>
    import { SceneManager } from '../3d/core/SceneManager';
    import { createAboutScene } from '../3d/scenes/SceneAbout';
    import { initAboutScroll } from '../scripts/about-scroll';

    const start = () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const canvas = document.getElementById('canvas-3d');
      if (!reduced && canvas instanceof HTMLCanvasElement && SceneManager.isWebGLAvailable()) {
        try {
          const sm = SceneManager.getInstance();
          sm.mount(canvas);
          sm.loadScene('about', createAboutScene);
        } catch (e) {
          console.warn('[about] 3D scene skipped:', e);
        }
      }
      initAboutScroll();
    };

    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 1500 });
    } else {
      setTimeout(start, 400);
    }
  </script>
</BaseLayout>
