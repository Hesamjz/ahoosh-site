---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="The founder behind AHoosh — Hesam Jafarzadeh, AI Operations practitioner and PhD Candidate.">

  <!-- Hero -->
  <section style="
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
    padding: 48px 24px 40px;
    text-align: center;
    border-bottom: 1px solid rgba(215,161,61,0.1);
  ">
    <div class="section-eyebrow">About</div>
    <h1 style="
      font-family: var(--font-head);
      font-weight: 700;
      font-size: clamp(24px, 6vw, 36px);
      letter-spacing: -0.01em;
      color: var(--silver);
      margin-bottom: 8px;
    ">The Founder</h1>
    <p style="font-size:14px;color:var(--silver-dim);line-height:1.6;">AHoosh is the practice. Hesam is the practitioner.</p>
  </section>

  <!-- Founder card -->
  <div style="max-width:680px;margin:32px auto 0;padding:0 24px;">
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.15);
      border-radius: 8px;
      overflow: hidden;
    ">
      <!-- Photo -->
      <div style="
        width:100%;height:340px;
        background: linear-gradient(135deg, #03142E 0%, #1a2e50 100%);
        display:flex;align-items:center;justify-content:center;
        border-bottom: 1px solid rgba(215,161,61,0.1);
        overflow: hidden;
      ">
        <img
          src="/assets/hesam.png"
          alt="Hesam Jafarzadeh"
          style="width:100%;height:100%;object-fit:cover;object-position:center 15%;"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
        />
        <div style="
          display:none;
          width:80px;height:80px;border-radius:50%;
          background:rgba(215,161,61,0.15);border:2px solid var(--gold);
          align-items:center;justify-content:center;
          font-family:var(--font-head);font-weight:600;font-size:22px;color:var(--gold);letter-spacing:0.05em;
        ">HJ</div>
      </div>

      <!-- Info -->
      <div style="padding:20px;">
        <div style="font-family:var(--font-head);font-weight:700;font-size:20px;color:var(--silver);margin-bottom:4px;">Hesam Jafarzadeh</div>
        <div style="font-size:13px;color:var(--gold);font-weight:500;letter-spacing:0.04em;margin-bottom:14px;">Founder, AHoosh · PhD Candidate</div>
        <p style="font-size:14px;line-height:1.7;color:var(--silver-dim);">
          I build AI-augmented operations for B2B companies that want to scale without proportional headcount. I work at the intersection of AI tooling, operational design, and the Serbia–Iran–EU business corridor.
        </p>
      </div>
    </div>
  </div>

  <!-- Credentials & Timeline -->
  <div style="padding:0 24px 32px;max-width:680px;margin:0 auto;">

    <!-- Credential pills -->
    <div style="margin-top:32px;">
      <div class="section-eyebrow" style="margin-bottom:12px;">Credentials</div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;">
        <span style="background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:500;padding:6px 12px;border-radius:999px;">PhD Candidate</span>
        <span style="background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:500;padding:6px 12px;border-radius:999px;">AI Operations</span>
        <span style="background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:500;padding:6px 12px;border-radius:999px;">B2B Digital</span>
        <span style="background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:500;padding:6px 12px;border-radius:999px;">Serbia · Iran · EU</span>
        <span style="background:rgba(215,161,61,0.1);border:1px solid rgba(215,161,61,0.25);color:var(--gold-light);font-size:12px;font-weight:500;padding:6px 12px;border-radius:999px;">10+ Years Field</span>
      </div>
    </div>

    <!-- Timeline -->
    <div>
      <div class="section-eyebrow" style="margin-bottom:14px;">Background</div>
      <div style="display:flex;flex-direction:column;gap:0;">
        <div style="display:flex;gap:14px;margin-bottom:20px;align-items:flex-start;">
          <div style="flex-shrink:0;width:8px;height:8px;border-radius:50%;background:var(--gold);margin-top:5px;"></div>
          <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);"><strong style="color:var(--silver);font-weight:600;">2024–present</strong> — PhD research on AI adoption in emerging-market B2B contexts</div>
        </div>
        <div style="display:flex;gap:14px;margin-bottom:20px;align-items:flex-start;">
          <div style="flex-shrink:0;width:8px;height:8px;border-radius:50%;background:var(--gold);margin-top:5px;"></div>
          <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);"><strong style="color:var(--silver);font-weight:600;">2022–present</strong> — Founded AHoosh, helping companies in Serbia and the region build AI-augmented operations</div>
        </div>
        <div style="display:flex;gap:14px;margin-bottom:20px;align-items:flex-start;">
          <div style="flex-shrink:0;width:8px;height:8px;border-radius:50%;background:var(--gold);margin-top:5px;"></div>
          <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);"><strong style="color:var(--silver);font-weight:600;">10+ years</strong> — B2B operations, digital transformation, and e-commerce across Serbia, Iran, and EU markets</div>
        </div>
        <div style="display:flex;gap:14px;align-items:flex-start;">
          <div style="flex-shrink:0;width:8px;height:8px;border-radius:50%;background:var(--gold);margin-top:5px;"></div>
          <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);"><strong style="color:var(--silver);font-weight:600;">Languages</strong> — Persian (native), English (C1), Serbian (A1 and growing)</div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA band -->
  <section style="
    background: linear-gradient(135deg, rgba(215,161,61,0.08) 0%, rgba(3,20,46,0.6) 100%);
    border-top: 1px solid rgba(215,161,61,0.15);
    padding: 40px 24px;
    text-align: center;
  ">
    <div style="max-width:480px;margin:0 auto;">
      <h2 style="font-family:var(--font-head);font-weight:700;font-size:20px;color:var(--silver);margin-bottom:8px;line-height:1.3;">Work with Hesam</h2>
      <p style="font-size:14px;color:var(--silver-dim);margin-bottom:24px;">30-minute discovery call. No pitch deck. Just a conversation.</p>
      <a href="/contact" class="btn-primary" style="display:inline-block;min-width:200px;">Book a Discovery Call</a>
    </div>
  </section>

</BaseLayout>
