---
import BaseLayout from '../layouts/BaseLayout.astro';
// Phase 2 — Homepage: 600vh scroll-choreographed flagship experience.
// Spec: AHoosh_3D_Interaction_Spec.docx Part II → PAGE 1 (Segments A–G).
// The 3D scene (SceneHomepage) renders on the global #canvas-3d behind content;
// homepage-scroll.ts drives the GSAP/ScrollTrigger choreography. Sections are
// transparent so the particle field / orb / constellation show through.
const services = [
  { key: 'strategy', title: 'Strategy & Research', desc: 'Turn unclear problems into decisions backed by AI-assisted research and market signals.' },
  { key: 'digital', title: 'Digital & Marketing', desc: 'Websites, SEO, content and campaigns that actually move the numbers that matter.' },
  { key: 'ai', title: 'AI Agent Setup', desc: 'Practical AI workflows wired into how your business already runs — not a science project.' },
  { key: 'web', title: 'Build & Run', desc: 'Design, build and operate the digital presence so you can focus on the work.' },
];
---

<BaseLayout
  title="Home"
  description="AHoosh combines AI, market data, research, and practical consulting to help founders and companies understand markets, evaluate opportunities, and act with better information."
>
  <!-- ══ SEGMENT A — HERO ══ -->
  <section class="s-hero" style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:0 24px;text-align:center;position:relative;">
    <div style="max-width:760px;margin:0 auto;">
      <div class="hero-eyebrow section-eyebrow" style="margin-bottom:16px;">Founded by Hesam Jafarzadeh</div>
      <h1 class="hero-h1" style="font-family:var(--font-head);font-weight:700;font-size:clamp(34px,7vw,68px);letter-spacing:-0.03em;line-height:1.05;color:var(--silver);margin-bottom:24px;text-shadow:0 2px 30px rgba(0,0,0,0.5);">AI, Market Data &amp; Research for Better Decisions</h1>
      <p class="hero-subline" style="font-size:clamp(15px,2.2vw,19px);line-height:1.75;color:var(--silver-dim);max-width:560px;margin:0 auto 36px;">AHoosh blends AI tools, market signals and practical research so founders and companies can act with better information.</p>
      <div class="hero-cta" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="/markets" class="btn-primary">Explore Market Data</a>
        <a href="/contact" class="btn-secondary">Request Consultation</a>
      </div>
    </div>
    <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--silver-muted);">Scroll ↓</div>
  </section>

  <!-- ══ SEGMENT B — SERVICES PREVIEW ══ -->
  <section class="s-services" style="min-height:120vh;display:flex;flex-direction:column;justify-content:center;padding:80px 24px;max-width:1080px;margin:0 auto;">
    <div class="services-intro-text" style="margin-bottom:40px;text-align:center;">
      <div class="section-eyebrow">What AHoosh Does</div>
      <h2 class="section-title" style="font-size:clamp(26px,4vw,40px);">Four capabilities, one practice</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:18px;">
      {services.map((s) => (
        <a href="/consulting" class={`service-card service-card--${s.key} card-dark`} style="padding:26px;display:block;text-decoration:none;">
          <div style="font-family:var(--font-head);font-weight:600;font-size:16px;color:var(--silver);margin-bottom:10px;">{s.title}</div>
          <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:14px;">{s.desc}</div>
          <span class="arrow" style="color:var(--gold);font-size:13px;opacity:0.6;display:inline-block;">Learn more →</span>
        </a>
      ))}
    </div>
    <div class="services-cta" style="text-align:center;margin-top:36px;">
      <a href="/consulting" class="link-gold">See all services</a>
    </div>
  </section>

  <!-- ══ SEGMENT C — FOUNDER / PHILOSOPHY ══ -->
  <section class="s-founder" style="min-height:120vh;display:flex;align-items:center;padding:80px 24px;">
    <div style="max-width:920px;margin:0 auto;display:grid;grid-template-columns:minmax(0,1fr);gap:36px;align-items:center;">
      <div class="founder-statement" style="text-align:center;">
        <div class="section-eyebrow">The Philosophy</div>
        <h2 class="section-title" style="font-size:clamp(24px,3.6vw,36px);">Clarity before motion</h2>
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:24px;">
        <div class="founder-photo" style="width:140px;height:140px;border-radius:50%;overflow:hidden;border:2px solid rgba(215,161,61,0.45);box-shadow:0 0 32px rgba(215,161,61,0.18);flex-shrink:0;">
          <img src="/assets/hesam.png" alt="Hesam Jafarzadeh" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;" onerror="this.parentElement.style.display='none';" />
        </div>
        <blockquote class="quote-text" style="font-family:var(--font-head);font-weight:600;font-size:clamp(18px,3vw,26px);line-height:1.5;color:var(--silver);text-align:center;max-width:640px;margin:0;">"Most decisions don't fail from lack of effort — they fail from acting before the picture is clear. My job is to make the picture clear."</blockquote>
        <div class="founder-credentials" style="font-size:13px;color:var(--silver-muted);text-align:center;">Hesam Jafarzadeh · CBAP · PhD researcher, University of Belgrade · 15+ years across industries</div>
      </div>
    </div>
  </section>

  <!-- ══ SEGMENT D — PINNED SERVICE SHOWCASE ══ -->
  <section class="services-showcase" style="height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;overflow:hidden;">
    <div style="max-width:1080px;width:100%;">
      <div class="section-eyebrow" style="text-align:center;">In Depth</div>
      <h2 class="section-title" style="text-align:center;font-size:clamp(24px,4vw,38px);margin-bottom:28px;">How each capability works</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
        {services.map((s) => (
          <div class={`svc-card svc-card--${s.key} card-dark`} style="padding:28px;">
            <div style="font-family:var(--font-head);font-weight:600;font-size:17px;color:var(--silver);margin-bottom:10px;">{s.title}</div>
            <div style="font-size:13px;line-height:1.65;color:var(--silver-dim);">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ SEGMENT E — STATS / SOCIAL PROOF ══ -->
  <section class="s-stats" style="min-height:120vh;display:flex;flex-direction:column;justify-content:center;padding:80px 24px;max-width:980px;margin:0 auto;text-align:center;">
    <div class="section-eyebrow">By the numbers</div>
    <h2 class="section-title" style="font-size:clamp(24px,4vw,38px);margin-bottom:40px;">Experience that compounds</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px;">
      <div>
        <div class="stat-number--1" data-counter="15" data-suffix="+" style="font-family:var(--font-head);font-weight:700;font-size:clamp(34px,7vw,64px);color:var(--gold);">0</div>
        <div style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--silver-muted);margin-top:6px;">Years across industries</div>
      </div>
      <div>
        <div class="stat-number--2" data-counter="40" data-suffix="+" style="font-family:var(--font-head);font-weight:700;font-size:clamp(34px,7vw,64px);color:var(--gold);">0</div>
        <div style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--silver-muted);margin-top:6px;">Published articles</div>
      </div>
      <div>
        <div class="stat-number--3" data-counter="4" data-suffix="" style="font-family:var(--font-head);font-weight:700;font-size:clamp(34px,7vw,64px);color:var(--gold);">0</div>
        <div style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--silver-muted);margin-top:6px;">Languages served</div>
      </div>
    </div>
    <div class="testimonial-card card-dark" style="padding:28px;max-width:620px;margin:0 auto 36px;">
      <div style="font-size:15px;line-height:1.7;color:var(--silver-dim);font-style:italic;">"Hesam turned a vague market question into a decision we could actually act on — fast, and without the usual consulting theatre."</div>
      <div style="font-size:12px;color:var(--gold-light);margin-top:14px;">— Operator, B2B distribution</div>
    </div>
    <div class="logo-strip" style="display:flex;gap:28px;justify-content:center;flex-wrap:wrap;opacity:0.6;">
      {['Research', 'Markets', 'AI Ops', 'Strategy'].map((l) => (
        <span class="logo" style="font-family:var(--font-head);font-size:13px;letter-spacing:0.12em;text-transform:uppercase;color:var(--silver-muted);">{l}</span>
      ))}
    </div>
  </section>

  <!-- ══ SEGMENT F — FINAL CTA ══ -->
  <section class="s-cta" style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:0 24px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <div class="cta-eyebrow section-eyebrow" style="margin-bottom:14px;">Let's talk</div>
      <h2 class="cta-h2" style="font-family:var(--font-head);font-weight:700;font-size:clamp(28px,6vw,52px);letter-spacing:-0.025em;line-height:1.1;color:var(--silver);margin-bottom:18px;">Tell me what you're trying to figure out</h2>
      <p style="font-size:15px;color:var(--silver-dim);margin-bottom:32px;line-height:1.75;">No pitch deck. Just a direct conversation about what you need.</p>
      <div style="display:flex;flex-direction:column;gap:14px;align-items:center;">
        <a href="/contact" class="cta-btn-primary btn-primary" style="min-width:240px;">Contact AHoosh</a>
        <a href="/articles" class="cta-btn-secondary link-gold" style="font-size:13px;">Read the articles instead</a>
      </div>
    </div>
  </section>

  <!--
    Homepage 3D + scroll island (client:idle intent via requestIdleCallback).
    Mounts SceneHomepage on the global #canvas-3d only when WebGL is available
    and reduced-motion is off; the scroll choreography always runs (DOM-only when
    no WebGL). Deferred so it never blocks the LCP (the hero text).
  -->
  <script>
    import { SceneManager } from '../3d/core/SceneManager';
    import { createHomepageScene } from '../3d/scenes/SceneHomepage';
    import { initHomepageScroll } from '../scripts/homepage-scroll';

    const start = () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const canvas = document.getElementById('canvas-3d');
      if (!reduced && canvas instanceof HTMLCanvasElement && SceneManager.isWebGLAvailable()) {
        try {
          const sm = SceneManager.getInstance();
          sm.mount(canvas);
          sm.loadScene('home', createHomepageScene);
        } catch (e) {
          console.warn('[homepage] 3D scene skipped:', e);
        }
      }
      initHomepageScroll();
    };

    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 1500 });
    } else {
      setTimeout(start, 400);
    }
  </script>
</BaseLayout>
