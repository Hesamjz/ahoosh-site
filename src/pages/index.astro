---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
// REDESIGN 2026-06-19 (mont-fort/capital feel): one continuous particle background;
// content "stages" play REAL content as you scroll — latest articles cross-fade
// one→next while sticky, live markets tick on screen. No personal info (that's /about).
const latestArticles = (await getCollection('blog'))
  .filter((p) => !p.data.draft && !/^(fa|de|sr)\//.test(p.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
const artStageVh = latestArticles.length * 62 + 30;
const functions = [
  { href: '/news', tag: 'Live', title: 'News', desc: 'Business news in English, Persian, German and Serbian — refreshed through the day.', accent: '#e0a93f' },
  { href: '/markets', tag: 'Live', title: 'Markets', desc: 'FX, gold and crypto prices, updated every minute.', accent: '#4ea3ff' },
  { href: '/articles', tag: '40+', title: 'Articles', desc: 'Deep-dive analysis for operators and decision-makers.', accent: '#e0a93f' },
  { href: '/assess', tag: 'Free', title: 'Diagnostics', desc: 'AI assessments for your business, website and decision style.', accent: '#46d6c0' },
  { href: '/consulting', tag: 'Work with us', title: 'Consulting', desc: 'Strategy, AI setup and growth — directly with AHoosh.', accent: '#9b7bff' },
];
---

<BaseLayout
  title="Home"
  description="AHoosh brings live market data, business news in four languages, AI-assisted research and practical tools into one place — clear enough to act on."
>
  <!-- ══ HERO — brand sphere + portal headline ══ -->
  <section class="s-hero" style="min-height:92vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:72px 24px 56px;position:relative;">
    <div class="hero-eyebrow" style="font-family:var(--font-head);font-size:12px;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-bottom:28px;">AHoosh.ai</div>
    <canvas class="hero-sphere" id="vc" width="340" height="260" style="cursor:grab;display:block;touch-action:none;width:min(380px,82vw);aspect-ratio:340/260;margin-bottom:28px;filter:drop-shadow(0 0 40px rgba(224,169,63,0.28));"></canvas>
    <h1 class="hero-h1" style="font-family:var(--font-head);font-weight:800;font-size:clamp(34px,7.5vw,72px);letter-spacing:-0.035em;line-height:1.02;color:#fff;margin-bottom:22px;max-width:880px;text-shadow:0 2px 40px rgba(0,0,0,0.6);">Markets, news &amp; research —<br/><span style="color:var(--gold);">clear enough to act on.</span></h1>
    <p class="hero-subline" style="font-size:clamp(15px,2.2vw,19px);line-height:1.7;color:var(--silver-dim);max-width:580px;margin:0 auto 36px;">Live market data, business news in four languages, and AI-assisted research and tools — in one place.</p>
    <div class="hero-cta" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="/news" class="btn-primary" data-magnetic="0.5" style="font-size:15px;padding:14px 28px;will-change:transform;">Explore the News</a>
      <a href="/markets" class="btn-secondary" data-magnetic="0.5" style="font-size:15px;padding:14px 28px;will-change:transform;">Live Markets</a>
    </div>
    <div style="position:absolute;bottom:24px;left:50%;transform:translateX(-50%);font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--silver-muted);">Scroll ↓</div>
  </section>

  <!-- ══ FUNCTIONS — portal grid ══ -->
  <section style="padding:40px 24px 72px;max-width:1120px;margin:0 auto;">
    <div class="reveal" style="text-align:center;margin-bottom:40px;">
      <div style="font-family:var(--font-head);font-size:12px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">Everything in one place</div>
      <h2 style="font-family:var(--font-head);font-weight:800;font-size:clamp(26px,4.5vw,44px);letter-spacing:-0.02em;color:#fff;">What you can do here</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(248px,1fr));gap:18px;">
      {functions.map((f) => (
        <a href={f.href} class="fn-card" data-magnetic="0.3" data-cursor="cta" data-cursor-label="OPEN" style="display:block;text-decoration:none;position:relative;padding:28px;border-radius:16px;background:linear-gradient(160deg,#0d2140 0%,#07142a 100%);border:1px solid rgba(224,169,63,0.18);box-shadow:0 8px 28px rgba(0,0,0,0.35);overflow:hidden;will-change:transform;">
          <div style={`position:absolute;top:0;left:0;width:100%;height:3px;background:${f.accent};opacity:0.9;`}></div>
          <div style={`display:inline-block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:${f.accent};border:1px solid ${f.accent}55;border-radius:999px;padding:3px 10px;margin-bottom:18px;`}>{f.tag}</div>
          <div style="font-family:var(--font-head);font-weight:700;font-size:22px;color:#fff;margin-bottom:10px;">{f.title}</div>
          <div style="font-size:14px;line-height:1.65;color:var(--silver-dim);margin-bottom:18px;">{f.desc}</div>
          <span class="arrow" style={`color:${f.accent};font-size:14px;font-weight:600;opacity:0.7;display:inline-block;`}>Open →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ══ ARTICLES STAGE — real posts cross-fade as you scroll ══ -->
  <section class={`stage stage-articles`} style={`height:${artStageVh}vh;`}>
    <div class="stage-inner">
      <div class="stage-eyebrow">From the journal · scroll</div>
      {latestArticles.map((post, i) => (
        <a class={`article-slide${i === 0 ? ' active' : ''}`} href={`/articles/${post.id}`}>
          <div class="art-tag">{(post.data.tags && post.data.tags[0]) || 'Analysis'}</div>
          <div class="art-title">{post.data.title}</div>
          {post.data.description && <div class="art-desc">{post.data.description}</div>}
          <div class="art-meta">{post.data.pubDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}</div>
          <span class="art-read">Read the article →</span>
        </a>
      ))}
      <div class="stage-dots">
        {latestArticles.map((_, i) => (<span class={`stage-dot${i === 0 ? ' on' : ''}`}></span>))}
      </div>
    </div>
  </section>

  <!-- ══ MARKETS STAGE — live numbers on screen ══ -->
  <section class="stage stage-markets" style="height:150vh;">
    <div class="stage-inner">
      <div class="stage-eyebrow" style="color:#4ea3ff;">● Live markets · updates every minute</div>
      <h2 class="stage-heading">The markets, right now</h2>
      <div id="mkt-live" class="mkt-grid"><div class="mkt-loading">loading live prices…</div></div>
      <a href="/markets" class="stage-cta link-gold" data-magnetic="0.4" style="margin-top:26px;display:inline-block;will-change:transform;">Open the full markets →</a>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section style="padding:80px 24px;text-align:center;background:linear-gradient(160deg,rgba(224,169,63,0.1) 0%,rgba(7,20,42,0.9) 55%,rgba(78,163,255,0.08) 100%);border-top:1px solid rgba(224,169,63,0.22);border-bottom:1px solid rgba(224,169,63,0.22);">
    <div class="reveal" style="max-width:620px;margin:0 auto;">
      <h2 class="cta-h2" style="font-family:var(--font-head);font-weight:800;font-size:clamp(28px,6vw,52px);letter-spacing:-0.025em;line-height:1.08;color:#fff;margin-bottom:18px;">Start with what you need</h2>
      <p style="font-size:15px;color:var(--silver-dim);margin-bottom:32px;line-height:1.7;">Read the markets, scan the news, or bring a problem and work on it directly.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="/consulting" class="btn-primary" data-magnetic="0.5" style="font-size:15px;padding:14px 28px;will-change:transform;">Work with AHoosh</a>
        <a href="/assess" class="btn-secondary" data-magnetic="0.5" style="font-size:15px;padding:14px 28px;will-change:transform;">Try the free diagnostics</a>
      </div>
    </div>
  </section>

  <!-- TEMP background switcher (review phase) — pick 1/2/3, reloads with ?bg= -->
  <div id="bg-switch" style="position:fixed;right:16px;bottom:16px;z-index:9998;display:flex;gap:6px;align-items:center;background:rgba(7,20,42,0.82);border:1px solid rgba(224,169,63,0.3);border-radius:999px;padding:6px 8px;backdrop-filter:blur(8px);font-family:var(--font-head);">
    <span style="font-size:10px;color:var(--silver-muted);letter-spacing:0.12em;padding:0 4px;">BG</span>
    <button data-bg="1" type="button" title="Molten gold" style="width:26px;height:26px;border-radius:50%;border:1px solid rgba(224,169,63,0.4);background:transparent;color:var(--silver-dim);font-size:12px;font-weight:700;cursor:pointer;">1</button>
    <button data-bg="2" type="button" title="Data nebula" style="width:26px;height:26px;border-radius:50%;border:1px solid rgba(224,169,63,0.4);background:transparent;color:var(--silver-dim);font-size:12px;font-weight:700;cursor:pointer;">2</button>
    <button data-bg="3" type="button" title="Fintech grid" style="width:26px;height:26px;border-radius:50%;border:1px solid rgba(224,169,63,0.4);background:transparent;color:var(--silver-dim);font-size:12px;font-weight:700;cursor:pointer;">3</button>
  </div>
  <script is:inline>
    (function(){
      var cur = new URLSearchParams(location.search).get('bg') || '1';
      document.querySelectorAll('#bg-switch button').forEach(function(b){
        if (b.getAttribute('data-bg') === cur) { b.style.background = 'var(--gold)'; b.style.color = '#07142a'; b.style.borderColor = 'var(--gold)'; }
        b.addEventListener('click', function(){
          var u = new URL(location.href); u.searchParams.set('bg', b.getAttribute('data-bg')); location.href = u.toString();
        });
      });
    })();
  </script>

  <!-- Brand sphere (restored vortex) — self-contained 2D canvas, no scroll dep. -->
  <script is:inline>
  (function(){
    var canvas=document.getElementById("vc");if(!canvas)return;
    var ctx=canvas.getContext("2d");
    var W=canvas.width,H=canvas.height,CX=W/2,CY=H/2-4;
    var NA=5,ND=26,AK=[0,1,2,0,1],R=104,FOV=300,AE=Math.PI*0.88,WR=1.3;
    var WHITE=[247,244,236],GOLD=[224,169,63],HR=64;
    var BASE=[];
    for(var a=0;a<NA;a++){for(var i=0;i<ND;i++){var t=i/(ND-1);var alpha=0.04+AE*t;var phi=(a/NA)*2*Math.PI-t*2*Math.PI*WR;var sa=Math.sin(alpha);BASE.push({x:R*sa*Math.cos(phi),y:R*sa*Math.sin(phi),z:R*Math.cos(alpha),isW:t>0.55&&(i+AK[a])%3===0,br:0.15+6.0*t,t:t});}}
    var HX=-0.20,HY=0.0,HZ=0.0,rX=HX,rY=HY,rZ=HZ,velX=0,velY=0,drag=false,lmx=0,lmy=0,mx=-999,my=-999;
    function rxf(x,y,z,a){var c=Math.cos(a),s=Math.sin(a);return[x,y*c-z*s,y*s+z*c];}
    function ryf(x,y,z,a){var c=Math.cos(a),s=Math.sin(a);return[x*c+z*s,y,-x*s+z*c];}
    function rzf(x,y,z,a){var c=Math.cos(a),s=Math.sin(a);return[x*c-y*s,x*s+y*c,z];}
    canvas.addEventListener("mousedown",function(e){drag=true;lmx=e.clientX;lmy=e.clientY;velX=0;velY=0;});
    window.addEventListener("mousemove",function(e){var r=canvas.getBoundingClientRect();mx=e.clientX-r.left;my=e.clientY-r.top;if(!drag)return;var dx=e.clientX-lmx,dy=e.clientY-lmy;velY=dx*0.012;velX=dy*0.012;rY+=velY;rX+=velX;rX=Math.max(-1.2,Math.min(1.2,rX));lmx=e.clientX;lmy=e.clientY;});
    window.addEventListener("mouseup",function(){drag=false;});
    canvas.addEventListener("mouseleave",function(){if(!drag){mx=-999;my=-999;}});
    canvas.addEventListener("touchstart",function(e){e.preventDefault();drag=true;lmx=e.touches[0].clientX;lmy=e.touches[0].clientY;velX=0;velY=0;},{passive:false});
    canvas.addEventListener("touchmove",function(e){e.preventDefault();var dx=e.touches[0].clientX-lmx,dy=e.touches[0].clientY-lmy;velY=dx*0.012;velX=dy*0.012;rY+=velY;rX+=velX;rX=Math.max(-1.2,Math.min(1.2,rX));lmx=e.touches[0].clientX;lmy=e.touches[0].clientY;},{passive:false});
    canvas.addEventListener("touchend",function(){drag=false;});
    function frame(){
      if(!drag){velX*=0.90;velY*=0.90;rX+=velX;rY+=velY;rX+=(HX-rX)*0.025;rY+=(HY-rY)*0.025;rZ+=(HZ-rZ)*0.025;}
      ctx.clearRect(0,0,W,H);
      var pts=BASE.map(function(p){var q=rzf(p.x,p.y,p.z,rZ);q=ryf(q[0],q[1],q[2],rY);q=rxf(q[0],q[1],q[2],rX);var x=q[0],y=q[1],z=q[2];var sc=FOV/(FOV+z),px=CX+x*sc,py=CY-y*sc;var df=(z+R)/(2*R),op=Math.max(0,Math.pow(1-df,2.2));var ddx=px-mx,ddy=py-my,hv=Math.max(0,1-Math.sqrt(ddx*ddx+ddy*ddy)/HR);var fo=Math.min(1,op+hv*0.9);return{px:px,py:py,sc:sc,depth:z,fo:fo,hv:hv,isW:p.isW,br:p.br};}).sort(function(a,b){return a.depth-b.depth;});
      pts.forEach(function(p){var dr=Math.max(0.3,p.br*p.sc),fo=p.fo;var rgb=p.isW?WHITE:GOLD,r=rgb[0],g=rgb[1],b=rgb[2];if(p.hv>0.1){ctx.beginPath();ctx.arc(p.px,p.py,dr*1.8,0,6.28);ctx.fillStyle="rgba("+r+","+g+","+b+","+(p.hv*0.15).toFixed(3)+")";ctx.fill();}var rd=Math.max(0.4,dr),grad=ctx.createRadialGradient(p.px,p.py,0,p.px,p.py,rd);grad.addColorStop(0,"rgba("+Math.min(255,r+40)+","+Math.min(255,g+30)+","+Math.min(255,b+20)+","+fo.toFixed(3)+")");grad.addColorStop(1,"rgba("+r+","+g+","+b+","+fo.toFixed(3)+")");ctx.beginPath();ctx.arc(p.px,p.py,rd,0,6.28);ctx.fillStyle=grad;ctx.fill();});
      requestAnimationFrame(frame);
    }
    frame();
  })();
  </script>

  <!-- Ambient 3D background + scroll motion + magnetism + live markets (deferred). -->
  <script>
    import { SceneManager } from '../3d/core/SceneManager';
    import { createHomepageScene } from '../3d/scenes/SceneHomepage';
    import { initHomepageScroll } from '../scripts/homepage-scroll';
    import { initInteractions } from '../scripts/interactions';
    import { initMarketsLive } from '../scripts/markets-live';

    const start = () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const canvas = document.getElementById('canvas-3d');
      if (!reduced && canvas instanceof HTMLCanvasElement && SceneManager.isWebGLAvailable()) {
        try {
          const sm = SceneManager.getInstance();
          sm.mount(canvas);
          sm.loadScene('home', createHomepageScene);
        } catch (e) {
          console.warn('[homepage] 3D background skipped:', e);
        }
      }
      initHomepageScroll();
      initInteractions();
      initMarketsLive();
    };

    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 1500 });
    } else {
      setTimeout(start, 400);
    }
  </script>

  <style>
    /* ── Living stages (sticky, content plays over the continuous background) ── */
    .stage { position: relative; }
    .stage-inner {
      position: sticky; top: 0; height: 100vh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center; padding: 0 24px; overflow: hidden;
    }
    .stage-eyebrow {
      font-family: var(--font-head); font-size: 12px; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
      margin-bottom: 22px;
    }
    .stage-heading {
      font-family: var(--font-head); font-weight: 800; color: #fff;
      font-size: clamp(28px, 5vw, 56px); letter-spacing: -0.03em; margin-bottom: 32px;
    }

    /* Article slides cross-fade via CSS transition (toggled by .active in JS) */
    .article-slide {
      position: absolute; inset: 0; display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      padding: 0 24px; max-width: 860px; margin: 0 auto;
      opacity: 0; transform: translateY(42px); pointer-events: none;
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
      text-decoration: none;
    }
    .article-slide.active { opacity: 1; transform: none; pointer-events: auto; }
    .art-tag {
      display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--gold); border: 1px solid rgba(224,169,63,0.4);
      border-radius: 999px; padding: 4px 12px; margin-bottom: 20px;
    }
    .art-title {
      font-family: var(--font-head); font-weight: 800; color: #fff;
      font-size: clamp(26px, 5vw, 60px); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 18px;
    }
    .art-desc { font-size: clamp(15px,2.2vw,20px); line-height: 1.7; color: var(--silver-dim); max-width: 620px; margin: 0 auto 18px; }
    .art-meta { font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--silver-muted); margin-bottom: 22px; }
    .art-read { color: var(--gold); font-weight: 600; font-size: 15px; }
    .stage-dots { position: absolute; bottom: 9vh; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; }
    .stage-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.22); transition: all 0.3s ease; }
    .stage-dot.on { background: var(--gold); transform: scale(1.4); box-shadow: 0 0 12px rgba(224,169,63,0.6); }

    /* Live market tiles */
    .mkt-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px; width: 100%; max-width: 860px; }
    .mkt-loading { grid-column: 1 / -1; color: var(--silver-muted); font-size: 14px; }
    .mkt-tile {
      background: linear-gradient(160deg, #0d2140 0%, #07142a 100%);
      border: 1px solid rgba(224,169,63,0.18); border-radius: 14px; padding: 20px 18px;
      box-shadow: 0 8px 28px rgba(0,0,0,0.35); transition: background 0.6s ease;
    }
    .mkt-sym { font-family: var(--font-head); font-size: 12px; font-weight: 700; letter-spacing: 0.06em; color: var(--silver-muted); margin-bottom: 10px; display: flex; align-items: center; justify-content: center; gap: 6px; }
    .mkt-dot { width: 6px; height: 6px; border-radius: 50%; background: #46d6c0; box-shadow: 0 0 8px #46d6c0; animation: mkt-pulse 2s infinite; }
    @keyframes mkt-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
    .mkt-val { font-family: var(--font-head); font-weight: 800; font-size: clamp(20px, 3vw, 30px); color: #fff; letter-spacing: -0.01em; }
    .mkt-ch { font-size: 12px; font-weight: 600; margin-top: 6px; }
    .mkt-up { color: #46d6a0; } .mkt-down { color: #ff6b6b; } .mkt-flat { color: var(--silver-muted); }
    .mkt-tile.flash-up { animation: flash-g 0.8s ease; } .mkt-tile.flash-down { animation: flash-r 0.8s ease; }
    @keyframes flash-g { 0% { background: rgba(70,214,160,0.25); } 100% { background: linear-gradient(160deg,#0d2140,#07142a); } }
    @keyframes flash-r { 0% { background: rgba(255,107,107,0.22); } 100% { background: linear-gradient(160deg,#0d2140,#07142a); } }

    @media (pointer: coarse) { .stage-articles { /* height set inline; sticky still smooth */ } }
  </style>
</BaseLayout>
