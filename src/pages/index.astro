---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
// REDESIGN 2026-06-19 (no blocks, integrated): content floats in/out over the
// living background (#3 fintech grid). Real article hero images with 3D mouse-tilt;
// markets as a live animated chart visual (not a numbers box). No personal info.
const latestArticles = (await getCollection('blog'))
  .filter((p) => !p.data.draft && !/^(fa|de|sr)\//.test(p.id) && p.data.heroImage)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
const artStageVh = latestArticles.length * 70 + 40;
const caps = [
  { href: '/news', tag: 'Live', title: 'News', desc: 'Business news in English, Persian, German and Serbian — refreshed through the day.' },
  { href: '/markets', tag: 'Live', title: 'Markets', desc: 'FX, gold and crypto, updated every minute.' },
  { href: '/articles', tag: '40+', title: 'Articles', desc: 'Deep-dive analysis for operators and decision-makers.' },
  { href: '/assess', tag: 'Free', title: 'Diagnostics', desc: 'AI assessments for your business, website and decision style.' },
  { href: '/consulting', tag: 'Work with us', title: 'Consulting', desc: 'Strategy, AI setup and growth — directly with AHoosh.' },
];
---

<BaseLayout
  title="Home"
  description="AHoosh brings live market data, business news in four languages, AI-assisted research and practical tools into one place — clear enough to act on."
>
  <!-- ══ HERO ══ -->
  <section class="s-hero">
    <div class="hero-eyebrow shiny-text">AHoosh.ai</div>
    <canvas class="hero-sphere" id="vc" width="340" height="260"></canvas>
    <h1 class="hero-h1">Markets, news &amp; research — clear enough to act on.</h1>
    <p class="hero-subline">Live market data, business news in four languages, and AI-assisted research and tools — in one place.</p>
    <div class="hero-cta">
      <a href="/news" class="btn-primary" data-magnetic="0.5">Explore the News</a>
      <a href="/markets" class="btn-secondary" data-magnetic="0.5">Live Markets</a>
    </div>
    <div class="scroll-hint">Scroll ↓</div>
  </section>

  <!-- ══ LIVE NEWS — headlines sliding right→left ══ -->
  <section class="news-strip" aria-label="Live news">
    <span class="news-label">● Live news</span>
    <div class="news-viewport"><div class="news-track" id="news-track"></div></div>
  </section>

  <!-- ══ CAPABILITIES — float-in text rows, no boxes ══ -->
  <section class="s-caps">
    <div data-reveal data-from="up" class="caps-head">
      <div class="eyebrow shiny-text">Everything in one place</div>
      <h2 class="big-h2">What you can do here</h2>
    </div>
    {caps.map((c, i) => (
      <a href={c.href} class="cap-row" data-reveal data-from={i % 2 ? 'right' : 'left'} data-magnetic="0.15" data-cursor="cta" data-cursor-label="OPEN">
        <span class="cap-title">{c.title}</span>
        <span class="cap-desc">{c.desc}</span>
        <span class="cap-tag arrow">{c.tag} →</span>
      </a>
    ))}
  </section>

  <!-- ══ ARTICLES — real hero images, 3D tilt, cross-fade on scroll ══ -->
  <section class="stage stage-articles" style={`height:${artStageVh}vh;`}>
    <div class="stage-inner">
      <div class="stage-eyebrow" data-reveal data-from="up">From the journal · scroll</div>
      {latestArticles.map((post, i) => (
        <a class={`article-slide${i === 0 ? ' active' : ''}`} href={`/articles/${post.id}`}>
          <div class="art-visual" data-tilt="9">
            <div class="art-img" data-tilt-inner style={`background-image:url('${post.data.heroImage}')`}>
              <span class="art-glare" data-tilt-glare></span>
            </div>
          </div>
          <div class="art-text">
            <div class="art-tag">{(post.data.tags && post.data.tags[0]) || 'Analysis'}</div>
            <div class="art-title">{post.data.title}</div>
            {post.data.description && <div class="art-desc">{post.data.description}</div>}
            <div class="art-meta">{post.data.pubDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}</div>
            <span class="art-read">Read the article →</span>
          </div>
        </a>
      ))}
      <div class="stage-dots">
        {latestArticles.map((_, i) => (<span class={`stage-dot${i === 0 ? ' on' : ''}`}></span>))}
      </div>
    </div>
  </section>

  <!-- ══ MARKETS — live chart visual, no box ══ -->
  <section class="stage stage-markets" style="height:140vh;">
    <div class="stage-inner">
      <div class="stage-eyebrow" style="color:#4ea3ff;">● Live markets</div>
      <h2 class="stage-heading">The markets, moving in real time</h2>
      <canvas id="mkt-chart" class="mkt-chart"></canvas>
      <div id="mkt-tickers" class="mkt-tickers"></div>
      <a href="/markets" class="link-gold" data-magnetic="0.4" style="margin-top:22px;display:inline-block;">Open the full markets →</a>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section class="s-cta">
    <div data-reveal data-from="up">
      <h2 class="cta-h2">Start with what you need</h2>
      <p class="cta-sub">Read the markets, scan the news, or bring a problem and work on it directly.</p>
      <div class="hero-cta">
        <a href="/consulting" class="btn-primary" data-magnetic="0.5">Work with AHoosh</a>
        <a href="/assess" class="btn-secondary" data-magnetic="0.5">Try the free diagnostics</a>
      </div>
    </div>
  </section>

  <!-- Brand sphere (vortex) -->
  <script is:inline>
  (function(){
    var canvas=document.getElementById("vc");if(!canvas)return;
    var ctx=canvas.getContext("2d");
    var W=canvas.width,H=canvas.height,CX=W/2,CY=H/2-4;
    var NA=5,ND=26,AK=[0,1,2,0,1],R=104,FOV=300,AE=Math.PI*0.88,WR=1.3;
    var WHITE=[247,244,236],GOLD=[224,169,63],HR=64;
    var BASE=[];
    for(var a=0;a<NA;a++){for(var i=0;i<ND;i++){var t=i/(ND-1);var alpha=0.04+AE*t;var phi=(a/NA)*2*Math.PI-t*2*Math.PI*WR;var sa=Math.sin(alpha);BASE.push({x:R*sa*Math.cos(phi),y:R*sa*Math.sin(phi),z:R*Math.cos(alpha),isW:t>0.55&&(i+AK[a])%3===0,br:0.15+6.0*t,t:t});}}
    var HX=-0.20,HY=0.0,HZ=0.0,rX=HX,rY=HY,rZ=HZ,velX=0,velY=0,drag=false,lmx=0,lmy=0,mx=-999,my=-999;
    function rxf(x,y,z,a){var c=Math.cos(a),s=Math.sin(a);return[x,y*c-z*s,y*s+z*c];}
    function ryf(x,y,z,a){var c=Math.cos(a),s=Math.sin(a);return[x*c+z*s,y,-x*s+z*c];}
    function rzf(x,y,z,a){var c=Math.cos(a),s=Math.sin(a);return[x*c-y*s,x*s+y*c,z];}
    canvas.addEventListener("mousedown",function(e){drag=true;lmx=e.clientX;lmy=e.clientY;velX=0;velY=0;});
    window.addEventListener("mousemove",function(e){var r=canvas.getBoundingClientRect();mx=e.clientX-r.left;my=e.clientY-r.top;if(!drag)return;var dx=e.clientX-lmx,dy=e.clientY-lmy;velY=dx*0.012;velX=dy*0.012;rY+=velY;rX+=velX;rX=Math.max(-1.2,Math.min(1.2,rX));lmx=e.clientX;lmy=e.clientY;});
    window.addEventListener("mouseup",function(){drag=false;});
    canvas.addEventListener("mouseleave",function(){if(!drag){mx=-999;my=-999;}});
    canvas.addEventListener("touchstart",function(e){e.preventDefault();drag=true;lmx=e.touches[0].clientX;lmy=e.touches[0].clientY;velX=0;velY=0;},{passive:false});
    canvas.addEventListener("touchmove",function(e){e.preventDefault();var dx=e.touches[0].clientX-lmx,dy=e.touches[0].clientY-lmy;velY=dx*0.012;velX=dy*0.012;rY+=velY;rX+=velX;rX=Math.max(-1.2,Math.min(1.2,rX));lmx=e.touches[0].clientX;lmy=e.touches[0].clientY;},{passive:false});
    canvas.addEventListener("touchend",function(){drag=false;});
    function frame(){
      if(!drag){velX*=0.90;velY*=0.90;rX+=velX;rY+=velY;rX+=(HX-rX)*0.025;rY+=(HY-rY)*0.025;rZ+=(HZ-rZ)*0.025;}
      ctx.clearRect(0,0,W,H);
      var pts=BASE.map(function(p){var q=rzf(p.x,p.y,p.z,rZ);q=ryf(q[0],q[1],q[2],rY);q=rxf(q[0],q[1],q[2],rX);var x=q[0],y=q[1],z=q[2];var sc=FOV/(FOV+z),px=CX+x*sc,py=CY-y*sc;var df=(z+R)/(2*R),op=Math.max(0,Math.pow(1-df,2.2));var ddx=px-mx,ddy=py-my,hv=Math.max(0,1-Math.sqrt(ddx*ddx+ddy*ddy)/HR);var fo=Math.min(1,op+hv*0.9);return{px:px,py:py,sc:sc,depth:z,fo:fo,hv:hv,isW:p.isW,br:p.br};}).sort(function(a,b){return a.depth-b.depth;});
      pts.forEach(function(p){var dr=Math.max(0.3,p.br*p.sc),fo=p.fo;var rgb=p.isW?WHITE:GOLD,r=rgb[0],g=rgb[1],b=rgb[2];if(p.hv>0.1){ctx.beginPath();ctx.arc(p.px,p.py,dr*1.8,0,6.28);ctx.fillStyle="rgba("+r+","+g+","+b+","+(p.hv*0.15).toFixed(3)+")";ctx.fill();}var rd=Math.max(0.4,dr),grad=ctx.createRadialGradient(p.px,p.py,0,p.px,p.py,rd);grad.addColorStop(0,"rgba("+Math.min(255,r+40)+","+Math.min(255,g+30)+","+Math.min(255,b+20)+","+fo.toFixed(3)+")");grad.addColorStop(1,"rgba("+r+","+g+","+b+","+fo.toFixed(3)+")");ctx.beginPath();ctx.arc(p.px,p.py,rd,0,6.28);ctx.fillStyle=grad;ctx.fill();});
      requestAnimationFrame(frame);
    }
    frame();
  })();
  </script>

  <!-- Background + scroll + magnetism/tilt + live markets (deferred) -->
  <script>
    import { SceneManager } from '../3d/core/SceneManager';
    import { createHomepageScene } from '../3d/scenes/SceneHomepage';
    import { createImageScene } from '../3d/scenes/createImageScene';
    import { initHomepageScroll } from '../scripts/homepage-scroll';
    import { initInteractions } from '../scripts/interactions';
    import { initMarketsLive } from '../scripts/markets-live';
    import { initNewsTicker } from '../scripts/news-ticker';
    const start = () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const canvas = document.getElementById('canvas-3d');
      if (!reduced && canvas instanceof HTMLCanvasElement && SceneManager.isWebGLAvailable()) {
        try {
          const sm = SceneManager.getInstance(); sm.mount(canvas);
          const bgParam = new URLSearchParams(location.search).get('bg');
          const useShader = !!bgParam && ['1','2','3','4','5'].includes(bgParam);
          // Image-first default: real photographic Mont-Fort-style background (drifts + zooms on scroll).
          const HERO_IMG = 'https://images.unsplash.com/photo-1761437855740-c894da924d79?auto=format&fit=crop&w=1920&q=70';
          sm.loadScene('home', useShader ? createHomepageScene : createImageScene({ src: HERO_IMG }));
        }
        catch (e) { console.warn('[homepage] 3D bg skipped:', e); }
      }
      initHomepageScroll(); initInteractions(); initMarketsLive(); initNewsTicker();
    };
    if ('requestIdleCallback' in window) (window as any).requestIdleCallback(start, { timeout: 1500 });
    else setTimeout(start, 400);
  </script>

  <style>
    /* No blocks — everything is type + imagery over the living background. */
    .s-hero { min-height: 92vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 72px 24px 56px; position: relative; }
    .hero-eyebrow { font-family: var(--font-head); font-size: 12px; font-weight: 700; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 26px; }
    .hero-sphere { cursor: grab; display: block; touch-action: none; width: min(380px, 82vw); aspect-ratio: 340/260; margin-bottom: 28px; filter: drop-shadow(0 0 40px rgba(224,169,63,0.28)); }
    .hero-h1 { font-family: var(--font-head); font-weight: 800; font-size: clamp(34px, 7vw, 70px); letter-spacing: -0.035em; line-height: 1.05; color: #fff; margin: 0 auto 22px; max-width: 16ch; text-wrap: balance; text-shadow: 0 2px 40px rgba(0,0,0,0.6); }
    .hero-subline { font-size: clamp(15px, 2.2vw, 19px); line-height: 1.7; color: var(--silver-dim); max-width: 560px; margin: 0 auto 36px; text-wrap: pretty; }
    .hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .hero-cta .btn-primary, .hero-cta .btn-secondary { font-size: 15px; padding: 14px 28px; will-change: transform; }
    .scroll-hint { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--silver-muted); }
    .st-word { display: inline-block; } /* keep words intact under SplitText */

    /* Live news ticker — slides right→left, no box */
    .news-strip { display: flex; align-items: center; gap: 18px; max-width: 1200px; margin: 0 auto; padding: 14px 24px; border-top: 1px solid rgba(224,169,63,0.16); border-bottom: 1px solid rgba(224,169,63,0.16); }
    .news-label { flex: 0 0 auto; font-family: var(--font-head); font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); white-space: nowrap; }
    .news-viewport { flex: 1; overflow: hidden; -webkit-mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent); }
    .news-track { display: inline-flex; align-items: center; white-space: nowrap; will-change: transform; }
    .news-item { display: inline-flex; align-items: baseline; gap: 8px; text-decoration: none; padding: 0 6px; }
    .news-src { font-family: var(--font-head); font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--gold); opacity: 0.85; }
    .news-ttl { font-size: 14px; color: var(--silver); }
    .news-item:hover .news-ttl { color: #fff; }
    .news-dot { color: var(--gold); opacity: 0.5; padding: 0 16px; font-size: 8px; }

    /* Capabilities — float-in text rows, hairline dividers, no cards */
    .s-caps { max-width: 1000px; margin: 0 auto; padding: 50px 24px 80px; }
    .caps-head { text-align: center; margin-bottom: 44px; }
    .eyebrow { font-family: var(--font-head); font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
    .big-h2 { font-family: var(--font-head); font-weight: 800; font-size: clamp(26px, 4.5vw, 44px); letter-spacing: -0.02em; color: #fff; text-wrap: balance; }
    .cap-row { display: grid; grid-template-columns: minmax(120px, 0.6fr) 1.6fr auto; align-items: baseline; gap: 18px; padding: 26px 8px; border-top: 1px solid rgba(224,169,63,0.16); text-decoration: none; will-change: transform; transition: color 0.3s; }
    .cap-row:last-of-type { border-bottom: 1px solid rgba(224,169,63,0.16); }
    .cap-title { font-family: var(--font-head); font-weight: 800; font-size: clamp(22px, 3.4vw, 36px); color: #fff; letter-spacing: -0.02em; transition: color 0.3s; }
    .cap-row:hover .cap-title { color: var(--gold); }
    .cap-desc { font-size: 14px; line-height: 1.6; color: var(--silver-dim); }
    .cap-tag { font-family: var(--font-head); font-size: 13px; font-weight: 700; color: var(--gold); white-space: nowrap; opacity: 0.75; transition: transform 0.3s, opacity 0.3s; }
    .cap-row:hover .cap-tag { opacity: 1; transform: translateX(6px); }
    @media (max-width: 680px) { .cap-row { grid-template-columns: 1fr; gap: 8px; } }

    /* Living stages */
    .stage { position: relative; }
    .stage-inner { position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 24px; overflow: hidden; }
    .stage-eyebrow { font-family: var(--font-head); font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
    .stage-heading { font-family: var(--font-head); font-weight: 800; color: #fff; font-size: clamp(26px, 4.5vw, 52px); letter-spacing: -0.03em; margin-bottom: 26px; text-wrap: balance; }

    /* Article slides — image + text, cross-fade via .active */
    .article-slide { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: clamp(20px, 5vw, 64px); padding: 0 24px; max-width: 1060px; margin: 0 auto;
      opacity: 0; transform: translateY(42px); pointer-events: none; text-decoration: none;
      transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1); }
    .article-slide.active { opacity: 1; transform: none; pointer-events: auto; }
    .art-visual { flex: 0 0 46%; max-width: 480px; perspective: 1000px; }
    .art-img { position: relative; width: 100%; aspect-ratio: 4/3; background-size: cover; background-position: center; border-radius: 18px; box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(224,169,63,0.18); transform-style: preserve-3d; will-change: transform; }
    .art-glare { position: absolute; inset: 0; border-radius: 18px; background: radial-gradient(circle at 50% 30%, rgba(255,255,255,0.6), transparent 60%); opacity: 0; pointer-events: none; mix-blend-mode: overlay; }
    .art-text { flex: 1; text-align: left; max-width: 460px; }
    .art-tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(224,169,63,0.4); border-radius: 999px; padding: 4px 12px; margin-bottom: 18px; }
    .art-title { font-family: var(--font-head); font-weight: 800; color: #fff; font-size: clamp(22px, 3.4vw, 40px); letter-spacing: -0.025em; line-height: 1.1; margin-bottom: 16px; text-wrap: balance; }
    .art-desc { font-size: clamp(14px, 1.6vw, 17px); line-height: 1.65; color: var(--silver-dim); margin-bottom: 16px; }
    .art-meta { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--silver-muted); margin-bottom: 18px; }
    .art-read { color: var(--gold); font-weight: 600; font-size: 15px; }
    @media (max-width: 760px) { .article-slide { flex-direction: column; gap: 22px; } .art-visual { flex: none; width: min(360px, 80vw); } .art-text { text-align: center; } }
    .stage-dots { position: absolute; bottom: 7vh; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; }
    .stage-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.22); transition: all 0.3s; }
    .stage-dot.on { background: var(--gold); transform: scale(1.4); box-shadow: 0 0 12px rgba(224,169,63,0.6); }

    /* Markets visual — chart line + plain tickers, no box */
    .mkt-chart { width: min(900px, 92vw); height: 240px; display: block; margin: 6px auto 18px; }
    .mkt-tickers { display: flex; flex-wrap: wrap; gap: clamp(16px, 4vw, 40px); justify-content: center; }
    .mkt-ticker { display: flex; flex-direction: column; align-items: center; gap: 2px; }
    .mkt-ticker .mkt-sym { font-family: var(--font-head); font-size: 11px; font-weight: 700; letter-spacing: 0.06em; color: var(--silver-muted); }
    .mkt-ticker .mkt-val { font-family: var(--font-head); font-weight: 800; font-size: clamp(18px, 2.4vw, 26px); color: #fff; }
    .mkt-ch { font-size: 12px; font-weight: 600; }
    .mkt-up { color: #46d6a0; } .mkt-down { color: #ff6b6b; } .mkt-flat { color: var(--silver-muted); }
    .mkt-moved .mkt-val { animation: mkt-flash 0.8s ease; }
    @keyframes mkt-flash { 0% { color: var(--gold); } 100% { color: #fff; } }

    /* CTA */
    .s-cta { min-height: 90vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 0 24px; }
    .cta-h2 { font-family: var(--font-head); font-weight: 800; font-size: clamp(28px, 6vw, 52px); letter-spacing: -0.025em; line-height: 1.08; color: #fff; margin-bottom: 18px; max-width: 16ch; margin-inline: auto; text-wrap: balance; }
    .cta-sub { font-size: 15px; color: var(--silver-dim); margin-bottom: 32px; line-height: 1.7; }
  </style>
</BaseLayout>
