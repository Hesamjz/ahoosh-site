---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="AI-Augmented B2B Operations. Digital Transformation. Serbia–Iran–EU bridge.">

  <!-- Hero -->
  <section style="
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
    padding: 48px 24px 56px;
    text-align: center;
    border-bottom: 1px solid rgba(215,161,61,0.12);
  ">
    <h1 style="
      font-family: var(--font-head);
      font-weight: 700;
      font-size: clamp(26px, 7vw, 40px);
      line-height: 1.2;
      letter-spacing: -0.01em;
      color: var(--silver);
      margin-bottom: 16px;
    ">
      AI-Augmented Operations<br><em style="font-style:normal;color:var(--gold);">Designed to Scale</em>
    </h1>
    <p style="
      font-size: 15px;
      line-height: 1.65;
      color: var(--silver-dim);
      margin-bottom: 32px;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    ">
      We help B2B companies in emerging markets build AI-powered workflows that reduce cost, increase output, and compound over time.
    </p>
    <div style="display:flex;flex-direction:column;gap:12px;align-items:center;">
      <a href="/contact" class="btn-primary" style="width:100%;max-width:280px;">Book a Discovery Call</a>
      <a href="/consulting" class="btn-secondary" style="width:100%;max-width:280px;">Explore Our Services</a>
    </div>
  </section>

  <!-- Services strip -->
  <section style="
    padding: 40px 24px;
    border-bottom: 1px solid rgba(215,161,61,0.08);
    max-width: 680px;
    margin: 0 auto;
  ">
    <div class="section-eyebrow">What We Do</div>
    <h2 class="section-title">Three Ways We Work Together</h2>

    <!-- Card 1 -->
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.12);
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 12px;
    ">
      <div style="
        width:36px;height:36px;background:rgba(215,161,61,0.12);border-radius:6px;
        display:flex;align-items:center;justify-content:center;margin-bottom:12px;
      ">
        <svg width="18" height="18" fill="none" viewBox="0 0 18 18">
          <path d="M3 9h12M9 3v12" stroke="#D7A13D" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:6px;">AI Operations Design</div>
      <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">Map, automate, and scale your core business processes using AI tools that integrate with your existing stack.</div>
    </div>

    <!-- Card 2 -->
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.12);
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 12px;
    ">
      <div style="
        width:36px;height:36px;background:rgba(215,161,61,0.12);border-radius:6px;
        display:flex;align-items:center;justify-content:center;margin-bottom:12px;
      ">
        <svg width="18" height="18" fill="none" viewBox="0 0 18 18">
          <rect x="2" y="2" width="14" height="14" rx="2" stroke="#D7A13D" stroke-width="1.5"/>
          <path d="M6 9l2 2 4-4" stroke="#D7A13D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:6px;">Digital Transformation</div>
      <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">End-to-end transformation programs for B2B companies moving from manual operations to digital-first execution.</div>
    </div>

    <!-- Card 3 -->
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.12);
      border-radius: 6px;
      padding: 20px;
    ">
      <div style="
        width:36px;height:36px;background:rgba(215,161,61,0.12);border-radius:6px;
        display:flex;align-items:center;justify-content:center;margin-bottom:12px;
      ">
        <svg width="18" height="18" fill="none" viewBox="0 0 18 18">
          <circle cx="9" cy="9" r="7" stroke="#D7A13D" stroke-width="1.5"/>
          <path d="M9 5v4l3 2" stroke="#D7A13D" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:6px;">Strategic Advisory</div>
      <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">Retained advisory for founders and executives navigating the Serbia–Iran–EU corridor with AI as a competitive advantage.</div>
    </div>
  </section>

  <!-- Credibility bar -->
  <section style="
    padding: 24px;
    display: flex;
    border-bottom: 1px solid rgba(215,161,61,0.08);
    max-width: 680px;
    margin: 0 auto;
  ">
    <div style="flex:1;text-align:center;border-right:1px solid rgba(215,161,61,0.1);padding:0 8px;">
      <div style="font-family:var(--font-head);font-weight:700;font-size:24px;color:var(--gold);line-height:1;margin-bottom:4px;">10+</div>
      <div style="font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-dim);line-height:1.3;">Years B2B</div>
    </div>
    <div style="flex:1;text-align:center;border-right:1px solid rgba(215,161,61,0.1);padding:0 8px;">
      <div style="font-family:var(--font-head);font-weight:700;font-size:24px;color:var(--gold);line-height:1;margin-bottom:4px;">PhD</div>
      <div style="font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-dim);line-height:1.3;">Candidate</div>
    </div>
    <div style="flex:1;text-align:center;padding:0 8px;">
      <div style="font-family:var(--font-head);font-weight:700;font-size:24px;color:var(--gold);line-height:1;margin-bottom:4px;">3</div>
      <div style="font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-dim);line-height:1.3;">Markets</div>
    </div>
  </section>

  <!-- Articles teaser -->
  <section style="
    padding: 40px 24px;
    border-bottom: 1px solid rgba(215,161,61,0.08);
    max-width: 680px;
    margin: 0 auto;
  ">
    <div class="section-eyebrow">From the Intelligence</div>
    <h2 class="section-title">Recent Articles</h2>

    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:18px;margin-bottom:12px;">
      <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">AI Operations</div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:14px;line-height:1.4;color:var(--silver);margin-bottom:6px;">Why Most AI Implementations Fail in the First 90 Days</div>
      <div style="font-size:11px;color:var(--silver-muted);">June 2026</div>
    </div>

    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:18px;margin-bottom:16px;">
      <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">B2B Transformation</div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:14px;line-height:1.4;color:var(--silver);margin-bottom:6px;">The Emerging Market AI Stack: What Actually Works</div>
      <div style="font-size:11px;color:var(--silver-muted);">May 2026</div>
    </div>

    <a href="/articles" class="link-gold">All Articles</a>
  </section>

  <!-- CTA band -->
  <section style="
    background: linear-gradient(135deg, rgba(215,161,61,0.08) 0%, rgba(3,20,46,0.6) 100%);
    border-top: 1px solid rgba(215,161,61,0.15);
    padding: 40px 24px;
    text-align: center;
    max-width: 100%;
  ">
    <div style="max-width:480px;margin:0 auto;">
      <h2 style="font-family:var(--font-head);font-weight:700;font-size:20px;color:var(--silver);margin-bottom:8px;line-height:1.3;">Ready to build operations that compound?</h2>
      <p style="font-size:14px;color:var(--silver-dim);margin-bottom:24px;">A 30-minute discovery call. No pitch deck.</p>
      <a href="/contact" class="btn-primary" style="display:inline-block;min-width:200px;">Book a Discovery Call</a>
    </div>
  </section>

</BaseLayout>
