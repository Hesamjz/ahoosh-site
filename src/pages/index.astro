---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="AI-Augmented B2B Operations. Digital Transformation. Serbia–Iran–EU bridge.">
  <section style="max-width: 1100px; margin: 0 auto; padding: var(--space-12) var(--space-4);">
    <h1 style="font-size: clamp(36px, 6vw, 56px); font-weight: 600; letter-spacing: -0.02em; color: var(--color-navy); margin-bottom: var(--space-3);">
      AI-Augmented<br />B2B Operations
    </h1>
    <p style="font-size: 17px; max-width: 560px; color: var(--color-text-secondary); margin-bottom: var(--space-6);">
      AHoosh helps mid-market businesses in Serbia, Iran, and the EU unlock measurable growth
      by integrating AI into their operations — without the hype.
    </p>
    <div style="display: flex; gap: var(--space-2); flex-wrap: wrap;">
      <a href="/consulting" class="btn-primary">See how we work</a>
      <a href="/contact" class="btn-secondary">Start a conversation</a>
    </div>
  </section>
  <!-- Phase 3: Frontend_Developer fills this from v1_home.md copy -->
</BaseLayout>
