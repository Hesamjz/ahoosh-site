---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Consulting" description="AI Operations, Digital Marketing, Branding, SEO, Website Design, and Social Media Management — AHoosh consulting services for B2B, B2C, and government clients.">

  <!-- Hero -->
  <section style="
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
    padding: 48px 24px 40px;
    text-align: center;
    border-bottom: 1px solid rgba(215,161,61,0.1);
  ">
    <div class="section-eyebrow">Consulting</div>
    <h1 style="
      font-family: var(--font-head);
      font-weight: 700;
      font-size: clamp(22px, 6vw, 36px);
      letter-spacing: -0.01em;
      color: var(--silver);
      margin-bottom: 10px;
    ">Nine Service Lines.<br/>One Practice.</h1>
    <p style="font-size:14px;color:var(--silver-dim);line-height:1.6;max-width:460px;margin:0 auto;">
      From brand strategy through AI operations to ongoing social management — everything a growth-stage company needs, delivered as a managed practice, not a vendor stack.
    </p>
  </section>

  <!-- Services -->
  <section style="padding:40px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow" style="margin-bottom:20px;">Services</div>

    <!-- 01 -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-left:3px solid var(--gold);border-radius:6px;padding:20px;margin-bottom:16px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">01 · AI Operations &amp; Automation</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">Automate the Repetitive. Accelerate the Complex.</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">We audit your core processes and rebuild them around AI tools — automating customer service, workflows, and back-office operations. Purpose-built agents that run without constant oversight.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Operations Audit + Automation Stack + 90-Day Rollout Plan</div>
    </div>

    <!-- 02 -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-left:3px solid var(--gold);border-radius:6px;padding:20px;margin-bottom:16px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">02 · Digital Marketing</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">AI-Powered Campaigns That Compound</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">Email automation via Brevo, ad campaign management on Google and Meta, campaign analytics dashboards, and CRM-connected marketing flows. Built as a managed service or handed over fully trained to your team.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Marketing Stack Setup + Campaign Calendar + Monthly Analytics Report</div>
    </div>

    <!-- 03 -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-left:3px solid var(--gold);border-radius:6px;padding:20px;margin-bottom:16px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">03 · Website Design, Build &amp; Run</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">Fast, Convertible, Maintainable</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">We design, build, and run websites on modern stacks (Astro, Next.js, WooCommerce). Performance-first, SEO-baked-in, with CMS integration so your team can publish without touching code.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Design System + Built Site + Deployment + Ongoing Maintenance Retainer</div>
    </div>

    <!-- 04 -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-left:3px solid var(--gold);border-radius:6px;padding:20px;margin-bottom:16px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">04 · SEO &amp; Content Strategy</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">Search Visibility That Lasts</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">Technical SEO audits, keyword strategy, content architecture, and ongoing article production. We build content pipelines that compound authority over 6–12 months — not one-time blog bursts.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Technical SEO Audit + Content Roadmap + Monthly Article Package</div>
    </div>

    <!-- 05 -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-left:3px solid var(--gold);border-radius:6px;padding:20px;margin-bottom:16px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">05 · Branding &amp; Strategy</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">From Positioning to Market Entry</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">Brand architecture, visual identity, messaging frameworks, competitive analysis, and market-entry strategy. Particularly suited for companies moving into or across the EU, Middle East, and Iranian diaspora corridors.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Brand Book + Positioning Document + Go-to-Market Plan</div>
    </div>

    <!-- 06 -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-left:3px solid var(--gold);border-radius:6px;padding:20px;">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">06 · Social Media Management</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">Managed Presence Across All Channels</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">Daily publishing on LinkedIn, Instagram, X, and Telegram. AI-assisted content creation, visual design, community management, and performance reporting. Handed over as a managed service or with full team training.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Format:</strong> Monthly Content Calendar + Daily Publishing + Weekly Reporting</div>
    </div>
  </section>

  <!-- Process -->
  <section style="padding:40px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow" style="margin-bottom:16px;">How It Works</div>

    <div style="display:flex;gap:16px;margin-bottom:24px;align-items:flex-start;">
      <div style="flex-shrink:0;width:40px;height:40px;border-radius:50%;background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);">1</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Discovery Call</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">30 minutes. We understand your current operations, goals, and whether we're a fit.</div>
      </div>
    </div>

    <div style="display:flex;gap:16px;margin-bottom:24px;align-items:flex-start;">
      <div style="flex-shrink:0;width:40px;height:40px;border-radius:50%;background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);">2</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Diagnosis</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">We map your existing processes, channels, and stack. Identify where AI adds leverage. Size the impact.</div>
      </div>
    </div>

    <div style="display:flex;gap:16px;margin-bottom:24px;align-items:flex-start;">
      <div style="flex-shrink:0;width:40px;height:40px;border-radius:50%;background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);">3</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Design + Build</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">We design the new system, build the automations, create the content pipeline, and integrate with your stack.</div>
      </div>
    </div>

    <div style="display:flex;gap:16px;align-items:flex-start;">
      <div style="flex-shrink:0;width:40px;height:40px;border-radius:50%;background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);">4</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Handoff or Retainer</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">We train your team and document everything — or stay on as a monthly managed service partner. Your choice.</div>
      </div>
    </div>
  </section>

  <!-- Geography note -->
  <section style="padding:32px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow" style="margin-bottom:12px;">Where We Work</div>
    <p style="font-size:14px;line-height:1.7;color:var(--silver-dim);">
      Our practice is remote-first. Primary clients are in the <strong style="color:var(--silver);">US, EU, Middle East, and the Iranian diaspora</strong> business community. We bring a rare ability to translate between Western AI tooling and the cultural + operational context of emerging-market growth companies.
    </p>
  </section>

  <!-- CTA band -->
  <section style="background:linear-gradient(135deg,rgba(215,161,61,0.08) 0%,rgba(3,20,46,0.6) 100%);border-top:1px solid rgba(215,161,61,0.15);padding:40px 24px;text-align:center;">
    <div style="max-width:480px;margin:0 auto;">
      <h2 style="font-family:var(--font-head);font-weight:700;font-size:20px;color:var(--silver);margin-bottom:8px;line-height:1.3;">Start with a conversation</h2>
      <p style="font-size:14px;color:var(--silver-dim);margin-bottom:24px;">No retainer required for the discovery call.</p>
      <a href="/contact" class="btn-primary" style="display:inline-block;min-width:200px;">Book a Discovery Call</a>
    </div>
  </section>

</BaseLayout>
