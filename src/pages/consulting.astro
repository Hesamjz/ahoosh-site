---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Consulting" description="AI Operations Design, Digital Transformation, and Strategic Advisory for B2B companies in emerging markets.">

  <!-- Hero -->
  <section style="
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
    padding: 48px 24px 40px;
    text-align: center;
    border-bottom: 1px solid rgba(215,161,61,0.1);
  ">
    <div class="section-eyebrow">Consulting</div>
    <h1 style="
      font-family: var(--font-head);
      font-weight: 700;
      font-size: clamp(22px, 6vw, 36px);
      letter-spacing: -0.01em;
      color: var(--silver);
      margin-bottom: 10px;
    ">We Build AI-Augmented Operations</h1>
    <p style="font-size:14px;color:var(--silver-dim);line-height:1.6;max-width:420px;margin:0 auto;">For B2B companies that want to scale without scaling headcount.</p>
  </section>

  <!-- Services -->
  <section style="padding:32px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow" style="margin-bottom:16px;">Services</div>

    <!-- Service 01 -->
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.12);
      border-left: 3px solid var(--gold);
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 16px;
    ">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">01 · AI Operations Design</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">Map, Automate, Scale</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">We audit your core business processes and redesign them around AI tools — automating the repetitive, accelerating the complex, and eliminating the unnecessary.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Operations Playbook + Automation Stack + 90-Day Rollout</div>
    </div>

    <!-- Service 02 -->
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.12);
      border-left: 3px solid var(--gold);
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 16px;
    ">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">02 · Digital Transformation</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">From Manual to Digital-First</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">End-to-end transformation programs for companies stuck between spreadsheets and scale. We build the systems, train the team, and track the outcomes.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Deliverable:</strong> Digital Maturity Assessment + Roadmap + Implementation</div>
    </div>

    <!-- Service 03 -->
    <div style="
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(215,161,61,0.12);
      border-left: 3px solid var(--gold);
      border-radius: 6px;
      padding: 20px;
    ">
      <div style="font-family:var(--font-head);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">03 · Strategic Advisory</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--silver);margin-bottom:8px;">Retained Intelligence</div>
      <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">Monthly retained advisory for founders and leadership teams navigating AI adoption, market expansion, and operational scale — particularly across the Serbia–Iran–EU corridor.</p>
      <div style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--silver-muted);"><strong style="color:var(--gold);font-weight:600;">Format:</strong> Monthly sessions + async support + quarterly reviews</div>
    </div>
  </section>

  <!-- Process -->
  <section style="padding:32px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow" style="margin-bottom:16px;">How It Works</div>

    <!-- Step 1 -->
    <div style="display:flex;gap:16px;margin-bottom:24px;align-items:flex-start;">
      <div style="
        flex-shrink:0;width:40px;height:40px;border-radius:50%;
        background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);
        display:flex;align-items:center;justify-content:center;
        font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);
      ">1</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Discovery Call</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">30 minutes. We understand your current operations, your goals, and whether we're a fit.</div>
      </div>
    </div>

    <!-- Step 2 -->
    <div style="display:flex;gap:16px;margin-bottom:24px;align-items:flex-start;">
      <div style="
        flex-shrink:0;width:40px;height:40px;border-radius:50%;
        background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);
        display:flex;align-items:center;justify-content:center;
        font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);
      ">2</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Operations Audit</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">We map your existing processes, identify automation opportunities, and size the impact.</div>
      </div>
    </div>

    <!-- Step 3 -->
    <div style="display:flex;gap:16px;margin-bottom:24px;align-items:flex-start;">
      <div style="
        flex-shrink:0;width:40px;height:40px;border-radius:50%;
        background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);
        display:flex;align-items:center;justify-content:center;
        font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);
      ">3</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Design + Build</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">We design the new operational system, build the automations, and integrate with your stack.</div>
      </div>
    </div>

    <!-- Step 4 -->
    <div style="display:flex;gap:16px;align-items:flex-start;">
      <div style="
        flex-shrink:0;width:40px;height:40px;border-radius:50%;
        background:rgba(215,161,61,0.1);border:1.5px solid rgba(215,161,61,0.35);
        display:flex;align-items:center;justify-content:center;
        font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gold);
      ">4</div>
      <div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:15px;color:var(--silver);margin-bottom:4px;">Handoff + Optimize</div>
        <div style="font-size:13px;line-height:1.6;color:var(--silver-dim);">We train your team, document everything, and stay available to optimize as you scale.</div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section style="
    background: linear-gradient(135deg, rgba(215,161,61,0.08) 0%, rgba(3,20,46,0.6) 100%);
    border-top: 1px solid rgba(215,161,61,0.15);
    padding: 40px 24px;
    text-align: center;
  ">
    <div style="max-width:480px;margin:0 auto;">
      <h2 style="font-family:var(--font-head);font-weight:700;font-size:20px;color:var(--silver);margin-bottom:8px;line-height:1.3;">Start with a conversation</h2>
      <p style="font-size:14px;color:var(--silver-dim);margin-bottom:24px;">No retainer required for the discovery call.</p>
      <a href="/contact" class="btn-primary" style="display:inline-block;min-width:200px;">Book a Discovery Call</a>
    </div>
  </section>

</BaseLayout>
