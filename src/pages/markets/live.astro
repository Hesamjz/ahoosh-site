---
// Live markets view backed by the markets-fetcher Worker pipeline
// (cron every 1 min → D1 snapshots + KV). Reads /api/markets/latest.
// Day-1 (FX + crypto + gold). Deliberately a SEPARATE route from /markets
// (which still reads the on-demand /api/markets Pages Function) so nothing is
// clobbered; consolidation into the main page is a coordinated follow-up.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Live Markets — AHoosh"
  description="Live FX, crypto and gold — refreshed every minute. Each value carries its own source and timestamp."
  locale="en"
>
  <section class="mkt">
    <header class="mkt-head">
      <p class="eyebrow">Markets · live pipeline</p>
      <h1>Live Markets</h1>
      <p class="sub">
        FX · Crypto · Gold — fetched every minute from locked sources. Every value
        shows its own source and capture time. <span class="muted">Information only.</span>
      </p>
      <p id="status" class="status">Loading…</p>
    </header>

    <div id="groups" class="groups"></div>

    <footer class="mkt-foot">
      <span id="updated" class="muted"></span>
      <span class="muted"> · auto-refresh 60s · <span class="dot fresh"></span> fresh this minute · <span class="dot stale"></span> last known</span>
    </footer>
  </section>

  <style>
    .mkt { max-width: 920px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }
    .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .72rem; color: #D7A13D; margin: 0 0 .35rem; }
    .mkt-head h1 { font-size: 2rem; margin: 0 0 .4rem; color: #03142E; }
    .sub { color: #2a3b54; margin: 0 0 .6rem; }
    .muted { color: #6b7890; }
    .status { font-size: .85rem; color: #6b7890; margin: .2rem 0 0; }
    .groups { margin-top: 1.6rem; display: grid; gap: 1.6rem; }
    .grp h2 { font-size: .95rem; text-transform: uppercase; letter-spacing: .08em; color: #03142E; margin: 0 0 .5rem; border-bottom: 1px solid #e4dccb; padding-bottom: .35rem; }
    table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
    th, td { text-align: right; padding: .5rem .4rem; font-size: .92rem; }
    th:first-child, td:first-child { text-align: left; }
    th { font-weight: 600; color: #6b7890; font-size: .74rem; text-transform: uppercase; letter-spacing: .05em; }
    tbody tr { border-bottom: 1px solid #f0ebdf; }
    .asset { font-weight: 600; color: #03142E; }
    .val { font-weight: 600; color: #03142E; }
    .chg-up { color: #1a7f4b; } .chg-dn { color: #b23b3b; } .chg-flat { color: #6b7890; }
    .src { color: #8a93a6; font-size: .78rem; }
    .as-of { color: #8a93a6; font-size: .78rem; white-space: nowrap; }
    .dot { display: inline-block; width: .55rem; height: .55rem; border-radius: 50%; vertical-align: middle; }
    .dot.fresh { background: #1a7f4b; } .dot.stale { background: #c9a23a; }
    .mkt-foot { margin-top: 1.8rem; font-size: .8rem; }
  </style>

  <script is:inline>
    const ENDPOINT = '/api/markets/latest';
    const CET = 'Europe/Belgrade'; // CET/CEST
    const GROUPS = [
      { title: 'Foreign exchange', keys: ['USD/IRR','EUR/IRR','USD/RSD','EUR/RSD','EUR/USD','GBP/USD','USD/JPY','USD/CNY','USD/TRY','USD/AED'] },
      { title: 'Gold', keys: ['XAU/USD','XAU/EUR'] },
      { title: 'Crypto (USD)', keys: ['BTC','ETH','BNB','SOL','XRP','USDT','USDC','ADA','DOGE','AVAX'] },
    ];

    function fmt(v) {
      if (v == null) return '—';
      const abs = Math.abs(v);
      const dp = abs >= 1000 ? 0 : abs >= 1 ? 2 : 4;
      return v.toLocaleString('en-US', { minimumFractionDigits: dp, maximumFractionDigits: dp });
    }
    function asOfCET(s) {
      if (!s) return '';
      // D1 CURRENT_TIMESTAMP is UTC ("YYYY-MM-DD HH:MM:SS")
      const iso = s.includes('T') ? s : s.replace(' ', 'T') + 'Z';
      const d = new Date(iso);
      if (isNaN(d)) return '';
      return d.toLocaleTimeString('en-GB', { timeZone: CET, hour: '2-digit', minute: '2-digit' }) + ' CET';
    }
    function chg(c) {
      if (c == null) return '<span class="chg-flat">·</span>';
      const cls = c > 0 ? 'chg-up' : c < 0 ? 'chg-dn' : 'chg-flat';
      const sign = c > 0 ? '+' : '';
      return `<span class="${cls}">${sign}${c.toFixed(2)}%</span>`;
    }

    async function load() {
      const status = document.getElementById('status');
      try {
        const r = await fetch(ENDPOINT, { cache: 'no-store' });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const d = await r.json();
        render(d);
        status.textContent = `${d.fresh_count}/${d.shown_count} fresh this minute` +
          (d.stale_count ? ` · ${d.stale_count} showing last-known` : '');
      } catch (e) {
        status.textContent = 'Could not load live data — ' + e.message;
      }
    }

    function render(d) {
      const a = d.assets || {};
      const root = document.getElementById('groups');
      root.innerHTML = GROUPS.map((g) => {
        const rows = g.keys.filter((k) => a[k]).map((k) => {
          const x = a[k];
          const dot = x.fresh ? 'fresh' : 'stale';
          return `<tr>
            <td class="asset"><span class="dot ${dot}"></span> ${k}</td>
            <td class="val">${fmt(x.value)}</td>
            <td>${chg(x.change)}</td>
            <td class="src">${x.source || ''}</td>
            <td class="as-of">${asOfCET(x.as_of)}</td>
          </tr>`;
        }).join('');
        if (!rows) return '';
        return `<div class="grp"><h2>${g.title}</h2><table>
          <thead><tr><th>Asset</th><th>Value</th><th>24h</th><th>Source</th><th>As of</th></tr></thead>
          <tbody>${rows}</tbody></table></div>`;
      }).join('');
      const upd = document.getElementById('updated');
      if (d.updated) upd.textContent = 'Snapshot ' + asOfCET(d.updated.replace('T',' ').replace('Z',''));
    }

    load();
    setInterval(load, 60000);
  </script>
</BaseLayout>
