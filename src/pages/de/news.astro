---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsPage from '../../components/NewsPage.astro';

const t = {
  eyebrow: 'Nachrichten + Live-TV',
  heading: 'Weltgeschehen — Aktuell',
  subheading: 'Internationale Nachrichten · Aktualisierung alle 5 Minuten · Nur zur Information',
  liveTVLabel: '📺 Live-TV',
  latestNewsLabel: '📰 Aktuelle Nachrichten',
  searchPlaceholder: 'Nachrichten durchsuchen...',
  allChannels: 'Alle',
  allNews: 'Alle',
  liveSuffix: 'Live',
  noResults: 'Keine Ergebnisse gefunden.',
  failedLoad: 'Fehler beim Laden. Bitte erneut versuchen.',
  updatedAt: 'Letzte Aktualisierung',
  metaSources: 'Artikel aus {n} Quellen',
  timeAgo: { now: 'Gerade eben', min: ' Min. zuvor', hr: ' Std. zuvor', days: ' Tage zuvor' },
  localeCode: 'de-DE',
  rtl: false,
  langNames: { en:'Englisch', fa:'Persisch', de:'Deutsch', fr:'Französisch', ar:'Arabisch', sr:'Serbisch', market:'Märkte', es:'Spanisch' },
};
---
<BaseLayout title="Nachrichten &amp; Live-TV" description="Internationale Nachrichten aus 40+ Quellen. Aktualisierung alle 5 Minuten." locale="de">
  <NewsPage locale="de" t={t} />
</BaseLayout>
