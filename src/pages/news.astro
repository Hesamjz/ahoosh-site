---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsPage from '../components/NewsPage.astro';

const t = {
  eyebrow: 'News + Live TV',
  heading: 'World Events — Live',
  subheading: 'Persian &amp; international news · Updated every 5 minutes · Information only',
  liveTVLabel: '📺 Live TV',
  latestNewsLabel: '📰 Latest News',
  searchPlaceholder: 'Search news...',
  allChannels: 'All',
  allNews: 'All',
  liveSuffix: 'Live',
  noResults: 'No results found.',
  failedLoad: 'Failed to load news. Please try again.',
  updatedAt: 'Last updated',
  metaSources: 'articles from {n} sources',
  timeAgo: { now: 'Just now', min: ' min ago', hr: ' hr ago', days: ' days ago' },
  localeCode: 'en-GB',
  rtl: false,
  langNames: { en:'English', fa:'Persian', de:'Deutsch', fr:'Français', ar:'Arabic', sr:'Serbian', market:'Markets', es:'Español' },
};
---
<BaseLayout title="News &amp; Live TV" description="Live international news from 40+ channels. Updated every 5 minutes." locale="en">
  <NewsPage locale="en" t={t} />
</BaseLayout>
