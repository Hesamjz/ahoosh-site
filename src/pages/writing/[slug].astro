---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Legacy /writing/ URLs existed for English posts only — translations
  // (fa/ de/ sr/ subfolders) have ids with slashes that a single [slug]
  // param cannot hold, and never had /writing/ URLs to redirect from.
  return posts
    .filter((post) => !/^(fa|de|sr)\//.test(post.id))
    .map((post) => ({
      params: { slug: post.id },
    }));
}

const { slug } = Astro.params;
return Astro.redirect(`/articles/${slug}`, 301);
---
