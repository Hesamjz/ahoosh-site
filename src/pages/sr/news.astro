---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsPage from '../../components/NewsPage.astro';

const t = {
  eyebrow: 'Vesti + Uživo TV',
  heading: 'Svetski događaji — Uživo',
  subheading: 'Međunarodne vesti · Ažuriranje svakih 5 minuta · Samo informativno',
  liveTVLabel: '📺 Uživo TV',
  latestNewsLabel: '📰 Najnovije vesti',
  searchPlaceholder: 'Pretraži vesti...',
  allChannels: 'Sve',
  allNews: 'Sve',
  liveSuffix: 'Uživo',
  noResults: 'Nema rezultata.',
  failedLoad: 'Greška pri učitavanju. Pokušajte ponovo.',
  updatedAt: 'Poslednje ažuriranje',
  metaSources: 'vesti iz {n} izvora',
  timeAgo: { now: 'Upravo sada', min: ' min pre', hr: ' sat pre', days: ' dana pre' },
  localeCode: 'sr-RS',
  rtl: false,
  langNames: { en:'Engleski', fa:'Persijski', de:'Nemački', fr:'Francuski', ar:'Arapski', sr:'Srpski', market:'Tržišta', es:'Španski' },
};
---
<BaseLayout title="Vesti i Uživo TV" description="Međunarodne vesti iz 40+ kanala. Ažuriranje svakih 5 minuta." locale="sr">
  <NewsPage locale="sr" t={t} />
</BaseLayout>
