---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsPage from '../../components/NewsPage.astro';

const t = {
  eyebrow: 'اخبار + تلویزیون زنده',
  heading: 'رویدادهای جهان — به‌روز',
  subheading: 'اخبار فارسی و بین‌المللی · به‌روزرسانی هر ۵ دقیقه · صرفاً اطلاع‌رسانی',
  liveTVLabel: '📺 تلویزیون زنده',
  latestNewsLabel: '📰 آخرین اخبار',
  searchPlaceholder: 'جستجو در اخبار...',
  allChannels: 'همه',
  allNews: 'همه',
  liveSuffix: 'پخش زنده',
  noResults: 'نتیجه‌ای یافت نشد.',
  failedLoad: 'در بارگذاری اخبار خطایی رخ داد. دوباره تلاش کنید.',
  updatedAt: 'آخرین به‌روزرسانی',
  metaSources: 'خبر از {n} منبع',
  timeAgo: { now: 'همین الان', min: ' دقیقه پیش', hr: ' ساعت پیش', days: ' روز پیش' },
  localeCode: 'fa-IR',
  rtl: true,
  langNames: { en:'انگلیسی', fa:'فارسی', de:'آلمانی', fr:'فرانسوی', ar:'عربی', sr:'صربی', market:'بازارها', es:'اسپانیایی' },
};
---
<BaseLayout title="اخبار و تلویزیون زنده" description="اخبار زنده از ۴۰+ کانال بین‌المللی. به‌روزرسانی هر ۵ دقیقه." locale="fa">
  <NewsPage locale="fa" t={t} />
</BaseLayout>
