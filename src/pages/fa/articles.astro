---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const en = all
  .filter((p) => !p.data.draft && !/^(fa|de|sr)\//.test(p.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const translated = new Map(
  all.filter((p) => p.id.startsWith('fa/') && !p.data.draft).map((p) => [p.id.slice(3), p])
);
const posts = en.map((p) => {
  const t = translated.get(p.id);
  return t
    ? { href: `/fa/articles/${p.id}`, data: t.data, isEnglish: false }
    : { href: `/articles/${p.id}`, data: p.data, isEnglish: true };
});
---

<BaseLayout title="مقالات" description="دیدگاه‌های عملی درباره هوش مصنوعی، عملیات B2B و کسب‌وکار در بازارهای نوظهور." locale="fa">

  <!-- Hero -->
  <section style="background:linear-gradient(160deg,#03142E 0%,#010A18 100%);padding:48px 24px 40px;text-align:center;border-bottom:1px solid rgba(215,161,61,0.1);">
    <div class="section-eyebrow">مقالات</div>
    <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(24px,6vw,36px);color:var(--silver);margin-bottom:10px;">تحلیل، مکتوب‌شده</h1>
    <p style="font-size:14px;color:var(--silver-dim);line-height:1.9;max-width:380px;margin:0 auto;">دیدگاه‌های عملی درباره هوش مصنوعی، عملیات B2B و کسب‌وکار در بازارهای نوظهور.</p>
    <p style="font-size:12px;color:var(--gold);margin-top:14px;">مقالات فعلاً به زبان انگلیسی‌اند — ترجمه فارسی به‌تدریج اضافه می‌شود.</p>
  </section>

  <!-- Article list -->
  <div style="padding:24px 24px 40px;max-width:680px;margin:0 auto;">
    {posts.map((post) => (
      <a href={post.href} style="display:block;text-decoration:none;">
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:20px;margin-bottom:12px;transition:border-color 150ms ease;" dir={post.isEnglish ? "ltr" : "rtl"}>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <span style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);">
              {(post.data as any).tags?.[0] ?? 'Article'}
            </span>
            {post.isEnglish && (<span style="font-size:9px;font-weight:700;border:1px solid rgba(215,161,61,0.4);color:var(--gold);padding:2px 7px;border-radius:999px;">EN</span>)}
          </div>
          <div style="font-family:'Montserrat',sans-serif;font-weight:600;font-size:15px;line-height:1.4;color:var(--silver);margin-bottom:8px;">
            {post.data.title}
          </div>
          {post.data.description && (
            <p style="font-size:13px;line-height:1.6;color:var(--silver-dim);margin-bottom:12px;">
              {post.data.description}
            </p>
          )}
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:var(--silver-muted);">
              {post.data.pubDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
            </span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Read →</span>
          </div>
        </div>
      </a>
    ))}
  </div>

</BaseLayout>
