---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="خانه"
  description="آهوش با ترکیب هوش مصنوعی، داده‌های بازار، پژوهش و مشاوره کاربردی به بنیان‌گذاران، شرکت‌ها و تصمیم‌گیران کمک می‌کند بازارها را بفهمند، فرصت‌ها را بسنجند و با اطلاعات بهتر اقدام کنند."
  locale="fa"
>

  <!-- Hero -->
  <section style="background:#010A18;padding:64px 24px 56px;border-bottom:1px solid rgba(215,161,61,0.12);">
    <div style="max-width:680px;margin:0 auto;">

      <div style="display:flex;flex-direction:column;align-items:center;gap:32px;">
        <canvas id="vc" width="320" height="240" style="cursor:grab;display:block;touch-action:none;width:min(320px,80vw);aspect-ratio:320/240;flex-shrink:0;"></canvas>

        <div style="text-align:center;max-width:560px;">
          <div class="section-eyebrow" style="margin-bottom:10px;">بنیان‌گذار: حسام جعفرزاده</div>
          <h1 style="font-family:var(--font-head);font-weight:700;font-size:clamp(26px,6vw,42px);line-height:1.3;color:var(--silver);margin-bottom:18px;">هوش مصنوعی، داده بازار و<br/>پژوهش برای تصمیم‌های بهتر</h1>
          <p style="font-size:15px;line-height:2;color:var(--silver-dim);margin-bottom:32px;">
            آهوش به بنیان‌گذاران، شرکت‌ها، مشاوران و تصمیم‌گیران کمک می‌کند ابزارهای هوش مصنوعی،
            سیگنال‌های بازار و پژوهش کاربردی را با هم ترکیب کنند تا فرصت‌ها را بشناسند،
            عدم‌قطعیت را کم کنند و استراتژی‌های هوشمندانه‌تری بسازند.
          </p>
          <div style="display:flex;flex-direction:column;gap:12px;align-items:center;">
            <a href="/fa/markets" class="btn-primary" style="width:100%;max-width:280px;">مشاهده داده‌های بازار</a>
            <a href="/fa/contact" class="btn-secondary" style="width:100%;max-width:280px;">درخواست مشاوره</a>
            <a href="/fa/articles" class="link-gold" style="font-size:14px;padding:8px 0;">خواندن مقالات ←</a>
          </div>
        </div>
      </div>

      <!-- Founder card -->
      <div style="display:flex;align-items:center;gap:16px;margin-top:48px;padding:20px;background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.15);border-radius:8px;">
        <div style="flex-shrink:0;width:64px;height:64px;border-radius:50%;overflow:hidden;border:2px solid rgba(215,161,61,0.4);background:rgba(215,161,61,0.1);">
          <img src="/assets/hesam.png" alt="حسام جعفرزاده" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;"
            onerror="this.parentElement.innerHTML='<div style=\'width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:700;font-size:18px;color:var(--gold);\'>HJ</div>';" />
        </div>
        <div>
          <div style="font-family:var(--font-head);font-weight:700;font-size:15px;color:var(--silver);line-height:1.4;">حسام جعفرزاده</div>
          <div style="font-size:12px;color:var(--gold);font-weight:500;margin-top:3px;">بنیان‌گذار · پژوهشگر · مشاور هوش مصنوعی و هوش بازار</div>
          <div style="font-size:12px;color:var(--silver-muted);margin-top:4px;">بیش از ۱۵ سال تجربه · پژوهشگر دکتری دانشگاه بلگراد</div>
        </div>
        <a href="/fa/about" style="margin-inline-start:auto;flex-shrink:0;font-family:var(--font-head);font-size:11px;font-weight:700;color:var(--gold);white-space:nowrap;">درباره ←</a>
      </div>

    </div>
  </section>

  <script is:inline>
  (function(){
    const canvas=document.getElementById("vc");
    const ctx=canvas.getContext("2d");
    const W=canvas.width,H=canvas.height,CX=W/2,CY=H/2-4;
    const NA=5,ND=26,AK=[0,1,2,0,1],R=100,FOV=280,AE=Math.PI*0.88,WR=1.3;
    const WHITE=[247,244,236],GOLD=[216,166,66],HR=60;
    const BASE=[];
    for(let a=0;a<NA;a++){for(let i=0;i<ND;i++){const t=i/(ND-1);const alpha=0.04+AE*t;const phi=(a/NA)*2*Math.PI-t*2*Math.PI*WR;const sa=Math.sin(alpha);BASE.push({x:R*sa*Math.cos(phi),y:R*sa*Math.sin(phi),z:R*Math.cos(alpha),isW:t>0.55&&(i+AK[a])%3===0,br:0.15+6.0*t,t});}}
    const HX=-0.20,HY=0.0,HZ=0.0;let rX=HX,rY=HY,rZ=HZ,velX=0,velY=0,drag=false,lmx=0,lmy=0,mx=-999,my=-999;
    const rxf=(x,y,z,a)=>{const c=Math.cos(a),s=Math.sin(a);return[x,y*c-z*s,y*s+z*c];};
    const ryf=(x,y,z,a)=>{const c=Math.cos(a),s=Math.sin(a);return[x*c+z*s,y,-x*s+z*c];};
    const rzf=(x,y,z,a)=>{const c=Math.cos(a),s=Math.sin(a);return[x*c-y*s,x*s+y*c,z];};
    canvas.addEventListener("mousedown",e=>{drag=true;lmx=e.clientX;lmy=e.clientY;velX=0;velY=0;});
    window.addEventListener("mousemove",e=>{const r=canvas.getBoundingClientRect();mx=e.clientX-r.left;my=e.clientY-r.top;if(!drag)return;const dx=e.clientX-lmx,dy=e.clientY-lmy;velY=dx*0.012;velX=dy*0.012;rY+=velY;rX+=velX;rX=Math.max(-1.2,Math.min(1.2,rX));lmx=e.clientX;lmy=e.clientY;});
    window.addEventListener("mouseup",()=>{drag=false;});
    canvas.addEventListener("mouseleave",()=>{if(!drag){mx=-999;my=-999;}});
    canvas.addEventListener("touchstart",e=>{e.preventDefault();drag=true;lmx=e.touches[0].clientX;lmy=e.touches[0].clientY;velX=0;velY=0;},{passive:false});
    canvas.addEventListener("touchmove",e=>{e.preventDefault();const dx=e.touches[0].clientX-lmx,dy=e.touches[0].clientY-lmy;velY=dx*0.012;velX=dy*0.012;rY+=velY;rX+=velX;rX=Math.max(-1.2,Math.min(1.2,rX));lmx=e.touches[0].clientX;lmy=e.touches[0].clientY;},{passive:false});
    canvas.addEventListener("touchend",()=>{drag=false;});
    function frame(){
      if(!drag){velX*=0.90;velY*=0.90;rX+=velX;rY+=velY;rX+=(HX-rX)*0.025;rY+=(HY-rY)*0.025;rZ+=(HZ-rZ)*0.025;}
      ctx.clearRect(0,0,W,H);
      const pts=BASE.map(p=>{let [x,y,z]=rzf(p.x,p.y,p.z,rZ);[x,y,z]=ryf(x,y,z,rY);[x,y,z]=rxf(x,y,z,rX);const sc=FOV/(FOV+z),px=CX+x*sc,py=CY-y*sc;const df=(z+R)/(2*R),op=Math.max(0,Math.pow(1-df,2.2));const ddx=px-mx,ddy=py-my,hv=Math.max(0,1-Math.sqrt(ddx*ddx+ddy*ddy)/HR);const fo=Math.min(1,op+hv*0.9);return{...p,px,py,sc,depth:z,fo,hv};}).sort((a,b)=>a.depth-b.depth);
      pts.forEach(p=>{const dr=Math.max(0.3,p.br*p.sc),fo=p.fo;const [r,g,b]=p.isW?WHITE:GOLD;if(p.hv>0.1){ctx.beginPath();ctx.arc(p.px,p.py,dr*1.8,0,6.28);ctx.fillStyle="rgba("+r+","+g+","+b+","+(p.hv*0.15).toFixed(3)+")";ctx.fill();}const rd=Math.max(0.4,dr),grad=ctx.createRadialGradient(p.px,p.py,0,p.px,p.py,rd);grad.addColorStop(0,"rgba("+Math.min(255,r+40)+","+Math.min(255,g+30)+","+Math.min(255,b+20)+","+fo.toFixed(3)+")");grad.addColorStop(0.6,"rgba("+r+","+g+","+b+","+fo.toFixed(3)+")");grad.addColorStop(1,"rgba("+r+","+g+","+b+","+fo.toFixed(3)+")");ctx.beginPath();ctx.arc(p.px,p.py,rd,0,6.28);ctx.fillStyle=grad;ctx.fill();});
      requestAnimationFrame(frame);
    }
    frame();
  })();
  </script>

  <!-- What AHoosh does -->
  <section style="padding:48px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow">آهوش چه می‌کند</div>
    <h2 class="section-title">چهار لایه، یک مجموعه</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-radius:6px;padding:18px;">
        <div style="font-size:20px;margin-bottom:8px;">🤖</div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:13px;color:var(--silver);margin-bottom:6px;">پژوهش با کمک هوش مصنوعی</div>
        <div style="font-size:12px;line-height:1.9;color:var(--silver-dim);">استفاده از ابزارهای هوش مصنوعی برای گردآوری، سازماندهی، مقایسه و توضیح اطلاعات، سریع‌تر از روش‌های سنتی.</div>
      </div>
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-radius:6px;padding:18px;">
        <div style="font-size:20px;margin-bottom:8px;">📊</div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:13px;color:var(--silver);margin-bottom:6px;">هوش بازار</div>
        <div style="font-size:12px;line-height:1.9;color:var(--silver-dim);">رصد قیمت‌ها، روندها، سیگنال‌ها و داده‌های عمومی که بر تصمیم‌های تجاری و سرمایه‌گذاری اثر می‌گذارند.</div>
      </div>
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-radius:6px;padding:18px;">
        <div style="font-size:20px;margin-bottom:8px;">🧩</div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:13px;color:var(--silver);margin-bottom:6px;">مشاوره</div>
        <div style="font-size:12px;line-height:1.9;color:var(--silver-dim);">کمک به بنیان‌گذاران و شرکت‌ها برای تبدیل مسئله‌های مبهم به تصمیم‌های عملی و برنامه اقدام.</div>
      </div>
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(215,161,61,0.12);border-radius:6px;padding:18px;">
        <div style="font-size:20px;margin-bottom:8px;">📝</div>
        <div style="font-family:var(--font-head);font-weight:600;font-size:13px;color:var(--silver);margin-bottom:6px;">محتوا و آموزش</div>
        <div style="font-size:12px;line-height:1.9;color:var(--silver-dim);">انتشار مقالات، راهنماها و توضیح‌های کاربردی برای مخاطبان در سراسر جهان.</div>
      </div>
    </div>
    <div style="text-align:center;margin-top:24px;">
      <a href="/fa/consulting" class="link-gold">مشاهده همه خدمات مشاوره ←</a>
    </div>
  </section>

  <!-- Who it's for -->
  <section style="padding:40px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow">برای چه کسانی</div>
    <h2 class="section-title">ساخته‌شده برای تصمیم‌گیران</h2>
    <p style="font-size:14px;line-height:2.1;color:var(--silver-dim);">
      آهوش با بنیان‌گذاران، استارتاپ‌ها، مشاوران، شرکت‌های جاافتاده و تصمیم‌گیران مستقل کار می‌کند — کسانی که پیش از حرکت به شفافیت نیاز دارند؛ چه در حال بررسی یک بازار باشند، چه آزمودن یک ایده، بهبود عملیات داخلی یا یافتن راه‌های بهتر برای استفاده از هوش مصنوعی.
    </p>
    <p style="font-size:14px;line-height:2.1;color:var(--silver-dim);margin-top:12px;">
      این مجموعه برای هر کسی طراحی شده که پژوهش کاربردی، سیگنال‌های مفید بازار و پشتیبانی تصمیم با کمک هوش مصنوعی می‌خواهد — در هر بازاری که فعالیت می‌کند.
    </p>
  </section>

  <!-- Articles teaser -->
  <section style="padding:40px 24px;border-bottom:1px solid rgba(215,161,61,0.08);max-width:680px;margin:0 auto;">
    <div class="section-eyebrow">تحلیل و دیدگاه</div>
    <h2 class="section-title">تازه‌ترین مقالات</h2>
    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:18px;margin-bottom:12px;">
      <div style="font-size:10px;font-weight:600;color:var(--gold);margin-bottom:8px;">هوش مصنوعی و تصمیم‌گیری</div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:14px;line-height:1.7;color:var(--silver);margin-bottom:6px;">چرا بیشتر پیاده‌سازی‌های هوش مصنوعی در ۹۰ روز اول شکست می‌خورند</div>
      <div style="font-size:11px;color:var(--silver-muted);">ژوئن ۲۰۲۶ · متن انگلیسی</div>
    </div>
    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(215,161,61,0.1);border-radius:6px;padding:18px;margin-bottom:16px;">
      <div style="font-size:10px;font-weight:600;color:var(--gold);margin-bottom:8px;">هوش بازار</div>
      <div style="font-family:var(--font-head);font-weight:600;font-size:14px;line-height:1.7;color:var(--silver);margin-bottom:6px;">خواندن سیگنال‌های بازار: چیزی که بنیان‌گذاران نمی‌بینند و چرا مهم است</div>
      <div style="font-size:11px;color:var(--silver-muted);">مه ۲۰۲۶ · متن انگلیسی</div>
    </div>
    <a href="/fa/articles" class="link-gold">همه مقالات ←</a>
  </section>

  <!-- CTA band -->
  <section style="background:linear-gradient(135deg,rgba(215,161,61,0.08) 0%,rgba(3,20,46,0.6) 100%);border-top:1px solid rgba(215,161,61,0.15);padding:48px 24px;text-align:center;">
    <div style="max-width:480px;margin:0 auto;">
      <div style="width:56px;height:56px;border-radius:50%;overflow:hidden;border:2px solid rgba(215,161,61,0.4);margin:0 auto 16px;background:rgba(215,161,61,0.1);">
        <img src="/assets/hesam.png" alt="حسام" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;" onerror="this.style.display='none';" />
      </div>
      <h2 style="font-family:var(--font-head);font-weight:700;font-size:22px;color:var(--silver);margin-bottom:8px;line-height:1.6;">بگویید دنبال فهمیدن چه چیزی هستید</h2>
      <p style="font-size:14px;color:var(--silver-dim);margin-bottom:24px;">بدون اسلاید و تشریفات. فقط یک گفت‌وگوی مستقیم درباره چیزی که نیاز دارید.</p>
      <a href="/fa/contact" class="btn-primary" style="display:inline-block;min-width:220px;">تماس با آهوش</a>
    </div>
  </section>

</BaseLayout>
