---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="مرکز ارزیابی — AHoosh.ai"
  description="سه ارزیابی. پانزده دقیقه. یک گزارش هوش مصنوعی که دقیقاً به شما می‌گوید کجا تمرکز کنید — و چه چیزی را اول درست کنید."
  locale="fa"
>
<style>
  :root { --gold:#D7A13D; --navy:#010A18; --card:#0B1A32; }
  body  { background:var(--navy); color:#c8d4e0; }
  .wrap { max-width:860px; margin:0 auto; padding:0 20px 100px; direction:rtl; }
  .hero { padding:72px 0 56px; text-align:center; }
  .hero-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:var(--gold); margin-bottom:18px; }
  .hero h1 { font-size:clamp(24px,4.5vw,40px); font-weight:800; color:#e8eaf0; line-height:1.4; margin:0 0 16px; }
  .hero p  { font-size:clamp(14px,2vw,17px); color:#7a8b9e; max-width:540px; margin:0 auto; line-height:1.9; }
  .tracks-label { font-size:11px; font-weight:700; letter-spacing:0.05em; color:#4a5a6e; margin-bottom:20px; }
  .tracks { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:18px; margin-bottom:56px; }
  .track-card { background:var(--card); border:1px solid rgba(215,161,61,0.12); border-radius:16px; padding:28px 24px; text-decoration:none; display:block; transition:all .2s; position:relative; text-align:right; }
  .track-card:hover { border-color:rgba(215,161,61,0.45); transform:translateY(-3px); box-shadow:0 12px 40px rgba(0,0,0,.5); }
  .track-icon { font-size:28px; margin-bottom:14px; }
  .track-card h3 { font-size:17px; font-weight:700; color:#e8eaf0; margin:0 0 6px; }
  .track-card p  { font-size:13px; color:#7a8b9e; line-height:1.8; margin:0 0 18px; }
  .track-cta { font-size:13px; font-weight:700; color:var(--gold); }
  .track-done { position:absolute; top:16px; left:16px; width:22px; height:22px; background:rgba(52,211,153,0.15); border:1.5px solid #34d399; border-radius:50%; display:none; align-items:center; justify-content:center; font-size:11px; color:#34d399; }
  .track-done.visible { display:flex; }
  .how { background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.07); border-radius:16px; padding:36px 32px; margin-bottom:48px; }
  .how h2 { font-size:13px; font-weight:700; letter-spacing:0.05em; color:var(--gold); margin:0 0 28px; }
  .steps { display:flex; gap:24px; flex-wrap:wrap; }
  .step { flex:1; min-width:160px; }
  .step-num { width:30px; height:30px; border-radius:50%; border:1.5px solid rgba(215,161,61,0.4); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:var(--gold); margin-bottom:12px; margin-right:0; margin-left:auto; }
  .step h4 { font-size:14px; font-weight:700; color:#e8eaf0; margin:0 0 6px; }
  .step p  { font-size:13px; color:#7a8b9e; line-height:1.8; margin:0; }
  .report-cta { text-align:center; padding:48px 32px; background:rgba(215,161,61,0.06); border:1px solid rgba(215,161,61,0.2); border-radius:16px; }
  .report-cta h3 { font-size:20px; font-weight:700; color:#e8eaf0; margin:0 0 10px; }
  .report-cta p  { font-size:14px; color:#7a8b9e; margin:0 0 24px; line-height:1.8; }
  .report-cta a  { display:inline-block; padding:14px 40px; background:var(--gold); color:var(--navy); font-weight:700; border-radius:10px; text-decoration:none; font-size:15px; transition:opacity .15s; }
  .report-cta a:hover { opacity:0.88; }
  .report-cta a.locked { opacity:0.35; pointer-events:none; }
  .locked-note { font-size:12px; color:#4a5a6e; margin-top:12px; display:none; line-height:1.8; }
  .locked-note.visible { display:block; }
</style>

<div class="wrap">
  <div class="hero">
    <div class="hero-eyebrow">مرکز ارزیابی AHoosh</div>
    <h1>بدانید چه چیزی کسب‌وکارتان را عقب نگه می‌دارد</h1>
    <p>سه ارزیابی. پانزده دقیقه. یک گزارش هوش مصنوعی که دقیقاً به شما می‌گوید کجا تمرکز کنید — و چه چیزی را اول درست کنید.</p>
  </div>

  <div class="tracks-label">انتخاب کنید از کجا شروع کنید</div>

  <div class="tracks">
    <a href="/assess/personality" class="track-card">
      <div class="track-done" id="done-personality">✓</div>
      <div class="track-icon">🧠</div>
      <h3>شخصیت و رهبری</h3>
      <p>بفهمید چگونه تصمیم می‌گیرید، تیم‌ها را رهبری می‌کنید و الگوهایتان چگونه در کسب‌وکار ظاهر می‌شوند.</p>
      <div class="track-cta">← شروع ارزیابی</div>
    </a>

    <a href="/assess/business" class="track-card">
      <div class="track-done" id="done-business">✓</div>
      <div class="track-icon">📊</div>
      <h3>تشخیص کسب‌وکار</h3>
      <p>نقاط قوت، ضعف و جایگاه بازاری‌تان را ترسیم کنید. پیشنهاد ارزش و مشتری ایده‌آل‌تان را شفاف کنید.</p>
      <div class="track-cta">← شروع ارزیابی</div>
    </a>

    <a href="/assess/website" class="track-card">
      <div class="track-done" id="done-website">✓</div>
      <div class="track-icon">🌐</div>
      <h3>وب‌سایت و حضور دیجیتال</h3>
      <p>امتیاز سرعت، فاصله‌های سئو و مشکلاتی که واقعاً سایتتان را عقب نگه می‌دارند — مستقیم از URL شما.</p>
      <div class="track-cta">← شروع ارزیابی</div>
    </a>
  </div>

  <div class="how">
    <h2>چگونه کار می‌کند</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">۱</div>
        <h4>ارزیابی‌ها را تکمیل کنید</h4>
        <p>هر بخش ۵ تا ۸ دقیقه طول می‌کشد. به هر ترتیبی. پیشرفت در مرورگرتان ذخیره می‌شود — نیازی به حساب نیست.</p>
      </div>
      <div class="step">
        <div class="step-num">۲</div>
        <h4>هوش مصنوعی تصویر کامل را می‌خواند</h4>
        <p>Claude تمام نتایج شما را با هم تحلیل می‌کند و سه مشکل با بیشترین اثرگذاری را در کسب‌وکار شما شناسایی می‌کند.</p>
      </div>
      <div class="step">
        <div class="step-num">۳</div>
        <h4>گزارش مشاوره‌تان را دریافت کنید</h4>
        <p>خلاصه اجرایی، توصیه‌های مشخص و یک اقدام سریع که می‌توانید همین هفته اجرا کنید.</p>
      </div>
    </div>
  </div>

  <div class="report-cta">
    <h3>آماده‌اید گزارشتان را ببینید؟</h3>
    <p id="cta-sub">حداقل یک ارزیابی را تکمیل کنید تا گزارش هوش مصنوعی شما ساخته شود.</p>
    <a href="/assess/report" id="report-btn" class="locked">نمایش گزارش من</a>
    <div class="locked-note" id="locked-note">ابتدا حداقل یکی از ارزیابی‌های بالا را تکمیل کنید.</div>
  </div>
</div>

<script is:inline>
(function(){
  var checks=[['done-personality','ahoosh_assess_personality'],['done-business','ahoosh_assess_business'],['done-website','ahoosh_assess_website']];
  var done=0;
  checks.forEach(function(c){try{if(localStorage.getItem(c[1])){var el=document.getElementById(c[0]);if(el)el.classList.add('visible');done++;}}catch(e){}});
  var btn=document.getElementById('report-btn');
  var sub=document.getElementById('cta-sub');
  var note=document.getElementById('locked-note');
  if(done>0){if(btn)btn.classList.remove('locked');if(sub)sub.textContent=''+done+' از ۳ ارزیابی کامل شده. گزارش شما آماده است.';}
  else{if(note)note.classList.add('visible');}
})();
</script>
</BaseLayout>
