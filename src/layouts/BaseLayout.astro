    <style>
      /* Desktop nav breakpoint */
      @media (min-width: 900px) {
        #desktop-nav { display: flex !important; }
        #mobile-controls #nav-toggle { display: none !important; }
        #mobile-lang { display: none !important; }
      }
      /* Consulting + Assess dropdown */
      .nav-drop-wrap {
        position: relative;
      }
      .nav-drop-btn {
        font-family: var(--font-body);
        font-size: 14px;
        font-weight: 500;
        color: var(--silver-dim);
        letter-spacing: 0.04em;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: color 150ms ease;
      }
      .nav-drop-btn:hover { color: var(--silver); }
      .nav-drop-arrow { font-size: 10px; opacity: 0.6; }
      .nav-drop-menu {
        display: none;
        position: absolute;
        top: calc(100% + 10px);
        left: 50%;
        transform: translateX(-50%);
        background: #03142E;
        border: 1px solid rgba(215,161,61,0.2);
        border-radius: 8px;
        padding: 6px;
        min-width: 190px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        z-index: 200;
      }
      .nav-drop-wrap:hover .nav-drop-menu,
      .nav-drop-wrap:focus-within .nav-drop-menu {
        display: block;
      }
      .nav-drop-item {
        display: block;
        padding: 9px 14px;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        color: var(--silver-dim);
        border-radius: 5px;
        text-decoration: none;
        transition: background 120ms ease, color 120ms ease;
      }
      .nav-drop-item:hover { background: rgba(215,161,61,0.1); color: var(--silver); }
      .nav-drop-gold { color: var(--gold) !important; }
      .nav-drop-gold:hover { color: var(--gold) !important; }
    </style>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const closeBtn = document.getElementById('menu-close');
      const menu = document.getElementById('mobile-menu');

      toggle?.addEventListener('click', () => {
        menu!.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });

      // ── GA4 Custom Event Tracking ──────────────────────────────────────
      function gtagEvent(eventName: string, params: Record<string, string | number>) {
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', eventName, params);
        }
      }

      // CTA clicks — "Book Discovery Call" / "Contact" buttons
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('a, button');
        if (!el) return;
        const href = (el as HTMLAnchorElement).href || '';
        const text = el.textContent?.trim() || '';

        // Primary CTA — book call / contact
        if (href.includes('/contact') || href.includes('/تماس') || text.toLowerCase().includes('book') || text.toLowerCase().includes('discovery')) {
          gtagEvent('generate_lead', { event_category: 'CTA', event_label: text.slice(0, 50), page: window.location.pathname });
        }

        // Assess CTA
        if (href.includes('/assess') || text.toLowerCase().includes('assess')) {
          gtagEvent('assess_start', { event_category: 'Assess', event_label: 'cta_click', page: window.location.pathname });
        }

        // Language switch
        if (el.closest('#desktop-nav div, #mobile-lang') && (el as HTMLAnchorElement).href) {
          const lang = (el as HTMLAnchorElement).href.match(/\/(fa|de|sr|en)\//)?.[1] || 'en';
          gtagEvent('language_switch', { event_category: 'Navigation', event_label: lang });
        }

        // Article card clicks
        if (el.closest('.article-card') || href.includes('/articles/')) {
          gtagEvent('article_read', { event_category: 'Content', event_label: text.slice(0, 80) || href });
        }

        // Markets page
        if (href.includes('/markets')) {
          gtagEvent('markets_view', { event_category: 'Navigation', event_label: 'markets_click' });
        }
      });

      // Article scroll depth — fire at 50% and 90%
      if (window.location.pathname.includes('/articles/')) {
        let fired50 = false, fired90 = false;
        window.addEventListener('scroll', () => {
          const pct = (window.scrollY + window.innerHeight) / document.body.scrollHeight;
          if (!fired50 && pct >= 0.5) { fired50 = true; gtagEvent('article_scroll', { event_category: 'Engagement', event_label: '50pct', page: window.location.pathname }); }
          if (!fired90 && pct >= 0.9) { fired90 = true; gtagEvent('article_scroll', { event_category: 'Engagement', event_label: '90pct', page: window.location.pathname }); }
        }, { passive: true });
      }

      // Contact form submission
      document.querySelector('form')?.addEventListener('submit', () => {
        gtagEvent('form_submit', { event_category: 'Lead', event_label: 'contact_form', page: window.location.pathname });
      });
      // ──────────────────────────────────────────────────────────────────

      closeBtn?.addEventListener('click', () => {
        menu!.style.display = 'none';
        document.body.style.overflow = '';
      });
    </script>
  </body>
</html>
