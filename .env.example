# Copy this to .env for local dev — .env is gitignored, never commit it
# GITHUB_TOKEN and Cloudflare tokens are set in Cloudflare Pages env vars, not here

# Example only — no real credentials
# SOME_API_KEY=your_key_here

# ── Hokm card game (client-side, PUBLIC_ vars are inlined into the build) ──
# Google OAuth Web client id (also set as GOOGLE_CLIENT_ID in Pages + Worker)
PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# Local dev only — points the game WebSocket at the local wrangler dev worker.
# Leave UNSET in production (defaults to wss://<same-host>).
PUBLIC_HOKM_WS_BASE=ws://localhost:8787
