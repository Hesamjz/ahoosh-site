---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft && !/^(fa|de|sr)\//.test(p.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect unique tags
const allTags = ['All', ...new Set(posts.flatMap((p) => p.data.tags ?? []))];
---

<BaseLayout title="Articles" description="Practitioner perspectives on AI, B2B operations, and building in emerging markets.">

  <!-- Hero -->
  <section style="
    background: linear-gradient(160deg, #03142E 0%, #010A18 100%);
    padding: 48px 24px 40px;
    text-align: center;
    border-bottom: 1px solid rgba(215,161,61,0.1);
  ">
    <div class="section-eyebrow">Articles</div>
    <h1 style="
      font-family: var(--font-head);
      font-weight: 700;
      font-size: clamp(24px, 6vw, 36px);
      letter-spacing: -0.01em;
      color: var(--silver);
      margin-bottom: 10px;
    ">Intelligence,<br>Written Down</h1>
    <p style="font-size:14px;color:var(--silver-dim);line-height:1.6;max-width:380px;margin:0 auto;">Practitioner perspectives on AI, B2B operations, and building in emerging markets.</p>
  </section>

  <!-- Category filter pills -->
  <div id="tag-filter-row" style="
    padding: 24px 32px 0;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    max-width: 1100px;
    margin: 0 auto;
  ">
    {allTags.map((tag) => (
      <button
        data-tag={tag}
        class="tag-pill"
        style={tag === 'All' ? "flex-shrink:0;background:var(--gold);border:1px solid var(--gold);color:var(--navy-dark);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 14px;border-radius:999px;cursor:pointer;font-family:var(--font-body);" : "flex-shrink:0;background:transparent;border:1px solid rgba(215,161,61,0.25);color:var(--silver-dim);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 14px;border-radius:999px;cursor:pointer;font-family:var(--font-body);"}
      >{tag}</button>
    ))}
  </div>

  <!-- Article grid -->
  <div style="padding:24px 32px 64px;max-width:1100px;margin:0 auto;">

    {posts.length > 0 ? (
      <div id="article-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;">
      {posts.map((post, idx) => (
      <a href={`/articles/${post.id}`} data-tags={(post.data.tags ?? []).join(',')} class="article-card" style="display:block;text-decoration:none;">
        <div class="art-card-inner" style={`
          background: rgba(255,255,255,0.025);
          border: 1px solid rgba(215,161,61,0.12);
          border-radius: 10px;
          padding: 24px;
          height: 100%;
          box-sizing: border-box;
          display: flex;
          flex-direction: column;
          transition: border-color 180ms ease, background 180ms ease;
          ${idx === 0 ? 'border-color:rgba(215,161,61,0.28);background:rgba(215,161,61,0.04);' : ''}
        `}>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
            <div style="font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);background:rgba(215,161,61,0.1);padding:3px 8px;border-radius:4px;">
              {(post.data as any).tags?.[0] ?? 'Article'}
            </div>
            {idx === 0 && <div style="font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);opacity:0.7;">Latest</div>}
          </div>
          <div style="font-family:var(--font-head);font-weight:700;font-size:17px;line-height:1.4;color:var(--silver);margin-bottom:10px;flex:1;">
            {post.data.title}
          </div>
          {post.data.description && (
            <p style="font-size:13px;line-height:1.65;color:var(--silver-dim);margin-bottom:16px;">
              {post.data.description}
            </p>
          )}
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;padding-top:12px;border-top:1px solid rgba(215,161,61,0.08);">
            <span style="font-size:11px;color:var(--silver-muted);">
              {post.data.pubDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
            </span>
            <span style="font-size:12px;font-weight:600;color:var(--gold);letter-spacing:0.04em;">Read →</span>
          </div>
        </div>
      </a>
    ))}
    </div>
    ) : (
      /* Placeholder grid when no posts exist yet */
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;">
        {[
          { tag:'AI Operations', title:'Why Most AI Implementations Fail in the First 90 Days', desc:'The tools are not the problem. The process assumptions underneath them are.', date:'June 2026' },
          { tag:'Marketing', title:'Brevo from Zero to Automated: A Setup Guide for B2B Marketing Teams', desc:'How to configure Brevo for B2B marketing from scratch — list architecture, DKIM/SPF, five automation workflows.', date:'June 2026' },
          { tag:'AI Operations', title:'AI Returns Management in B2B Distribution: What Is Automatable', desc:'Returns cost distributors 20–30% of margin. AI can close that gap — but only on specific steps.', date:'May 2026' },
          { tag:'Emerging Markets', title:'Operating Between Markets: Running AHoosh from Belgrade', desc:'The systems, the surprises, and the compounding advantages of building with AI at the intersection of research and consulting.', date:'April 2026' },
        ].map((p, idx) => (
          <div style={`background:rgba(255,255,255,0.025);border:1px solid rgba(215,161,61,${idx===0?'0.28':'0.1'});border-radius:10px;padding:24px;display:flex;flex-direction:column;${idx===0?'background:rgba(215,161,61,0.04);':''}`}>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
              <div style="font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);background:rgba(215,161,61,0.1);padding:3px 8px;border-radius:4px;">{p.tag}</div>
              {idx===0 && <div style="font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);opacity:0.7;">Latest</div>}
            </div>
            <div style="font-family:var(--font-head);font-weight:700;font-size:17px;line-height:1.4;color:var(--silver);margin-bottom:10px;flex:1;">{p.title}</div>
            <p style="font-size:13px;line-height:1.65;color:var(--silver-dim);margin-bottom:16px;">{p.desc}</p>
            <div style="display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1px solid rgba(215,161,61,0.08);">
              <span style="font-size:11px;color:var(--silver-muted);">{p.date}</span>
              <span style="font-size:12px;font-weight:600;color:var(--gold);opacity:0.6;letter-spacing:0.04em;">Coming soon</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

<script is:inline>
(function () {
  var pills = document.querySelectorAll('.tag-pill');
  var cards = document.querySelectorAll('.article-card');

  function setActive(tag) {
    pills.forEach(function (p) {
      var active = p.dataset.tag === tag;
      p.style.background = active ? 'var(--gold)' : 'transparent';
      p.style.color = active ? 'var(--navy-dark)' : 'var(--silver-dim)';
      p.style.borderColor = active ? 'var(--gold)' : 'rgba(215,161,61,0.3)';
    });
    cards.forEach(function (c) {
      if (tag === 'All') {
        c.style.display = 'block';
      } else {
        var tags = (c.dataset.tags || '').split(',');
        c.style.display = tags.indexOf(tag) > -1 ? 'block' : 'none';
      }
    });
  }

  pills.forEach(function (p) {
    p.addEventListener('click', function () { setActive(p.dataset.tag); });
  });
})();
</script>

<style>
  .art-card-inner:hover {
    border-color: rgba(215,161,61,0.4) !important;
    background: rgba(215,161,61,0.06) !important;
  }
  @media (max-width: 680px) {
    #article-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

</BaseLayout>
